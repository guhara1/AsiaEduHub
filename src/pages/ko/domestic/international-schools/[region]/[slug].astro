---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import Flag from '~/components/Flag.astro';
import SchoolFinancialDetails from '~/components/SchoolFinancialDetails.astro';
import SchoolNeighborhood from '~/components/SchoolNeighborhood.astro';
import { deriveFinance } from '~/lib/school-finance';
import { SCHOOL_NEIGHBORHOODS } from '~/lib/school-neighborhood';
import { domesticToFinanceInput } from '~/lib/domestic-schools';
import { INTERNATIONAL_SCHOOLS, REGION_METAS, COMMON_ELIGIBILITY, COMMON_ADMISSION_PROCESS } from '~/lib/domestic-schools';

export async function getStaticPaths() {
  return INTERNATIONAL_SCHOOLS.map((s) => ({
    params: { region: s.region, slug: s.slug },
    props: { school: s },
  }));
}

const { school: s } = Astro.props;
const meta = REGION_METAS.find((r) => r.category === 'international-schools' && r.id === s.region)!;

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const title = `${s.name_ko} (${s.name_en}) — 내국인 입학 · 커리큘럼 · 학비 완벽 정리 | AsiaEduHub`;
const description = s.summary_ko;

const eduOrg = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: s.name_en,
  alternateName: [s.name_ko, s.name_zh].filter(Boolean),
  url: s.website,
  sameAs: [s.website].filter(Boolean),
  foundingDate: s.founded_year ? `${s.founded_year}` : undefined,
  address: { '@type': 'PostalAddress', addressLocality: s.city_ko, addressCountry: 'KR' },
  description: s.summary_ko,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `${s.name_ko} 학비 (연)`,
    itemListElement: [{
      '@type': 'Offer',
      priceCurrency: 'USD',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: s.tuition_range_usd[0],
        maxPrice: s.tuition_range_usd[1],
        priceCurrency: 'USD',
      },
      category: '연 학비',
    }],
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '국내 국제학교', item: (Astro.site?.toString() ?? '') + 'ko/domestic/' },
    { '@type': 'ListItem', position: 3, name: meta.ko, item: (Astro.site?.toString() ?? '') + `ko/domestic/international-schools/${s.region}/` },
    { '@type': 'ListItem', position: 4, name: s.name_ko },
  ],
};

const elig = COMMON_ELIGIBILITY['international-schools'].ko;
const proc = COMMON_ADMISSION_PROCESS.ko;

const otherSchools = INTERNATIONAL_SCHOOLS.filter((o) => o.region === s.region && o.slug !== s.slug);
const finance = deriveFinance(domesticToFinanceInput(s));
const neighborhoods = SCHOOL_NEIGHBORHOODS[s.slug] ?? [];
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[eduOrg, breadcrumb]}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="hero-gradient hero-gradient-korea school-hero-wrap">
    <div class="container-content pt-10 sm:pt-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/ko/domestic/">국내 국제학교</a> ·
        <a href={`/ko/domestic/international-schools/${s.region}/`}>{meta.ko}</a> · <span style="color: var(--color-text-primary)">{s.name_ko}</span>
      </nav>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <span class="badge-navy"><Flag country="KR" />국제학교 (내국인 입학 가능)</span>
        {s.founded_year && <span class="badge-navy">{s.founded_year} 개교</span>}
      </div>

      <h1 class="mt-5 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.02em">{s.name_ko}</h1>
      <p class="mt-2 text-base" style="color: var(--color-text-secondary); font-weight:500">{s.name_en}{s.abbreviation && ` · ${s.abbreviation}`}</p>
      <p class="mt-5 max-w-2xl text-base sm:text-lg text-pretty" style="color: var(--color-text-secondary); line-height: 1.7;">{s.summary_ko}</p>

      <div class="mt-6">
        <AuthorByline locale="ko" publishedAt={publishedAt} updatedAt={updatedAt}
          sources={`${s.name_ko} 공식 사이트, 제주특별법 / 인천경제자유구역법, 학교 입학 안내`} />
      </div>

      <div class="mt-5">
        <a href={s.website} target="_blank" rel="noopener" class="official-site-button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.7"/>
            <path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20" stroke="currentColor" stroke-width="1.7"/>
          </svg>
          공식 사이트 방문
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M7 17L17 7M7 7h10v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <div class="container-content school-stats-overlap">
    <dl class="stat-grid grid-cols-2 lg:grid-cols-4">
      <div class="stat-card">
        <span class="stat-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-7.5-7-12a7 7 0 1114 0c0 4.5-7 12-7 12z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.8"/></svg>
        </span>
        <dt>위치</dt>
        <dd>{s.city_ko}{s.district_ko && <><br/><span class="text-sm" style="color:var(--color-text-secondary); font-weight:500">{s.district_ko}</span></>}</dd>
      </div>
      <div class="stat-card">
        <span class="stat-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M2 7l10-4 10 4-10 4L2 7zM6 9v5c0 2 3 3 6 3s6-1 6-3V9" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
        </span>
        <dt>학년</dt>
        <dd>{s.grade_range}</dd>
      </div>
      <div class="stat-card">
        <span class="stat-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 5h16v14H4zM4 9h16M9 5v14" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
        </span>
        <dt>커리큘럼</dt>
        <dd class="text-sm" style="font-weight:600">{s.curriculum_en.join(' · ')}</dd>
      </div>
      <div class="stat-card stat-card-tuition">
        <span class="stat-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </span>
        <dt>연 학비 (추정)</dt>
        <dd>${s.tuition_range_usd[0].toLocaleString()}~${s.tuition_range_usd[1].toLocaleString()}</dd>
        <p class="tuition-note">학교 공식 발표 확인</p>
      </div>
    </dl>
  </div>

  <article class="container-content pt-6 pb-12 max-w-3xl">

    <section class="mt-10">
      <h2 class="text-xl">{s.name_ko} 핵심 특징</h2>
      <p class="mt-2 text-xs text-[color:var(--color-text-tertiary)]">학교 공식 자료 기반 객관 정리</p>
      <ul class="mt-4 space-y-2 text-sm">
        {s.highlights_ko.map((h) => <li>✓ {h}</li>)}
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-xl">입학 자격 — 내국인 입학 가능</h2>
      <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">
        {s.name_ko}는 한국 정부가 인가한 국제학교로 내국인 자녀도 외국 거주 이력 없이 입학 가능합니다.
        졸업 시 한국 학력으로 인정됩니다.
      </p>
      <ul class="mt-4 space-y-2 text-sm">
        {elig.map((e) => <li>• {e}</li>)}
      </ul>
      <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">
        영어 능력 시험·인터뷰 등 학교별 입학 평가 통과 필수.
      </p>
    </section>

    <SchoolFinancialDetails details={finance} locale="ko" schoolName={s.name_ko} />

    {neighborhoods.length > 0 && <SchoolNeighborhood neighborhoods={neighborhoods} locale="ko" />}

    <section class="mt-10">
      <h2 class="text-xl">입학 절차</h2>
      <ol class="mt-4 space-y-2 text-sm">
        {proc.map((p) => <li>• {p}</li>)}
      </ol>
    </section>

    <section class="mt-10 rounded-lg border-l-4 border-accent-500 bg-accent-100 p-5">
      <div class="text-xs uppercase tracking-wide text-accent-700">운영자 한마디 (작성 예정)</div>
      <p class="mt-2 text-sm text-accent-700">
        운영자(데이비드)가 {s.name_ko} 입학설명회·재학생 인터뷰·캠퍼스 방문 후 학부모 관점 분석을 추가합니다.
        한국인 학생 비율, 교사 국적, 보딩 환경, 졸업생 진학 결과 등 학교 공식 자료에 없는 디테일은
        <a href="/ko/contact/" class="underline">운영자에게 직접 문의</a> 가능합니다.
      </p>
    </section>

    {otherSchools.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl">같은 지역 다른 학교</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {otherSchools.map((o) => (
            <a href={`/ko/domestic/international-schools/${o.region}/${o.slug}/`} class="block rounded-md border p-4 text-sm hover:border-primary-700" style="border-color: var(--color-border-light)">
              <div class="text-primary-900" style="font-weight:500">{o.name_ko}</div>
              <div class="mt-1 text-xs text-[color:var(--color-text-secondary)]">{o.curriculum_en.join(' · ')}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mt-12 rounded-lg bg-primary-900 p-6 text-white">
      <h2 class="text-lg" style="font-weight:500">{s.name_ko} 입학 상담</h2>
      <p class="mt-2 text-sm opacity-90">
        자녀 학년 · 영어 수준 · 보딩 여부 · 졸업 후 진학 국가를 알려주시면 {s.name_ko}와 비교 가능한 학교까지 1:1 답변.
      </p>
      <div class="mt-4">
        <a href="/ko/contact/" class="inline-flex items-center rounded-md bg-white px-4 py-2 text-sm text-primary-900" style="font-weight:500">카카오톡 · 이메일 상담 →</a>
      </div>
    </section>

    <p class="mt-8 text-xs text-[color:var(--color-text-tertiary)]">
      ※ 본 페이지는 {s.name_ko} 공식 자료 기반으로 운영자(데이비드)가 정리한 정보 페이지입니다. 학교 정책·학비·자격은 매년 변경 가능하므로 학교 공식 사이트에서 최신 정보 확인.
    </p>
  </article>
</BaseLayout>
