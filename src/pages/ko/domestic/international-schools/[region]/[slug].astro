---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import { INTERNATIONAL_SCHOOLS, REGION_METAS, COMMON_ELIGIBILITY, COMMON_ADMISSION_PROCESS } from '~/lib/domestic-schools';

export async function getStaticPaths() {
  return INTERNATIONAL_SCHOOLS.map((s) => ({
    params: { region: s.region, slug: s.slug },
    props: { school: s },
  }));
}

const { school: s } = Astro.props;
const meta = REGION_METAS.find((r) => r.category === 'international-schools' && r.id === s.region)!;

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const title = `${s.name_ko} (${s.name_en}) — 내국인 입학 · 커리큘럼 · 학비 완벽 정리 | AsiaEduHub`;
const description = s.summary_ko;

const eduOrg = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: s.name_en,
  alternateName: [s.name_ko, s.name_zh].filter(Boolean),
  url: s.website,
  foundingDate: s.founded_year ? `${s.founded_year}` : undefined,
  address: { '@type': 'PostalAddress', addressLocality: s.city_ko, addressCountry: 'KR' },
  description: s.summary_ko,
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '국내 국제학교', item: (Astro.site?.toString() ?? '') + 'ko/domestic/' },
    { '@type': 'ListItem', position: 3, name: meta.ko, item: (Astro.site?.toString() ?? '') + `ko/domestic/international-schools/${s.region}/` },
    { '@type': 'ListItem', position: 4, name: s.name_ko },
  ],
};

const elig = COMMON_ELIGIBILITY['international-schools'].ko;
const proc = COMMON_ADMISSION_PROCESS.ko;

const otherSchools = INTERNATIONAL_SCHOOLS.filter((o) => o.region === s.region && o.slug !== s.slug);
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[eduOrg, breadcrumb]}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="hero-gradient border-b" style="border-color: var(--color-border-light)">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/ko/domestic/">국내 국제학교</a> ·
        <a href={`/ko/domestic/international-schools/${s.region}/`}>{meta.ko}</a> · {s.name_ko}
      </nav>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <span class="badge-navy">🇰🇷 국제학교 (내국인 입학 가능)</span>
        {s.founded_year && <span class="badge-navy">{s.founded_year} 개교</span>}
      </div>

      <h1 class="mt-4 text-3xl sm:text-4xl text-balance">{s.name_ko}</h1>
      <p class="mt-2 text-sm" style="color: var(--color-text-secondary)">{s.name_en}{s.abbreviation && ` (${s.abbreviation})`}</p>
      <p class="mt-4 max-w-2xl text-base text-pretty" style="color: var(--color-text-secondary); line-height: 1.65;">{s.summary_ko}</p>

      <div class="mt-5">
        <AuthorByline locale="ko" publishedAt={publishedAt} updatedAt={updatedAt}
          sources={`${s.name_ko} 공식 사이트, 제주특별법 / 인천경제자유구역법, 학교 입학 안내`} />
      </div>
    </div>
  </section>

  <article class="container-content py-10 max-w-3xl">
    <section class="stat-grid grid-cols-2 lg:grid-cols-4">
      <div class="stat-card">
        <dt>위치</dt>
        <dd>{s.city_ko}{s.district_ko && ` · ${s.district_ko}`}</dd>
      </div>
      <div class="stat-card">
        <dt>학년</dt>
        <dd>{s.grade_range}</dd>
      </div>
      <div class="stat-card">
        <dt>커리큘럼</dt>
        <dd class="text-sm">{s.curriculum_en.join(' · ')}</dd>
      </div>
      <div class="stat-card">
        <dt>연 학비 (추정)</dt>
        <dd>${s.tuition_range_usd[0].toLocaleString()} – ${s.tuition_range_usd[1].toLocaleString()}</dd>
        <p class="mt-1 text-[11px]" style="color: var(--color-text-tertiary)">정확한 학비는 학교 공식 발표 확인</p>
      </div>
    </section>

    <p class="mt-4 text-xs text-[color:var(--color-text-tertiary)]">
      공식 사이트: <a href={s.website} target="_blank" rel="noopener" class="text-primary-700 hover:underline">{s.website} ↗</a>
    </p>

    <section class="mt-10">
      <h2 class="text-xl">{s.name_ko} 핵심 특징</h2>
      <p class="mt-2 text-xs text-[color:var(--color-text-tertiary)]">학교 공식 자료 기반 객관 정리</p>
      <ul class="mt-4 space-y-2 text-sm">
        {s.highlights_ko.map((h) => <li>✓ {h}</li>)}
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-xl">입학 자격 — 내국인 입학 가능</h2>
      <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">
        {s.name_ko}는 한국 정부가 인가한 국제학교로 내국인 자녀도 외국 거주 이력 없이 입학 가능합니다.
        졸업 시 한국 학력으로 인정됩니다.
      </p>
      <ul class="mt-4 space-y-2 text-sm">
        {elig.map((e) => <li>• {e}</li>)}
      </ul>
      <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">
        영어 능력 시험·인터뷰 등 학교별 입학 평가 통과 필수.
      </p>
    </section>

    <section class="mt-10 rounded-lg border bg-[color:var(--color-bg-secondary)] p-5" style="border-color: var(--color-border-light)">
      <h2 class="text-lg" style="font-weight:500">학비 + 부대 비용 안내</h2>
      <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">
        연 학비 추정: <strong style="font-weight:500">${s.tuition_range_usd[0].toLocaleString()} – ${s.tuition_range_usd[1].toLocaleString()}</strong>.
        제주 국제학교는 보딩(기숙) 옵션 있음 — 기숙비 별도.
      </p>
      <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">학비 외:</p>
      <ul class="mt-2 space-y-1 text-sm text-[color:var(--color-text-secondary)]">
        <li>• 입학금 (연 학비의 10~30%)</li>
        <li>• 기숙비 (보딩 선택 시) — 학교별 큰 차이</li>
        <li>• 시설비 · 교복 · 교재 · 식비</li>
        <li>• 시험 응시료</li>
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-xl">입학 절차</h2>
      <ol class="mt-4 space-y-2 text-sm">
        {proc.map((p) => <li>• {p}</li>)}
      </ol>
    </section>

    <section class="mt-10 rounded-lg border-l-4 border-accent-500 bg-accent-100 p-5">
      <div class="text-xs uppercase tracking-wide text-accent-700">운영자 한마디 (작성 예정)</div>
      <p class="mt-2 text-sm text-accent-700">
        운영자(데이비드)가 {s.name_ko} 입학설명회·재학생 인터뷰·캠퍼스 방문 후 학부모 관점 분석을 추가합니다.
        한국인 학생 비율, 교사 국적, 보딩 환경, 졸업생 진학 결과 등 학교 공식 자료에 없는 디테일은
        <a href="/ko/contact/" class="underline">운영자에게 직접 문의</a> 가능합니다.
      </p>
    </section>

    {otherSchools.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl">같은 지역 다른 학교</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {otherSchools.map((o) => (
            <a href={`/ko/domestic/international-schools/${o.region}/${o.slug}/`} class="block rounded-md border p-4 text-sm hover:border-primary-700" style="border-color: var(--color-border-light)">
              <div class="text-primary-900" style="font-weight:500">{o.name_ko}</div>
              <div class="mt-1 text-xs text-[color:var(--color-text-secondary)]">{o.curriculum_en.join(' · ')}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mt-12 rounded-lg bg-primary-900 p-6 text-white">
      <h2 class="text-lg" style="font-weight:500">{s.name_ko} 입학 상담</h2>
      <p class="mt-2 text-sm opacity-90">
        자녀 학년 · 영어 수준 · 보딩 여부 · 졸업 후 진학 국가를 알려주시면 {s.name_ko}와 비교 가능한 학교까지 1:1 답변.
      </p>
      <div class="mt-4">
        <a href="/ko/contact/" class="inline-flex items-center rounded-md bg-white px-4 py-2 text-sm text-primary-900" style="font-weight:500">카카오톡 · 이메일 상담 →</a>
      </div>
    </section>

    <p class="mt-8 text-xs text-[color:var(--color-text-tertiary)]">
      ※ 본 페이지는 {s.name_ko} 공식 자료 기반으로 운영자(데이비드)가 정리한 정보 페이지입니다. 학교 정책·학비·자격은 매년 변경 가능하므로 학교 공식 사이트에서 최신 정보 확인.
    </p>
  </article>
</BaseLayout>
