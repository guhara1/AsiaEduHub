---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import { FOREIGN_SCHOOLS, REGION_METAS, COMMON_ELIGIBILITY, COMMON_ADMISSION_PROCESS, getRegionFaqs, type DomesticRegion } from '~/lib/domestic-schools';

export async function getStaticPaths() {
  const regions = REGION_METAS.filter((r) => r.category === 'foreign-schools');
  return regions.map((r) => ({
    params: { region: r.id },
    props: { regionId: r.id },
  }));
}

const { regionId } = Astro.props as { regionId: DomesticRegion };
const meta = REGION_METAS.find((r) => r.category === 'foreign-schools' && r.id === regionId)!;
const schools = FOREIGN_SCHOOLS.filter((s) => s.region === regionId);

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const title = `${meta.ko} — 학교별 상세 비교 (학비 · 커리큘럼 · 입학 자격) | AsiaEduHub`;
const description = `${meta.ko} 전체 목록: ${schools.map((s) => s.abbreviation || s.name_en).join(' · ')}. 입학 자격, 커리큘럼, 학비 범위, 공식 사이트, 자주 묻는 질문을 학교별로 정리.`;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '국내 국제학교', item: (Astro.site?.toString() ?? '') + 'ko/domestic/' },
    { '@type': 'ListItem', position: 3, name: '외국인학교' },
    { '@type': 'ListItem', position: 4, name: meta.ko },
  ],
};
const elig = COMMON_ELIGIBILITY['foreign-schools'].ko;
const proc = COMMON_ADMISSION_PROCESS.ko;
const faqs = getRegionFaqs(regionId);

const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q_ko,
    acceptedAnswer: { '@type': 'Answer', text: f.a_ko },
  })),
} : null;
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={faqSchema ? [breadcrumb, faqSchema] : breadcrumb}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="hero-gradient border-b" style="border-color: var(--color-border-light)">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/ko/">홈</a> · <a href="/ko/domestic/">국내 국제학교</a> · 외국인학교 · {meta.ko}
      </nav>
      <h1 class="mt-3 text-3xl sm:text-4xl text-balance">{meta.ko}</h1>
      <p class="mt-4 max-w-2xl text-base text-pretty" style="color: var(--color-text-secondary); line-height: 1.65;">{meta.intro_ko}</p>
      <div class="mt-5">
        <AuthorByline locale="ko" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="외국인학교법, 각 학교 공식 사이트, 학교별 입학 안내 자료" />
      </div>
    </div>
  </section>

  <section class="container-content py-10">

    {/* 학교 목록 */}
    <section class="mt-8">
      <h2 class="text-xl">{meta.ko} — 학교 {schools.length}곳</h2>
      <div class="mt-4 grid gap-5 md:grid-cols-2">
        {schools.map((s) => (
          <a href={`/ko/domestic/foreign-schools/${s.region}/${s.slug}/`} class="block rounded-lg border p-5 transition-colors hover:border-primary-700" style="border-color: var(--color-border-light)">
            <div class="flex items-baseline justify-between">
              <h3 class="text-lg text-primary-900" style="font-weight:500">{s.name_ko}</h3>
              {s.founded_year && <span class="text-xs text-[color:var(--color-text-tertiary)]">{s.founded_year} 설립</span>}
            </div>
            <p class="mt-1 text-xs text-[color:var(--color-text-secondary)]">{s.name_en}{s.abbreviation && ` (${s.abbreviation})`}</p>
            <p class="mt-1 text-xs text-[color:var(--color-text-tertiary)]">
              {s.city_ko}{s.district_ko && ` · ${s.district_ko}`}
            </p>
            <p class="mt-3 text-sm text-[color:var(--color-text-secondary)]">{s.summary_ko}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {s.curriculum_en.map((c) => (
                <span class="rounded-full bg-[color:var(--color-bg-tertiary)] px-2 py-0.5 text-[10px] text-[color:var(--color-text-secondary)]">{c}</span>
              ))}
            </div>
            <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">
              연 학비 (추정): ${s.tuition_range_usd[0].toLocaleString()} – ${s.tuition_range_usd[1].toLocaleString()}
            </p>
          </a>
        ))}
      </div>
    </section>

    {/* 외국인학교 공통 입학 자격 */}
    <section class="mt-12">
      <h2 class="text-xl">외국인학교 공통 입학 자격</h2>
      <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">
        외국인학교법(2009) 기준 — {meta.ko} 모든 학교에 공통 적용. 학교별 추가 요건은 각 학교 공식 사이트 확인.
      </p>
      <ul class="mt-4 space-y-2 text-sm">
        {elig.map((e) => <li>• {e}</li>)}
      </ul>
      <p class="mt-4 rounded-md border-l-4 border-accent-500 bg-accent-100 p-3 text-xs text-accent-700">
        ⚠ 내국인은 외국인학교 입학이 매우 제한적. 부모 외국 국적 또는 학생 해외 3년+ 거주가 필수. 단순 영어 환경 목적이면 <a href="/ko/domestic/international-schools/jeju/" class="underline">제주 국제학교</a> 검토 권장.
      </p>
    </section>

    {/* 입학 일정 */}
    <section class="mt-10">
      <h2 class="text-xl">입학 일정 (가을 학기 기준)</h2>
      <ol class="mt-4 space-y-2 text-sm">
        {proc.map((p) => <li>• {p}</li>)}
      </ol>
    </section>

    {/* 학비 안내 */}
    <section class="mt-10 rounded-lg border bg-[color:var(--color-bg-secondary)] p-5" style="border-color: var(--color-border-light)">
      <h2 class="text-lg" style="font-weight:500">학비 외 추가 비용 (공통)</h2>
      <ul class="mt-3 space-y-1 text-sm text-[color:var(--color-text-secondary)]">
        <li>• 입학금 (연 학비의 10~30%)</li>
        <li>• 시설 분담금</li>
        <li>• 교복 · 교재</li>
        <li>• 스쿨버스 (월 30~80만원)</li>
        <li>• 식비 (월 30~60만원)</li>
        <li>• 시험 응시료 (IB · AP · SAT 등)</li>
      </ul>
      <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">
        연간 학비의 15~25% 추가로 보는 것이 안전.
      </p>
    </section>

    {/* 학교별 빠른 이동 */}
    <section class="mt-10">
      <h2 class="text-xl">학교별 상세 페이지</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {schools.map((s) => (
          <a href={`/ko/domestic/foreign-schools/${s.region}/${s.slug}/`} class="rounded-full border px-3 py-1 text-xs hover:border-primary-700 hover:text-primary-700" style="border-color: var(--color-border-light)">
            {s.name_ko} →
          </a>
        ))}
      </div>
    </section>

    {/* FAQ */}
    {faqs.length > 0 && (
      <section id="faq" class="mt-12 scroll-mt-24">
        <h2 class="text-xl">{meta.ko} 자주 묻는 질문</h2>
        <div class="mt-5 space-y-3">
          {faqs.map((f) => (
            <details class="rounded-lg border p-4" style="border-color: var(--color-border-light)">
              <summary class="cursor-pointer text-sm text-primary-900" style="font-weight:500; list-style: disclosure-closed">{f.q_ko}</summary>
              <p class="mt-3 text-sm text-[color:var(--color-text-primary)]">{f.a_ko}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <section class="mt-12 rounded-lg bg-primary-900 p-6 text-white">
      <h2 class="text-lg" style="font-weight:500">자녀에게 맞는 학교 선택이 어렵다면</h2>
      <p class="mt-2 text-sm opacity-90">
        외국 거주 이력 · 자녀 학년 · 한국인 비율 선호 · 예산을 함께 알려주시면 운영자가 학교별 비교를 1:1 답변.
      </p>
      <div class="mt-4">
        <a href="/ko/contact/" class="inline-flex items-center rounded-md bg-white px-4 py-2 text-sm text-primary-900" style="font-weight:500">카카오톡 · 이메일 상담 →</a>
      </div>
    </section>
  </section>
</BaseLayout>
