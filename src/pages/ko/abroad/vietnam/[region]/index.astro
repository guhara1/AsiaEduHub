---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Flag from '~/components/Flag.astro';
import { VIETNAM_SCHOOLS, VN_REGION_LABELS, type VnRegion } from '~/lib/vietnam-schools';

export async function getStaticPaths() {
  const regions: VnRegion[] = ['hanoi', 'ho-chi-minh', 'hai-phong', 'da-nang'];
  return regions.map((region) => ({ params: { region }, props: { region } }));
}

const { region } = Astro.props as { region: VnRegion };
const regionLabel = VN_REGION_LABELS[region];
const schools = VIETNAM_SCHOOLS.filter((s) => s.region === region);

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const title = `베트남 ${regionLabel.ko} 국제학교 ${schools.length}곳 — 학교별 학비·커리큘럼 | AsiaEduHub`;
const description = `${regionLabel.ko} 지역 국제학교 ${schools.length}곳. ${schools.slice(0, 3).map(s => s.name_ko).join(' · ')} 등.`;

const siteRoot = Astro.site?.toString() ?? '';
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: siteRoot + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '해외 유학', item: siteRoot + 'ko/abroad/' },
    { '@type': 'ListItem', position: 3, name: '베트남', item: siteRoot + 'ko/abroad/vietnam/' },
    { '@type': 'ListItem', position: 4, name: regionLabel.ko },
  ],
};

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `베트남 ${regionLabel.ko} 국제학교`,
  numberOfItems: schools.length,
  itemListElement: schools.map((s, i) => ({
    '@type': 'ListItem', position: i + 1, name: s.name_ko,
    url: siteRoot + `ko/abroad/vietnam/${s.region}/${s.slug}/`,
  })),
};
---
<BaseLayout
  title={title} description={description}
  jsonLd={[breadcrumb, itemList]}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt} updatedAt={updatedAt}
>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/ko/abroad/">해외 유학</a> · <a href="/ko/abroad/vietnam/"><Flag country="VN" />베트남</a> · <span style="color: var(--color-text-primary)">{regionLabel.ko}</span>
      </nav>
      <h1 class="mt-4 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.02em">
        🇻🇳 {regionLabel.ko} 국제학교 {schools.length}곳
      </h1>
      <p class="mt-3 max-w-2xl text-base" style="color: var(--color-text-secondary); line-height: 1.7;">
        {regionLabel.ko} 지역 국제학교 학교별 상세 — 커리큘럼 · 학비 · 위치.
      </p>
    </div>
  </section>

  <article class="container-content py-10 max-w-4xl">
    <div class="grid gap-3 sm:grid-cols-2">
      {schools.map((s) => (
        <a href={`/ko/abroad/vietnam/${s.region}/${s.slug}/`} class="card text-sm block">
          <div class="text-primary-900" style="font-weight:600">{s.name_ko}</div>
          <div class="mt-1 text-xs" style="color: var(--color-text-secondary)">{s.name_en}{s.abbreviation ? ` · ${s.abbreviation}` : ''}</div>
          <p class="mt-2 text-xs" style="color: var(--color-text-secondary); line-height:1.55">{s.summary_ko}</p>
          <div class="mt-3 flex flex-wrap gap-1">
            <span class="badge-outlined">{s.curriculum.type}</span>
            {s.boarding && <span class="badge-navy">보딩</span>}
            {s.founded_year && <span class="badge-outlined">{s.founded_year}</span>}
          </div>
          <div class="mt-2 text-xs" style="color: var(--color-text-tertiary)">
            연 ${s.tuition_range_usd[0].toLocaleString()}~${s.tuition_range_usd[1].toLocaleString()}
          </div>
        </a>
      ))}
    </div>

    <section class="mt-12 card-cta">
      <h2 class="text-xl text-white" style="font-weight:500">{regionLabel.ko} 학교 입학 상담</h2>
      <p class="mt-3 text-sm opacity-95">자녀 학년 · 영어 수준 · 예산을 알려주시면 1:1 답변.</p>
      <a href="/ko/contact/" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-3 text-primary-900" style="font-weight:500">
        카카오톡 · 이메일 상담
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
    </section>
  </article>
</BaseLayout>
