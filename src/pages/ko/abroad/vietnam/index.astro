---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import Flag from '~/components/Flag.astro';
import { VIETNAM_SCHOOLS, VN_REGION_LABELS, type VnRegion } from '~/lib/vietnam-schools';

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const title = '베트남 국제학교 22곳 — 하노이 · 호치민 · 하이퐁 · 다낭 학교별 상세 | AsiaEduHub';
const description =
  'BIS · Dwight · ISHCMC · EIS · BVIS · TAS · CIS · ABCIS · WIS · Dewey · Horizon · APU 등 베트남 국제학교 22곳의 커리큘럼·학비·위치·바이링궐 옵션 정리.';

const siteRoot = Astro.site?.toString() ?? '';
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: siteRoot + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '해외 유학', item: siteRoot + 'ko/abroad/' },
    { '@type': 'ListItem', position: 3, name: '베트남' },
  ],
};

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '베트남 국제학교 22곳',
  numberOfItems: VIETNAM_SCHOOLS.length,
  itemListElement: VIETNAM_SCHOOLS.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.name_ko,
    url: siteRoot + `ko/abroad/vietnam/${s.region}/${s.slug}/`,
  })),
};

const regions: VnRegion[] = ['hanoi', 'ho-chi-minh', 'hai-phong', 'da-nang'];
const byRegion: Record<VnRegion, typeof VIETNAM_SCHOOLS> = {
  'hanoi': VIETNAM_SCHOOLS.filter((s) => s.region === 'hanoi'),
  'ho-chi-minh': VIETNAM_SCHOOLS.filter((s) => s.region === 'ho-chi-minh'),
  'hai-phong': VIETNAM_SCHOOLS.filter((s) => s.region === 'hai-phong'),
  'da-nang': VIETNAM_SCHOOLS.filter((s) => s.region === 'da-nang'),
};
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumb, itemList]}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/ko/">홈</a> · <a href="/ko/abroad/">해외 유학</a> · <Flag country="VN" />베트남
      </nav>

      <h1 class="mt-4 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.02em">
        🇻🇳 베트남 국제학교 22곳
      </h1>
      <p class="mt-3 max-w-2xl text-base sm:text-lg text-pretty" style="color: var(--color-text-secondary); line-height: 1.7;">
        하노이 · 호치민 · 하이퐁 · 다낭 4개 지역. 영국식 · 미국식 · IB · 캐나다 · 바이링궐 (영·베) 학교 종합 정리. ISHCMC · EIS · BIS · Dwight 등 글로벌 명문 다수.
      </p>

      <div class="mt-5">
        <AuthorByline locale="ko" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="각 학교 공식 사이트, 학교 입학 안내, 학부모 커뮤니티 청취" />
      </div>
    </div>
  </section>

  <article class="container-content py-10 max-w-4xl">
    {regions.map((r) => byRegion[r].length > 0 && (
      <section class="mt-10" id={r}>
        <h2 class="text-xl sm:text-2xl" style="font-weight:700; letter-spacing:-0.01em">
          <Flag country="VN" />{VN_REGION_LABELS[r].ko} <span style="color: var(--color-text-tertiary); font-weight:500; font-size: 0.85em">({byRegion[r].length}곳)</span>
        </h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {byRegion[r].map((s) => (
            <a href={`/ko/abroad/vietnam/${s.region}/${s.slug}/`} class="card text-sm block">
              <div class="text-primary-900" style="font-weight:600">{s.name_ko}</div>
              <div class="mt-1 text-xs" style="color: var(--color-text-secondary)">
                {s.name_en}{s.abbreviation ? ` · ${s.abbreviation}` : ''}
              </div>
              <div class="mt-2 flex flex-wrap gap-1">
                <span class="badge-outlined">{s.curriculum.type}</span>
                {s.boarding && <span class="badge-navy">보딩</span>}
                {s.founded_year && <span class="badge-outlined">{s.founded_year}</span>}
              </div>
              <div class="mt-2 text-xs" style="color: var(--color-text-tertiary)">
                연 ${s.tuition_range_usd[0].toLocaleString()}~${s.tuition_range_usd[1].toLocaleString()}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 card-cta">
      <h2 class="text-xl text-white" style="font-weight:500">베트남 국제학교 입학 상담</h2>
      <p class="mt-3 text-sm opacity-95">
        자녀 학년 · 영어 수준 · 지역(하노이·호치민·하이퐁·다낭) · 바이링궐 희망 여부 · 예산을 알려주시면 1:1 답변.
      </p>
      <a href="/ko/contact/" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-3 text-primary-900" style="font-weight:500">
        카카오톡 · 이메일 상담
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
    </section>
  </article>
</BaseLayout>
