---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import Flag from '~/components/Flag.astro';
import { ANGLOSPHERE_INFO, ANGLO_KEYS } from '~/lib/anglosphere-info';

export async function getStaticPaths() {
  return ANGLO_KEYS.map((country) => ({ params: { country }, props: { country } }));
}

const { country } = Astro.props as { country: string };
const info = ANGLOSPHERE_INFO[country];

const publishedAt = new Date('2026-05-21');
const updatedAt = new Date('2026-05-21');

const title = `${info.name_ko} 보딩스쿨·국제학교 종합 가이드 — 학비·비자·입학 시험·진학 트랙 | AsiaEduHub`;
const description = info.tagline_ko + ' 학비 ' + info.tuition_local + ', 비자·입학 시험·명문 학교까지 한 페이지 정리.';

const siteRoot = Astro.site?.toString() ?? '';
const flagCode = country === 'usa' ? 'US' : country === 'uk' ? 'UK' : country === 'canada' ? 'CA' : 'AU';

const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: siteRoot + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '해외 유학', item: siteRoot + 'ko/abroad/' },
    { '@type': 'ListItem', position: 3, name: info.name_ko },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: info.faqs.map((f) => ({
    '@type': 'Question', name: f.q_ko,
    acceptedAnswer: { '@type': 'Answer', text: f.a_ko },
  })),
};
---
<BaseLayout
  title={title} description={description}
  jsonLd={[breadcrumb, faqSchema]}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt} updatedAt={updatedAt}
>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/ko/">홈</a> · <a href="/ko/abroad/">해외 유학</a> · <span style="color: var(--color-text-primary)">{info.name_ko}</span>
      </nav>
      <div class="mt-4 flex flex-wrap items-center gap-2">
        <span class="badge-navy"><Flag country={flagCode as any} />영미권 프리미엄</span>
        <span class="badge-navy">{info.tuition_usd}</span>
      </div>
      <h1 class="mt-5 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.022em">
        {info.flag} {info.name_ko}
      </h1>
      <p class="mt-4 max-w-2xl text-base sm:text-lg text-pretty" style="color: var(--color-text-secondary); line-height: 1.7;">
        {info.tagline_ko}
      </p>
      <div class="mt-5">
        <AuthorByline locale="ko" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="각국 정부 공식 자료, 학교 공식 사이트, 운영자 학부모 커뮤니티 청취" />
      </div>
    </div>
  </section>

  <article class="container-content py-10 max-w-3xl">

    {/* 핵심 요약 */}
    <div class="rounded-2xl p-6 mt-2" style="background: linear-gradient(135deg, #FFFBF0 0%, #FEF9E7 100%); border: 1px solid #FCD34D">
      <div class="text-xs uppercase tracking-wider" style="color: var(--color-accent-700); font-weight: 700; letter-spacing: 0.08em">✦ 핵심 요약</div>
      <p class="mt-3 text-base" style="color: var(--color-accent-700); line-height: 1.7; font-weight: 500">
        {info.tagline_ko} <strong>학비 {info.tuition_local}</strong>. {info.destinations_ko}
      </p>
    </div>

    {/* 핵심 포인트 */}
    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">한국 학부모 관점 핵심 포인트</h2>
      <ul class="mt-5 space-y-2 text-sm" style="line-height:1.75">
        {info.key_points_ko.map((p) => <li>✓ {p}</li>)}
      </ul>
    </section>

    {/* 교육 시스템 */}
    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">교육 시스템 개요</h2>
      <p class="mt-3 text-base" style="line-height:1.75">{info.system_ko}</p>
    </section>

    {/* 비자 */}
    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">비자 정보</h2>
      <div class="mt-4 rounded-xl p-5" style="background: var(--color-primary-50); border-left: 4px solid var(--color-primary-700)">
        <p class="text-sm" style="color: var(--color-primary-900); line-height:1.7; font-weight:500">{info.visa_ko}</p>
      </div>
    </section>

    {/* 입학 시험 */}
    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">입학 시험</h2>
      <ul class="mt-4 space-y-2 text-sm" style="line-height:1.7">
        {info.exams.map((e) => <li>• <strong>{e}</strong></li>)}
      </ul>
      <p class="mt-3 text-sm" style="color: var(--color-text-secondary); line-height:1.7">{info.timeline_ko}</p>
    </section>

    {/* 대표 학교 */}
    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">대표 학교</h2>
      <p class="mt-2 text-xs text-[color:var(--color-text-tertiary)]">한국 학부모 사이에서 자주 검색되는 학교 위주 정리. 모든 정보는 학교 공식 사이트 최신 확인 권장.</p>
      <div class="mt-5 grid gap-3">
        {info.notable_schools.map((s) => (
          <div class="rounded-xl border p-4" style="border-color: var(--color-border-light)">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <div class="text-primary-900" style="font-weight:700">{s.name}</div>
              <div class="text-xs" style="color: var(--color-text-tertiary)">{s.location}</div>
            </div>
            <p class="mt-2 text-sm" style="color: var(--color-text-secondary); line-height:1.6">{s.note_ko}</p>
          </div>
        ))}
      </div>
    </section>

    {/* 진학 트랙 */}
    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">진학 트랙</h2>
      <p class="mt-3 text-base" style="line-height:1.75">{info.destinations_ko}</p>
    </section>

    {/* FAQ */}
    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">자주 묻는 질문</h2>
      <div class="mt-5 space-y-3">
        {info.faqs.map((f) => (
          <details class="rounded-xl p-4" style="border:1px solid var(--color-border-light)">
            <summary class="cursor-pointer" style="font-weight:600; color: var(--color-primary-900)">{f.q_ko}</summary>
            <p class="mt-3 text-sm" style="line-height:1.7">{f.a_ko}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mt-12 card-cta">
      <h2 class="text-xl text-white" style="font-weight:500">{info.name_ko} 입학 상담</h2>
      <p class="mt-3 text-sm">자녀 학년 · 영어 수준 · 예산 · 학부모 동반 의향을 알려주시면 1:1 답변.</p>
      <a href="/ko/contact/" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-3 text-primary-900" style="font-weight:500">
        카카오톡 · 이메일 상담
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
    </section>

    <section class="mt-10">
      <h2 class="text-xl" style="font-weight:700">관련 정보</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/ko/abroad/types/boarding/" class="card text-sm block">
          <div class="text-primary-900" style="font-weight:500">보딩스쿨 (기숙) 종합</div>
          <div class="mt-1 text-xs" style="color: var(--color-text-secondary)">영·미·호주·동남아 보딩 비교</div>
        </a>
        <a href="/ko/abroad/types/ib/" class="card text-sm block">
          <div class="text-primary-900" style="font-weight:500">IB 학교 가이드</div>
          <div class="mt-1 text-xs" style="color: var(--color-text-secondary)">PYP · MYP · DP 시스템</div>
        </a>
        <a href="/ko/abroad/" class="card text-sm block">
          <div class="text-primary-900" style="font-weight:500">해외 국제학교 종합</div>
          <div class="mt-1 text-xs" style="color: var(--color-text-secondary)">동남아 vs 영미권 비교</div>
        </a>
        <a href="/ko/tools/compare/#calculator" class="card text-sm block">
          <div class="text-primary-900" style="font-weight:500">학비 계산기</div>
          <div class="mt-1 text-xs" style="color: var(--color-text-secondary)">총비용 시뮬레이션</div>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>
