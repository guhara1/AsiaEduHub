---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { loadSchools, getRegion, COUNTRY_LABEL, REGION_LABEL, BUDGET_LABEL, formatUsd, formatDate, schoolUrl, basePairKey } from '~/lib/schools';
import { alternateUrlFor } from '~/lib/i18n';

export async function getStaticPaths() {
  const ko = await loadSchools('ko');
  return ko.map((entry) => ({
    params: {
      region: getRegion(entry.data.country),
      country: entry.data.country,
      city: entry.data.city,
      slug: entry.slug,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await entry.render();
const t = 'ko' as const;

const title = `${d.name} | ${COUNTRY_LABEL.ko[d.country]} ${d.city} · AsiaEduHub`;
const description = d.summary;

// hreflang 짝(zh 버전) 찾기
const allZh = await loadSchools('zh');
const pair = allZh.find((e) => basePairKey(e) === basePairKey(entry));
const zhUrl = pair ? schoolUrl(pair) : alternateUrlFor(Astro.url.pathname, 'zh');

const eduOrg = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: d.name_en,
  alternateName: [d.name_ko, d.name_zh].filter(Boolean),
  url: d.website,
  address: d.address ? { '@type': 'PostalAddress', addressLocality: d.city, addressCountry: d.country } : undefined,
  description: d.summary,
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '해외 국제학교', item: (Astro.site?.toString() ?? '') + 'ko/abroad/' },
    { '@type': 'ListItem', position: 3, name: REGION_LABEL.ko[getRegion(d.country)] },
    { '@type': 'ListItem', position: 4, name: COUNTRY_LABEL.ko[d.country] },
    { '@type': 'ListItem', position: 5, name: d.name },
  ],
};

const teach = d.teaching_staff;
const stud = d.student_nationality;
---
<BaseLayout title={title} description={description} jsonLd={[eduOrg, breadcrumb]}>
  <article class="container-content py-10">
    <nav class="text-sm text-[color:var(--color-text-secondary)]">
      <a href="/ko/abroad/">해외 국제학교</a> ·
      {REGION_LABEL.ko[getRegion(d.country)]} · {COUNTRY_LABEL.ko[d.country]} · {d.city}
    </nav>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      {d.visited_by_operator && <span class="badge-gold">⭐ 운영자 방문 확인</span>}
      {d.sponsored && <span class="badge-sponsored">SPONSORED</span>}
      <span class="badge-navy">{BUDGET_LABEL.ko[d.budget_tier]}</span>
    </div>

    <h1 class="mt-3 text-2xl sm:text-3xl">{d.name}</h1>
    <p class="mt-1 text-sm text-[color:var(--color-text-secondary)]">{d.name_en}</p>

    <p class="mt-4 max-w-2xl text-[color:var(--color-text-secondary)]">{d.summary}</p>

    {/* 핵심 데이터 카드 */}
    <section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-lg border p-4" style="border-color: var(--color-border-light)">
        <dt class="text-xs text-[color:var(--color-text-secondary)]">연 학비</dt>
        <dd class="mt-1 text-lg" style="font-weight:500">{formatUsd(d.tuition_annual_usd, 'ko')}</dd>
        {d.tuition_year && <p class="mt-1 text-xs text-[color:var(--color-text-tertiary)]">{d.tuition_year} 기준</p>}
      </div>
      <div class="rounded-lg border p-4" style="border-color: var(--color-border-light)">
        <dt class="text-xs text-[color:var(--color-text-secondary)]">커리큘럼</dt>
        <dd class="mt-1 text-lg" style="font-weight:500">{d.curriculum.primary_curriculum}</dd>
      </div>
      <div class="rounded-lg border p-4" style="border-color: var(--color-border-light)">
        <dt class="text-xs text-[color:var(--color-text-secondary)]">학년</dt>
        <dd class="mt-1 text-lg" style="font-weight:500">{d.grade_range[0]} – {d.grade_range[1]}</dd>
      </div>
      <div class="rounded-lg border p-4" style="border-color: var(--color-border-light)">
        <dt class="text-xs text-[color:var(--color-text-secondary)]">기숙</dt>
        <dd class="mt-1 text-lg" style="font-weight:500">
          {d.boarding === 'day-only' ? '통학' : d.boarding === 'boarding-optional' ? '선택 기숙' : '기숙 전용'}
        </dd>
      </div>
    </section>

    {/* 학생 국적 — 본토 vs 화교 분리 */}
    {stud && (
      <section class="mt-10">
        <h2 class="text-xl">학생 국적 구성</h2>
        <p class="text-xs text-[color:var(--color-text-tertiary)]">
          출처: {stud.source ?? '미표기'} · 업데이트 {stud.last_updated ? formatDate(stud.last_updated, 'ko') : '미표기'}
        </p>
        <dl class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 text-sm">
          {stud.korean_ratio !== undefined && <div><dt class="text-[color:var(--color-text-secondary)]">한국</dt><dd style="font-weight:500">{stud.korean_ratio}%</dd></div>}
          {stud.chinese_mainland_ratio !== undefined && <div><dt class="text-[color:var(--color-text-secondary)]">중국 본토</dt><dd style="font-weight:500">{stud.chinese_mainland_ratio}%</dd></div>}
          {stud.chinese_overseas_ratio !== undefined && <div><dt class="text-[color:var(--color-text-secondary)]">화교 (현지 중국계)</dt><dd style="font-weight:500">{stud.chinese_overseas_ratio}%</dd></div>}
          {stud.other_asian_ratio !== undefined && <div><dt class="text-[color:var(--color-text-secondary)]">기타 아시아</dt><dd style="font-weight:500">{stud.other_asian_ratio}%</dd></div>}
          {stud.western_ratio !== undefined && <div><dt class="text-[color:var(--color-text-secondary)]">서구권</dt><dd style="font-weight:500">{stud.western_ratio}%</dd></div>}
          {stud.local_host_country_ratio !== undefined && <div><dt class="text-[color:var(--color-text-secondary)]">현지</dt><dd style="font-weight:500">{stud.local_host_country_ratio}%</dd></div>}
        </dl>
      </section>
    )}

    {/* 교사 구성 — 국적별 분리 */}
    {teach && (
      <section class="mt-10">
        <h2 class="text-xl">교사 구성</h2>
        <p class="text-xs text-[color:var(--color-text-tertiary)]">
          출처: {teach.source ?? '미표기'} · 업데이트 {teach.last_updated ? formatDate(teach.last_updated, 'ko') : '미표기'}
        </p>
        <dl class="mt-4 grid gap-3 sm:grid-cols-3 text-sm">
          {teach.native_english_speakers?.subtotal_ratio !== undefined && (
            <div class="rounded-lg border p-3" style="border-color: var(--color-border-light)">
              <dt class="text-xs text-[color:var(--color-text-secondary)]">영어 모국어 (미·영·캐·호·뉴·아일랜드)</dt>
              <dd class="mt-1 text-lg" style="font-weight:500">{teach.native_english_speakers.subtotal_ratio}%</dd>
            </div>
          )}
          {teach.asian_english_teachers?.subtotal_ratio !== undefined && (
            <div class="rounded-lg border p-3" style="border-color: var(--color-border-light)">
              <dt class="text-xs text-[color:var(--color-text-secondary)]">영어 가능 아시아 (인·필·싱·말 등)</dt>
              <dd class="mt-1 text-lg" style="font-weight:500">{teach.asian_english_teachers.subtotal_ratio}%</dd>
            </div>
          )}
          {teach.other_teachers?.subtotal_ratio !== undefined && (
            <div class="rounded-lg border p-3" style="border-color: var(--color-border-light)">
              <dt class="text-xs text-[color:var(--color-text-secondary)]">기타 (한·중·현지·유럽)</dt>
              <dd class="mt-1 text-lg" style="font-weight:500">{teach.other_teachers.subtotal_ratio}%</dd>
            </div>
          )}
        </dl>
        {teach.with_teaching_license_ratio !== undefined && (
          <p class="mt-3 text-sm text-[color:var(--color-text-secondary)]">
            정식 교원 자격증 보유율 <strong style="font-weight:500">{teach.with_teaching_license_ratio}%</strong>
            {teach.average_experience_years !== undefined && <> · 평균 경력 {teach.average_experience_years}년</>}
          </p>
        )}
      </section>
    )}

    {/* 운영자 1차 경험 본문 (MDX) */}
    <section class="mt-12 prose prose-neutral max-w-2xl">
      <Content />
    </section>

    <p class="mt-10 text-xs text-[color:var(--color-text-tertiary)]">
      마지막 업데이트: {formatDate(d.last_updated, 'ko')} · 저자: {d.author}
    </p>
  </article>
</BaseLayout>
