---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SchoolCard from '../../../components/SchoolCard.astro';
import { loadSchools, getRegion, REGION_LABEL, COUNTRY_LABEL, type Region } from '../../../lib/schools';

const schools = await loadSchools('ko');

const byRegion = new Map<Region, typeof schools>();
for (const s of schools) {
  const r = getRegion(s.data.country);
  if (!byRegion.has(r)) byRegion.set(r, []);
  byRegion.get(r)!.push(s);
}

const title = '해외 국제학교 — 동남아·영미권 | AsiaEduHub';
const description =
  '말레이시아·태국·싱가포르·베트남 등 동남아와 미국·영국·캐나다·호주 영미권 국제학교. 운영자가 직접 방문한 학교 우선 등록.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '해외 국제학교' },
  ],
};
---
<BaseLayout title={title} description={description} jsonLd={breadcrumb}>
  <section class="container-content py-12">
    <nav class="text-sm text-[color:var(--color-text-secondary)]"><a href="/ko/">홈</a> · 해외 국제학교</nav>
    <h1 class="mt-2 text-2xl sm:text-3xl">해외 국제학교</h1>
    <p class="mt-2 max-w-2xl text-sm text-[color:var(--color-text-secondary)]">
      동남아는 운영자가 직접 방문한 학교에 ⭐ 배지를 부여합니다. 영미권은 보딩스쿨 위주.
    </p>

    {(['southeast-asia', 'anglosphere'] as Region[]).map((region) => {
      const list = byRegion.get(region) ?? [];
      return (
        <div class="mt-10">
          <h2 class="text-xl">{REGION_LABEL.ko[region]}</h2>
          {list.length === 0 ? (
            <p class="mt-3 text-sm text-[color:var(--color-text-secondary)]">
              등록된 학교가 아직 없습니다. 운영자가 직접 방문·검증한 학교부터 순차 등록합니다.
            </p>
          ) : (
            <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {list.map((entry) => <SchoolCard entry={entry} locale="ko" />)}
            </div>
          )}
        </div>
      );
    })}
  </section>
</BaseLayout>
