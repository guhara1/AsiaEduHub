---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import TableOfContents from '~/components/TableOfContents.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '~/lib/schools';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (e) => e.data.locale === 'ko');
  return posts.map((entry) => ({
    params: { slug: entry.slug.replace(/-ko$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const title = `${entry.data.title} | AsiaEduHub`;
const description = entry.data.summary;

const siteRoot = Astro.site?.toString() ?? '';
const slug = entry.slug.replace(/-ko$/, '');

const CATEGORY_LABEL: Record<string, { ko: string; emoji: string }> = {
  'school-visits': { ko: '학교 방문기', emoji: '🏫' },
  'transfers': { ko: '두 번 옮긴 학부모', emoji: '⭐' },
  'news': { ko: '뉴스 · 업데이트', emoji: '📰' },
  'analysis': { ko: '운영자 분석', emoji: '📊' },
  'interviews': { ko: '학부모 인터뷰', emoji: '💬' },
};
const cat = CATEGORY_LABEL[entry.data.category] ?? { ko: entry.data.category, emoji: '📝' };

const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: siteRoot + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '블로그', item: siteRoot + 'ko/blog/' },
    { '@type': 'ListItem', position: 3, name: entry.data.title },
  ],
};

// 관련 글 (같은 카테고리, 본인 제외 최대 3개)
const allPosts = await getCollection('blog', (e) => e.data.locale === 'ko');
const relatedPosts = allPosts
  .filter((p) => p.slug !== entry.slug && p.data.category === entry.data.category)
  .slice(0, 3);

// sources 첫 항목을 한 줄 문자열로
const sourcesText = entry.data.sources && entry.data.sources.length > 0
  ? entry.data.sources.map((s) => s.label).join(' / ')
  : undefined;
---
<BaseLayout
  title={title} description={description}
  jsonLd={breadcrumb}
  author={{ name: entry.data.author, url: '/ko/about/' }}
  publishedAt={entry.data.published_at}
  updatedAt={entry.data.last_updated}
  articleType="BlogPosting"
>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12 max-w-3xl">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/ko/">홈</a> · <a href="/ko/blog/">블로그</a> · <span style="color: var(--color-text-primary)">{cat.ko}</span>
      </nav>
      <div class="mt-4">
        <span class="badge-navy">{cat.emoji} {cat.ko}</span>
      </div>
      <h1 class="mt-4 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.022em; line-height:1.2">
        {entry.data.title}
      </h1>
      <p class="mt-4 max-w-2xl text-base sm:text-lg text-pretty" style="color: var(--color-text-secondary); line-height: 1.7;">
        {entry.data.summary}
      </p>
      <div class="mt-5">
        <AuthorByline locale="ko"
          publishedAt={entry.data.published_at}
          updatedAt={entry.data.last_updated}
          sources={sourcesText} />
      </div>
    </div>
  </section>

  <article class="container-content py-10 max-w-3xl">
    {headings.length >= 3 && <TableOfContents headings={headings} locale="ko" />}

    <div class="blog-prose mt-8">
      <Content />
    </div>

    {/* long-tail 태그 — 블로그 글 하단 내부 링크 자산 */}
    {entry.data.tags && entry.data.tags.length > 0 && (
      <section class="mt-12 rounded-xl border bg-[color:var(--color-bg-soft)] p-5" style="border-color: var(--color-border-light)">
        <div class="text-xs uppercase tracking-wide" style="color: var(--color-text-tertiary); font-weight:600">이 글의 키워드</div>
        <div class="mt-3 flex flex-wrap gap-1.5">
          {entry.data.tags.map((t) => (
            <span class="rounded-full bg-white border px-3 py-1 text-xs" style="border-color: var(--color-border-light); color: var(--color-text-primary); font-weight:500">#{t}</span>
          ))}
        </div>
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl" style="font-weight:700">같은 카테고리 다른 글</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {relatedPosts.map((p) => {
            const pSlug = p.slug.replace(/-ko$/, '');
            return (
              <a href={`/ko/blog/${pSlug}/`} class="block rounded-lg border p-4 hover:border-primary-700 transition-colors" style="border-color: var(--color-border-light)">
                <div class="text-primary-900" style="font-weight:600">{p.data.title}</div>
                <div class="mt-2 text-xs" style="color: var(--color-text-secondary)">{p.data.summary.slice(0, 110)}…</div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <section class="mt-12 card-cta">
      <h2 class="text-xl text-white" style="font-weight:500">이 글에 대한 추가 질문</h2>
      <p class="mt-3 text-sm">운영자에게 직접 묻기 — 자녀 학년 · 거주 지역 · 예산 알려주시면 1:1 답변.</p>
      <a href="/ko/contact/" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-3 text-primary-900" style="font-weight:500">
        카카오톡 · 이메일 상담
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
    </section>

    <p class="mt-8 text-xs text-[color:var(--color-text-tertiary)]">
      ※ 본 글은 운영자(데이비드)의 1차 경험·관찰 기록입니다. 학교 정책·학비·국적 비율은 매년 변동됩니다 — 최신 정보는 학교 공식 사이트와 입학설명회에서 확인하세요.
    </p>
  </article>
</BaseLayout>

<style is:global>
  /* 블로그 본문 prose 스타일 */
  .blog-prose { font-size: 1.0625rem; line-height: 1.78; color: var(--color-text-primary); }
  .blog-prose p { margin: 1.25rem 0; word-break: keep-all; }
  .blog-prose h2 {
    margin: 2.75rem 0 1rem; padding-top: 0.5rem;
    font-size: 1.625rem; font-weight: 700; letter-spacing: -0.018em;
    color: var(--color-primary-900);
    border-top: 1px solid var(--color-border-light);
  }
  .blog-prose h3 { margin: 2rem 0 0.75rem; font-size: 1.25rem; font-weight: 700; letter-spacing: -0.012em; color: var(--color-text-primary); }
  .blog-prose h4 { margin: 1.5rem 0 0.5rem; font-size: 1.0625rem; font-weight: 600; color: var(--color-text-primary); }
  .blog-prose a { color: var(--color-primary-700); text-decoration: underline; text-decoration-thickness: 1.5px; text-underline-offset: 3px; }
  .blog-prose a:hover { color: var(--color-primary-900); }
  .blog-prose strong { font-weight: 700; color: var(--color-text-primary); }
  .blog-prose ul, .blog-prose ol { margin: 1.25rem 0; padding-left: 1.5rem; }
  .blog-prose ul li { list-style: disc; margin: 0.5rem 0; line-height: 1.7; }
  .blog-prose ol li { list-style: decimal; margin: 0.5rem 0; line-height: 1.7; }
  .blog-prose blockquote {
    margin: 1.75rem 0; padding: 1rem 1.25rem;
    background: linear-gradient(135deg, var(--color-accent-50) 0%, #fff 100%);
    border-left: 4px solid var(--color-accent-500);
    border-radius: 0 8px 8px 0;
    color: var(--color-accent-700);
    font-size: 0.975rem;
  }
  .blog-prose blockquote p { margin: 0.5rem 0; }
  .blog-prose blockquote strong { color: var(--color-accent-700); }
  .blog-prose table {
    width: 100%; margin: 1.5rem 0; border-collapse: collapse;
    font-size: 0.9375rem;
  }
  .blog-prose th, .blog-prose td {
    border: 1px solid var(--color-border-light); padding: 0.625rem 0.875rem; text-align: left;
  }
  .blog-prose th {
    background: var(--color-bg-soft); font-weight: 600; color: var(--color-primary-900);
    font-size: 0.85rem;
  }
  .blog-prose td { color: var(--color-text-primary); }
  .blog-prose hr {
    margin: 2.5rem 0; border: 0;
    border-top: 1px solid var(--color-border-light);
  }
  .blog-prose code {
    padding: 0.125rem 0.375rem; border-radius: 4px;
    background: var(--color-bg-tertiary); color: var(--color-primary-900);
    font-size: 0.9em;
  }
  :root[data-theme="dark"] .blog-prose blockquote {
    background: rgba(245, 158, 11, 0.08);
    color: var(--color-text-primary);
  }
  :root[data-theme="dark"] .blog-prose th { background: var(--color-bg-elevated); }
</style>
