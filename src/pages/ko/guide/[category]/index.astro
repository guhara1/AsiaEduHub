---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '~/lib/schools';
import { GUIDE_PAGES, GUIDE_KEYS } from '~/lib/guide-pages-info';

export async function getStaticPaths() {
  return GUIDE_KEYS.map((category) => ({ params: { category }, props: { category } }));
}

const { category } = Astro.props as { category: string };
const info = GUIDE_PAGES[category];

// 같은 카테고리의 가이드 글 필터
const allGuides = await getCollection('guides', (e) => e.data.locale === 'ko');
const categoryGuides = allGuides
  .filter((g) => g.data.category === category)
  .sort((a, b) => b.data.last_updated.getTime() - a.data.last_updated.getTime());

const publishedAt = new Date('2026-05-21');
const updatedAt = categoryGuides.length > 0 ? categoryGuides[0].data.last_updated : publishedAt;

const title = `${info.name_ko} — 종합 가이드 + 학부모 자주 묻는 질문 | AsiaEduHub`;
const description = info.tagline_ko;

const siteRoot = Astro.site?.toString() ?? '';
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: siteRoot + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '가이드', item: siteRoot + 'ko/guide/' },
    { '@type': 'ListItem', position: 3, name: info.name_ko },
  ],
};
const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: info.faqs.map((f) => ({
    '@type': 'Question', name: f.q_ko,
    acceptedAnswer: { '@type': 'Answer', text: f.a_ko },
  })),
};
---
<BaseLayout title={title} description={description}
  jsonLd={[breadcrumb, faqSchema]}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt} updatedAt={updatedAt}>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/ko/">홈</a> · <a href="/ko/guide/">가이드</a> · <span style="color: var(--color-text-primary)">{info.name_ko}</span>
      </nav>
      <h1 class="mt-5 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.022em">{info.emoji} {info.name_ko}</h1>
      <p class="mt-4 max-w-2xl text-base sm:text-lg" style="color: var(--color-text-secondary); line-height: 1.7;">{info.tagline_ko}</p>
      <div class="mt-5">
        <AuthorByline locale="ko" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="각국 정부 공식 자료 · 학교 공식 안내 · 운영자 1차 경험 · 학부모 커뮤니티 청취" />
      </div>
    </div>
  </section>

  <article class="container-content py-10 max-w-3xl">
    <div class="rounded-2xl p-6" style="background: linear-gradient(135deg, #FFFBF0 0%, #FEF9E7 100%); border: 1px solid #FCD34D">
      <div class="text-xs uppercase tracking-wider" style="color: var(--color-accent-700); font-weight: 700; letter-spacing: 0.08em">✦ 카테고리 소개</div>
      <p class="mt-3 text-base" style="color: var(--color-accent-700); line-height: 1.7; font-weight: 500">{info.intro_ko}</p>
    </div>

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">이 카테고리 핵심 포인트</h2>
      <ul class="mt-5 space-y-2 text-sm" style="line-height:1.75">
        {info.key_points_ko.map((p) => <li>✓ {p}</li>)}
      </ul>
    </section>

    {categoryGuides.length > 0 && (
      <section class="mt-10">
        <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">이 카테고리 가이드 글 ({categoryGuides.length}편)</h2>
        <div class="mt-5 grid gap-3">
          {categoryGuides.map((g) => {
            const slug = g.slug.replace(/-ko$/, '');
            return (
              <a href={`/ko/guide/${slug}/`} class="rounded-xl border p-4 hover:border-primary-700 transition-colors block" style="border-color: var(--color-border-light)">
                <div class="text-primary-900" style="font-weight:600">{g.data.title}</div>
                <p class="mt-2 text-sm" style="color: var(--color-text-secondary); line-height:1.6">{g.data.summary}</p>
                <div class="mt-2 text-xs" style="color: var(--color-text-tertiary)">{formatDate(g.data.last_updated, 'ko')} · {g.data.author}</div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">자주 묻는 질문</h2>
      <div class="mt-5 space-y-3">
        {info.faqs.map((f) => (
          <details class="rounded-xl p-4" style="border:1px solid var(--color-border-light)">
            <summary class="cursor-pointer" style="font-weight:600; color: var(--color-primary-900)">{f.q_ko}</summary>
            <p class="mt-3 text-sm" style="line-height:1.7">{f.a_ko}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mt-12 card-cta">
      <h2 class="text-xl text-white" style="font-weight:500">{info.name_ko} 1:1 상담</h2>
      <p class="mt-3 text-sm">자녀 학년 · 관심 학교 · 우선순위를 알려주시면 카테고리별 맞춤 답변.</p>
      <a href="/ko/contact/" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-3" style="font-weight:500">
        카카오톡 · 이메일 상담
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
    </section>

    <section class="mt-10">
      <h2 class="text-xl" style="font-weight:700">다른 가이드 카테고리</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        {GUIDE_KEYS.filter((k) => k !== category).map((k) => {
          const p = GUIDE_PAGES[k];
          return (
            <a href={`/ko/guide/${k}/`} class="card text-sm block">
              <div class="text-primary-900" style="font-weight:500">{p.emoji} {p.name_ko}</div>
              <div class="mt-1 text-xs" style="color: var(--color-text-secondary); line-height:1.5">{p.tagline_ko.slice(0, 70)}…</div>
            </a>
          );
        })}
      </div>
    </section>
  </article>
</BaseLayout>
