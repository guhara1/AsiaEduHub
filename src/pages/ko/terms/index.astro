---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';

const publishedAt = new Date('2026-05-21');
const updatedAt = new Date('2026-05-21');

const title = '이용약관 · AsiaEduHub';
const description = 'AsiaEduHub 이용약관 — 콘텐츠 사용 범위 · 면책 조항 · 광고 정책 · 분쟁 해결. 운영자(데이비드) 책임.';

const siteRoot = Astro.site?.toString() ?? '';
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: siteRoot + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '이용약관' },
  ],
};
---
<BaseLayout title={title} description={description} jsonLd={breadcrumb}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt} updatedAt={updatedAt}>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12 max-w-3xl">
      <nav class="text-sm" style="color: var(--color-text-secondary)"><a href="/ko/">홈</a> · 이용약관</nav>
      <h1 class="mt-3 text-3xl sm:text-4xl text-balance" style="font-weight:800; letter-spacing:-0.022em">이용약관</h1>
      <p class="mt-3 text-base" style="color: var(--color-text-secondary); line-height: 1.7;">
        본 약관은 AsiaEduHub 사이트 이용에 관한 권리·의무·책임 사항을 정합니다.
      </p>
      <div class="mt-5">
        <AuthorByline locale="ko" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="한국 전자상거래법 · 정보통신망법 · 표준 약관 가이드" />
      </div>
    </div>
  </section>

  <article class="container-content py-10 max-w-3xl">

    <section class="mt-2">
      <h2 class="text-xl" style="font-weight:700">1. 서비스 정의</h2>
      <p class="mt-2 text-sm" style="line-height:1.75">
        AsiaEduHub (asiaeduhub.com) 는 한국 · 중국 학부모가 동남아 · 국내 국제학교를 검토할 때 참고하는
        정보 사이트입니다. 운영자(데이비드)의 1차 경험 · 학교 공식 자료 · 학부모 커뮤니티 청취 기반 콘텐츠를 제공합니다.
      </p>
    </section>

    <section class="mt-8">
      <h2 class="text-xl" style="font-weight:700">2. 콘텐츠 사용 범위</h2>
      <ul class="mt-3 space-y-2 text-sm" style="line-height:1.7">
        <li>• 본 사이트 콘텐츠는 개인 학부모의 <strong>참고 용도로만</strong> 사용 가능합니다.</li>
        <li>• 콘텐츠의 일부 또는 전체를 <strong>상업적 목적으로 복사·재배포</strong>하는 행위 금지.</li>
        <li>• AI 학습 데이터로 활용하는 행위 금지 (robots.txt 에서 GPTBot · CCBot · Google-Extended · ClaudeBot 차단).</li>
        <li>• 출처 명시 시 <strong>인용 (200자 이내)</strong> 은 허용. 단, 본 사이트로 링크 백 필수.</li>
        <li>• 학교명 · 학비 · 비자 등 사실 정보는 자유롭게 사용 가능 (공개 정보).</li>
      </ul>
    </section>

    <section class="mt-8">
      <h2 class="text-xl" style="font-weight:700">3. 정보의 정확성·면책</h2>
      <ul class="mt-3 space-y-2 text-sm" style="line-height:1.7">
        <li>• 모든 정보는 발행 시점 기준 <strong>"추정 정보"</strong> 임을 명시합니다.</li>
        <li>• 학교 정책 · 학비 · 비자 요건은 매년 변경 — 최신 정보는 각 학교 · 정부 공식 사이트에서 확인 필수.</li>
        <li>• 운영자는 본 사이트 정보로 인한 <strong>학교 입학 · 비자 · 이주 결정의 결과에 대해 책임지지 않습니다</strong>.</li>
        <li>• 환율 변동 · 정책 개정으로 인한 실제 비용 차이에 대해 책임 없음.</li>
        <li>• 광고주가 약속한 사항은 광고주와 직접 합의 — 본 사이트는 중개자 역할만 수행.</li>
      </ul>
    </section>

    <section class="mt-8">
      <h2 class="text-xl" style="font-weight:700">4. 광고-콘텐츠 분리 정책</h2>
      <ul class="mt-3 space-y-2 text-sm" style="line-height:1.7">
        <li>• 광고 콘텐츠는 <strong>"SPONSORED" 배지</strong>로 명확히 표시.</li>
        <li>• 광고 링크는 <code>rel="sponsored"</code> 처리.</li>
        <li>• 광고주 학교 · 유학원과 편집 추천 학교는 페이지 분리.</li>
        <li>• 광고비를 받은 학교라도 운영자 방문 시 발견한 단점은 그대로 기록.</li>
      </ul>
    </section>

    <section class="mt-8">
      <h2 class="text-xl" style="font-weight:700">5. 사용자 행위 금지</h2>
      <ul class="mt-3 space-y-2 text-sm" style="line-height:1.7">
        <li>• 운영자 사칭 · 허위 정보 작성</li>
        <li>• 다른 사용자 비방 · 모욕</li>
        <li>• 스팸 · 광고 무단 게재</li>
        <li>• 사이트 시스템 해킹 · 부정 접근</li>
        <li>• 저작권 · 상표권 · 초상권 침해</li>
      </ul>
    </section>

    <section class="mt-8">
      <h2 class="text-xl" style="font-weight:700">6. 외부 링크</h2>
      <p class="mt-2 text-sm" style="line-height:1.75">
        본 사이트는 학교 공식 사이트 · 정부 사이트 · 학부모 커뮤니티 등 외부 사이트 링크를 포함합니다.
        외부 사이트의 콘텐츠 · 정확성 · 보안에 대해 운영자는 <strong>책임지지 않습니다</strong>.
        외부 사이트 이용 시 해당 사이트의 약관 · 개인정보 정책을 별도 확인하세요.
      </p>
    </section>

    <section class="mt-8">
      <h2 class="text-xl" style="font-weight:700">7. 서비스 변경·종료</h2>
      <p class="mt-2 text-sm" style="line-height:1.75">
        운영자는 사정에 따라 사이트 운영을 변경 · 종료할 수 있습니다.
        중요 변경 시 30일 전 사이트 공지 · 이메일 안내합니다.
      </p>
    </section>

    <section class="mt-8">
      <h2 class="text-xl" style="font-weight:700">8. 분쟁 해결</h2>
      <p class="mt-2 text-sm" style="line-height:1.75">
        본 약관 관련 분쟁은 한국 법령에 따르며, 협의로 해결되지 않을 경우 운영자 거주지 관할 법원이 1심 관할 법원입니다.
      </p>
    </section>

    <section class="mt-8">
      <h2 class="text-xl" style="font-weight:700">9. 변경 안내</h2>
      <p class="mt-2 text-sm" style="line-height:1.75">
        본 약관은 법령 · 운영 정책 변경에 따라 갱신됩니다.
        마지막 갱신: <strong>2026-05-21</strong>.
      </p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl" style="font-weight:700">관련 페이지</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/ko/privacy/" class="card text-sm block"><div class="text-primary-900" style="font-weight:500">개인정보처리방침</div></a>
        <a href="/ko/editorial-policy/" class="card text-sm block"><div class="text-primary-900" style="font-weight:500">편집 원칙</div></a>
        <a href="/ko/about/" class="card text-sm block"><div class="text-primary-900" style="font-weight:500">운영자 소개</div></a>
        <a href="/ko/contact/" class="card text-sm block"><div class="text-primary-900" style="font-weight:500">연락처</div></a>
      </div>
    </section>
  </article>
</BaseLayout>
