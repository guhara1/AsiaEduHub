---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getMessages } from '~/lib/i18n';
import { getCollection } from 'astro:content';
import { formatDate } from '~/lib/schools';

const t = getMessages('ko');

const title = `${t.site.name} — ${t.site.tagline}`;
const description =
  '말레이시아 거주 학부모 데이비드가 직접 운영. 외국인학교·제주 국제학교·동남아·영미권 학교 정보, MM2H 비자, 학비 계산기, 진학 트랙 시뮬레이터 등 학부모가 정말 필요한 정보 정리.';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: t.site.name,
  url: Astro.site?.toString(),
  inLanguage: 'ko-KR',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: `${Astro.site?.toString() ?? ''}ko/?q={search_term_string}` },
    'query-input': 'required name=search_term_string',
  },
};
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'AsiaEduHub',
  url: Astro.site?.toString(),
  logo: (Astro.site?.toString() ?? '') + 'favicon.svg',
  founder: { '@type': 'Person', name: '데이비드', url: (Astro.site?.toString() ?? '') + 'ko/about/' },
};

// 최근 콘텐츠 자동 노출
const recentGuides = (await getCollection('guides', (e) => e.data.locale === 'ko'))
  .sort((a, b) => b.data.last_updated.getTime() - a.data.last_updated.getTime())
  .slice(0, 3);
const recentExperts = (await getCollection('experts', (e) => e.data.locale === 'ko'))
  .sort((a, b) => b.data.published_at.getTime() - a.data.published_at.getTime())
  .slice(0, 2);
---
<BaseLayout title={title} description={description} jsonLd={[websiteSchema, orgSchema]}>
  {/* Hero */}
  <section class="container-content py-12 sm:py-16">
    <div class="grid gap-10 lg:grid-cols-[1.6fr_1fr] lg:items-start">
      <div>
        <p class="badge-gold mb-3">{t.badges.two_school_switches}</p>
        <h1 class="text-3xl sm:text-5xl">
          외국인학교·제주 국제학교·동남아 유학,<br />
          학부모가 직접 정리한 진짜 정보
        </h1>
        <p class="mt-6 max-w-2xl text-base text-[color:var(--color-text-secondary)]">
          운영자(데이비드)는 말레이시아 거주 한국인 학부모. 자녀 2명, 학교 두 번 옮긴 1차 경험을 바탕으로
          학비·비자·커리큘럼·진학 트랙을 학부모 관점에서 검증·정리합니다. AI 자동 생성 본문은 사용하지 않습니다.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/ko/abroad/" class="cta-primary">해외 유학 비교 →</a>
          <a href="/ko/domestic/" class="cta-secondary">국내 국제학교 →</a>
        </div>
      </div>

      {/* 운영자 정체성 카드 */}
      <aside class="rounded-lg border p-5" style="border-color: var(--color-border-light); background: var(--color-bg-secondary)">
        <div class="flex items-center gap-3">
          <span aria-hidden="true" class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary-900 text-white text-lg">D</span>
          <div>
            <div class="text-primary-900" style="font-weight:500">데이비드</div>
            <div class="text-xs text-[color:var(--color-text-tertiary)]">말레이시아 쿠알라룸푸르 · 두 번 옮긴 학부모</div>
          </div>
        </div>
        <ul class="mt-4 space-y-1 text-xs text-[color:var(--color-text-secondary)]">
          <li>• 2024 한국 → 쿠알라룸푸르 이주</li>
          <li>• 자녀 2명, UCSI 국제학교 재학</li>
          <li>• 학교 2회 이전 (학비 + 한국인 비율 폭증 경험)</li>
          <li>• 한국어·중국어(북경 거주)·영어</li>
          <li>• 온라인 마케팅 12년+ 경력</li>
        </ul>
        <a href="/ko/about/" class="mt-4 inline-block text-xs text-primary-700 hover:underline">운영자 소개 →</a>
      </aside>
    </div>
  </section>

  {/* 정보 진입 — 핵심 카드 */}
  <section class="container-content pb-4">
    <h2 class="text-xl">학부모가 가장 많이 묻는 주제</h2>
    <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/ko/domestic/" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">외국인학교 vs 국제학교 차이</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">법적 자격·학력 인정·학비 차이. SFS·YISS·NLCS·BHA 등 주요 학교 정리.</p>
      </a>
      <a href="/ko/mm2h/" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">MM2H · Thailand · Singapore 비자 비교</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">2024 MM2H 개정 포함. 학부모 비자 5종을 자격·비용·자녀 교육 영향으로 비교.</p>
      </a>
      <a href="/ko/abroad/" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">동남아 가성비 vs 영미권 프리미엄</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">학비 1/3~1/2 차이. 동남아 IB 트랙으로 옥스브리지·아이비 진학 가능.</p>
      </a>
      <a href="/ko/tools/compare/#track-simulator" class="block rounded-lg border p-5 bg-accent-100 hover:border-accent-500" style="border-color: var(--color-accent-500)">
        <div class="flex items-center gap-2">
          <h3 class="text-base text-accent-700" style="font-weight:500">진학 트랙 시뮬레이터</h3>
          <span class="badge-gold text-[10px]">⭐ 킬러 도구</span>
        </div>
        <p class="mt-2 text-sm text-accent-700">자녀 학년·목표 대학·예산 입력 → 학년별 단계·시험·총비용 자동 계산.</p>
      </a>
      <a href="/ko/tools/compare/#calculator" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">학비 계산기</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">학비 + 부대비 + 기숙 + 항공권 + 환율 + 인플레이션. 원화·위안화 환산.</p>
      </a>
      <a href="/ko/experts/" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">전문가 칼럼</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">현직 교사·입학사정관·유학 컨설턴트 인터뷰. 운영자 신원 확인.</p>
      </a>
    </div>
  </section>

  {/* 자녀 학년별 진입 */}
  <section class="container-content py-12">
    <h2 class="text-xl">자녀 학년에 맞는 시작점</h2>
    <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">학년별로 학부모가 봐야 할 정보가 다릅니다.</p>
    <div class="mt-5 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
        <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">유치원 ~ 초3 (저학년)</div>
        <h3 class="mt-1 text-base" style="font-weight:500">환경·시설·식사·한국인 비율 중심</h3>
        <ul class="mt-3 space-y-1 text-sm text-[color:var(--color-text-secondary)]">
          <li>• <a href="/ko/abroad/#malaysia" class="hover:text-primary-700">말레이시아 가성비 학교</a></li>
          <li>• <a href="/ko/domestic/#kindergarten" class="hover:text-primary-700">영어유치원 정보</a></li>
          <li>• <a href="/ko/guide/#admission" class="hover:text-primary-700">입학 시험·인터뷰 준비</a></li>
        </ul>
      </div>
      <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
        <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">초4 ~ 중2 (중학년)</div>
        <h3 class="mt-1 text-base" style="font-weight:500">학업 환경 + 커리큘럼 진입</h3>
        <ul class="mt-3 space-y-1 text-sm text-[color:var(--color-text-secondary)]">
          <li>• <a href="/ko/guide/#curriculum-compare" class="hover:text-primary-700">IB · A-Level · AP 비교</a></li>
          <li>• <a href="/ko/abroad/" class="hover:text-primary-700">동남아 IB 학교 정리</a></li>
          <li>• <a href="/ko/tools/compare/#calculator" class="hover:text-primary-700">학비 계산기</a></li>
        </ul>
      </div>
      <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
        <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">중3 ~ 고등 (고학년)</div>
        <h3 class="mt-1 text-base" style="font-weight:500">시험 결과 + 대학 진학 중심</h3>
        <ul class="mt-3 space-y-1 text-sm text-[color:var(--color-text-secondary)]">
          <li>• <a href="/ko/tools/compare/#track-simulator" class="hover:text-primary-700">진학 트랙 시뮬레이터</a></li>
          <li>• <a href="/ko/guide/#track-reviews" class="hover:text-primary-700">옥스브리지·아이비 합격 사례</a></li>
          <li>• <a href="/ko/abroad/#usa" class="hover:text-primary-700">영미권 보딩스쿨</a></li>
        </ul>
      </div>
    </div>
  </section>

  {/* 예산별 진입 */}
  <section class="container-content pb-4">
    <h2 class="text-xl">예산별 학교 추천</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { href: '/ko/tools/budget/budget-friendly/', title: '가성비', sub: '연 1,000만원 이하' },
        { href: '/ko/tools/budget/mid-range/', title: '중간 예산', sub: '1,000~2,000만원' },
        { href: '/ko/tools/budget/premium/', title: '프리미엄', sub: '2,000~3,500만원' },
        { href: '/ko/tools/budget/top-tier/', title: '최상위', sub: '3,500만원+' },
      ].map((b) => (
        <a href={b.href} class="rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
          <div class="text-lg text-primary-900" style="font-weight:500">{b.title}</div>
          <div class="mt-1 text-sm text-[color:var(--color-text-secondary)]">{b.sub}</div>
        </a>
      ))}
    </div>
  </section>

  {/* 최근 가이드·전문가 칼럼 */}
  {(recentGuides.length > 0 || recentExperts.length > 0) && (
    <section class="container-content py-12">
      <h2 class="text-xl">최근 발행 / 업데이트</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {recentGuides.map((g) => (
          <a href={`/ko/guide/${g.slug.replace(/-ko$/, '')}/`} class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
            <div class="text-xs text-[color:var(--color-text-tertiary)]">가이드</div>
            <div class="mt-1 text-base text-primary-900" style="font-weight:500">{g.data.title}</div>
            <p class="mt-2 text-xs text-[color:var(--color-text-secondary)]">{g.data.summary}</p>
            <p class="mt-2 text-xs text-[color:var(--color-text-tertiary)]">{formatDate(g.data.last_updated, 'ko')}</p>
          </a>
        ))}
        {recentExperts.map((e) => (
          <a href={`/ko/experts/${e.slug.replace(/-ko$/, '')}/`} class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
            <div class="flex items-center gap-1">
              <span class="text-xs text-[color:var(--color-text-tertiary)]">전문가 칼럼</span>
              {e.data.expert.verified && <span class="badge-gold text-[10px]">⭐ 검증</span>}
            </div>
            <div class="mt-1 text-base text-primary-900" style="font-weight:500">{e.data.title}</div>
            <p class="mt-2 text-xs text-[color:var(--color-text-secondary)]">{e.data.summary}</p>
            <p class="mt-2 text-xs text-[color:var(--color-text-tertiary)]">{e.data.expert.affiliation}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* 사이트 신뢰 신호 */}
  <section class="container-content pb-16">
    <div class="rounded-lg border p-5" style="border-color: var(--color-border-light); background: var(--color-bg-secondary)">
      <h2 class="text-lg" style="font-weight:500">왜 AsiaEduHub 인가</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-3 text-sm">
        <div>
          <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">1차 경험 (E-E-A-T)</div>
          <p class="mt-1">운영자 본인이 한국 → 말레이시아 이주, 학교 2회 이전, MM2H 신청 경험.</p>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">출처·검증</div>
          <p class="mt-1">모든 데이터에 출처 + 마지막 업데이트 날짜. 분기별 검증.</p>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">광고 분리</div>
          <p class="mt-1">광고 콘텐츠는 SPONSORED 배지. <a href="/ko/editorial-policy/" class="text-primary-700 hover:underline">편집 원칙</a> 공개.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
