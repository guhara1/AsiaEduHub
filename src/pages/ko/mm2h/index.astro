---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import { VISA_PROGRAMS, MM2H_FAQS } from '~/lib/mm2h-info';

const title = '동남아 장기 거주 비자 완벽 비교 — MM2H · Thailand Privilege · LTR · Singapore EP · PR | AsiaEduHub';
const description =
  '말레이시아 MM2H, 태국 Thailand Privilege · LTR, 싱가포르 EP · PR 의 자격·비용·기간·자녀 교육 영향 비교. 2024 MM2H 개정 포함. 학부모 FAQ.';

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'ko/' },
    { '@type': 'ListItem', position: 2, name: 'MM2H · 이주' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: MM2H_FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q_ko,
    acceptedAnswer: { '@type': 'Answer', text: f.a_ko },
  })),
};

// HowTo schema — MM2H 신청 7단계 (말레이시아 MM2H 만, 다른 비자는 별도)
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '말레이시아 MM2H 비자 신청 7단계',
  description: '말레이시아 MM2H(My Second Home) 비자를 2024 개정 기준으로 신청하는 7단계 절차.',
  totalTime: 'P9M', // 평균 6~12개월, 9개월 ISO 8601 duration
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'MYR',
    value: '520000', // Silver 정기예금 + 부대 비용 합 추정
  },
  step: [
    { '@type': 'HowToStep', position: 1, name: '사전 평가', text: '에이전시 또는 본인이 자격 요건 충족 여부 사전 평가. 정기예금 가능 금액·월 소득·자녀 동반 인원 정리. 1~2주 소요.' },
    { '@type': 'HowToStep', position: 2, name: '에이전시 선정', text: '정부 라이선스 에이전시 비교 후 선정. 비용·서비스·이전 성공 사례 검토. 비용 RM 15,000~40,000.' },
    { '@type': 'HowToStep', position: 3, name: '서류 준비', text: '여권·은행 잔고·소득·범죄 경력·건강 검진·아포스티유 등 서류 4~8주 준비.' },
    { '@type': 'HowToStep', position: 4, name: '신청서 접수', text: '에이전시가 MM2H 사무국에 제출. 접수 번호 부여.' },
    { '@type': 'HowToStep', position: 5, name: '정부 심사', text: '신원·재정·건강 검증. 3~6개월 소요. 추가 서류 요청 가능.' },
    { '@type': 'HowToStep', position: 6, name: '조건부 승인', text: 'Approval Letter 수령 후 정기예금 개설 · 의료 보험 가입 · 말레이시아 지정 병원 건강 검진 완료.' },
    { '@type': 'HowToStep', position: 7, name: '비자 발급 · 입국', text: '모든 조건 완료 후 비자 정식 발급. 5년 거주 시작.' },
  ],
};
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumb, faqSchema, howToSchema]}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="hero-gradient border-b" style="border-color: var(--color-border-light)">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)"><a href="/ko/">홈</a> · MM2H · 이주</nav>
      <h1 class="mt-3 text-3xl sm:text-4xl text-balance">동남아 장기 거주 비자 — <span class="text-accent-700">MM2H · Thailand · Singapore</span> 완벽 비교</h1>
      <p class="mt-4 max-w-2xl text-base text-pretty" style="color: var(--color-text-secondary); line-height: 1.65;">
        자녀 국제학교 교육을 위해 동남아 장기 비자를 알아보는 학부모를 위한 정보 정리입니다.
        말레이시아 MM2H(2024 개정), 태국 Thailand Privilege · LTR, 싱가포르 EP · PR 의 자격·비용·기간·자녀 교육 영향을 한 페이지에 정리.
      </p>
      <div class="mt-5">
        <AuthorByline locale="ko" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="말레이시아 MM2H 관광·예술·문화부, Thailand Privilege Card Co., Thailand BOI, Singapore MOM·ICA 공식 자료" />
      </div>
    </div>
  </section>

  <section class="container-content py-10">

    {/* 빠른 비교표 */}
    <section class="mt-8 rounded-lg border bg-[color:var(--color-bg-secondary)] p-5 overflow-x-auto" style="border-color: var(--color-border-light)">
      <h2 class="text-lg" style="font-weight:500">한눈에 비교</h2>
      <table class="mt-4 w-full text-sm min-w-[700px]">
        <thead>
          <tr class="border-b" style="border-color: var(--color-border-light)">
            <th class="py-2 text-left" style="font-weight:500">비자</th>
            <th class="py-2 text-left" style="font-weight:500">국가</th>
            <th class="py-2 text-left" style="font-weight:500">기간</th>
            <th class="py-2 text-left" style="font-weight:500">자격 핵심</th>
            <th class="py-2 text-left" style="font-weight:500">비용 (요약)</th>
          </tr>
        </thead>
        <tbody class="text-[color:var(--color-text-secondary)]">
          {VISA_PROGRAMS.map((v) => (
            <tr class="border-b align-top" style="border-color: var(--color-border-light)">
              <td class="py-3 text-[color:var(--color-text-primary)]" style="font-weight:500"><a href={`#${v.id}`} class="hover:text-primary-700">{v.ko.name}</a></td>
              <td class="py-3">{v.country === 'malaysia' ? '🇲🇾 말레이시아' : v.country === 'thailand' ? '🇹🇭 태국' : '🇸🇬 싱가포르'}</td>
              <td class="py-3">{v.ko.duration}</td>
              <td class="py-3">{v.ko.eligibility[0]}</td>
              <td class="py-3">{v.ko.cost}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">
        ※ 정확한 자격·금액은 각 비자 섹션의 공식 사이트 링크에서 확인. 정책은 자주 개정됩니다.
      </p>
    </section>

    {/* 각 비자 상세 */}
    {VISA_PROGRAMS.map((v) => (
      <section id={v.id} class="mt-12 scroll-mt-24">
        <div class="flex flex-wrap items-baseline gap-2">
          <h2 class="text-xl">{v.ko.full_name}</h2>
          <span class="text-xs text-[color:var(--color-text-tertiary)]">
            {v.country === 'malaysia' ? '🇲🇾' : v.country === 'thailand' ? '🇹🇭' : '🇸🇬'}
          </span>
        </div>
        <p class="mt-1 text-xs text-[color:var(--color-text-tertiary)]">근거: {v.ko.legal_basis}</p>

        <div class="mt-5 grid gap-5 sm:grid-cols-2">
          <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
            <h3 class="text-sm uppercase tracking-wide text-[color:var(--color-text-tertiary)]">자격 요건</h3>
            <ul class="mt-3 space-y-2 text-sm">
              {v.ko.eligibility.map((e) => <li>• {e}</li>)}
            </ul>
          </div>
          <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
            <h3 class="text-sm uppercase tracking-wide text-[color:var(--color-text-tertiary)]">비용 · 기간</h3>
            <dl class="mt-3 space-y-3 text-sm">
              <div>
                <dt class="text-[color:var(--color-text-secondary)]">비용</dt>
                <dd style="font-weight:500">{v.ko.cost}</dd>
              </div>
              <div>
                <dt class="text-[color:var(--color-text-secondary)]">기간</dt>
                <dd style="font-weight:500">{v.ko.duration}</dd>
              </div>
            </dl>
          </div>
        </div>

        <div class="mt-4 rounded-lg border-l-4 border-primary-700 bg-primary-100 p-4 text-sm text-primary-900">
          <div class="text-xs uppercase tracking-wide opacity-80">자녀 교육에 미치는 영향</div>
          <p class="mt-1">{v.ko.child_education}</p>
        </div>

        <div class="mt-5 grid gap-5 sm:grid-cols-2">
          <div>
            <h3 class="text-sm text-primary-900" style="font-weight:500">어떤 가족에 적합한가</h3>
            <ul class="mt-2 space-y-1 text-sm text-[color:var(--color-text-primary)]">
              {v.ko.suitable_for.map((s) => <li>✓ {s}</li>)}
            </ul>
          </div>
          <div>
            <h3 class="text-sm" style="font-weight:500; color: var(--color-danger)">유의 사항</h3>
            <ul class="mt-2 space-y-1 text-sm text-[color:var(--color-text-primary)]">
              {v.ko.cautions.map((c) => <li>⚠ {c}</li>)}
            </ul>
          </div>
        </div>

        <p class="mt-4 text-xs text-[color:var(--color-text-tertiary)]">
          공식 자료: <a href={v.official_url} target="_blank" rel="noopener" class="text-primary-700 hover:underline">{v.official_url} ↗</a>
        </p>
      </section>
    ))}

    {/* FAQ */}
    <section id="faq" class="mt-16 scroll-mt-24">
      <h2 class="text-xl">자주 묻는 질문</h2>
      <div class="mt-5 space-y-3">
        {MM2H_FAQS.map((f) => (
          <details class="rounded-lg border p-4" style="border-color: var(--color-border-light)">
            <summary class="cursor-pointer text-sm text-primary-900" style="font-weight:500; list-style: disclosure-closed">{f.q_ko}</summary>
            <p class="mt-3 text-sm text-[color:var(--color-text-primary)]">{f.a_ko}</p>
          </details>
        ))}
      </div>
    </section>

    {/* 운영자 작성 영역 */}
    <section class="mt-12 rounded-lg border-l-4 border-accent-500 bg-accent-100 p-5">
      <div class="text-xs uppercase tracking-wide text-accent-700">운영자 직접 경험</div>
      <p class="mt-2 text-sm text-accent-700">
        운영자(데이비드)는 본인이 MM2H 신청·말레이시아 거주 경험 보유. 실제 신청 과정 · 에이전시 비교 기준 · 비용 디테일은
        <a href="/ko/guide/" class="underline">가이드</a>의 비자 카테고리에 누적합니다.
      </p>
    </section>

    <section class="mt-10 rounded-lg bg-primary-900 p-6 text-white">
      <h2 class="text-lg" style="font-weight:500">어느 비자가 우리 가족에 맞는지 모르겠다면</h2>
      <p class="mt-2 text-sm opacity-90">
        자녀 학년, 희망 국가·도시, 자산·소득 수준을 함께 알려주시면 운영자가 1:1 답변합니다.
      </p>
      <div class="mt-4">
        <a href="/ko/contact/" class="inline-flex items-center rounded-md bg-white px-4 py-2 text-sm text-primary-900" style="font-weight:500">카카오톡 · 이메일 상담 →</a>
      </div>
    </section>
  </section>
</BaseLayout>
