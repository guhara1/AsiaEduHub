---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';

const publishedAt = new Date('2026-05-21');
const updatedAt = new Date('2026-05-21');

const title = '국제학교 입학 일정 캘린더 2026 — 국가별 학사 일정 · 마감일 · 12개월 타임라인 | AsiaEduHub';
const description =
  '한국·말레이·태국·싱가포르·영국·미국·호주 학년 시작 시점 비교. 입학설명회·시험·합격 발표·등록·비자 갱신 12개월 타임라인 정리. 학교 옮기기 적정 시점도 함께.';

const siteRoot = Astro.site?.toString() ?? '';
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: siteRoot + 'ko/' },
    { '@type': 'ListItem', position: 2, name: '비교 / 도구' },
    { '@type': 'ListItem', position: 3, name: '입학 일정 캘린더' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '국제학교 학년 시작 시점은 언제?', acceptedAnswer: { '@type': 'Answer', text: '대부분 9월 시작 (한국·말레이·태국·베트남·영국·미국·캐나다 국제학교). 싱가포르 일부 사립 (SFMS) · 호주는 1월 시작. 자녀 9월 학기 입학 = 전년 9월부터 1년 준비. 1월 학기 입학 = 전년 1월부터 1년 준비.' } },
    { '@type': 'Question', name: '학년 중간 입학(Mid-year)도 가능?', acceptedAnswer: { '@type': 'Answer', text: '대부분 학교 가능. 단 자리 부족 가능성 + 자녀 적응 부담 큼. 학교에 따라 1월 second-intake 운영. 9월 학기 시작 후 11~12월 입학설명회 별도 운영하는 학교도 있음. Mid-year 입학은 학년 진도 따라가는 부담 첫 3개월 큼.' } },
    { '@type': 'Question', name: '12개월 전부터 무엇을 시작?', acceptedAnswer: { '@type': 'Answer', text: '12개월 전 (전년 9월) = 후보 5~7개 학교 압축, 본 사이트 카탈로그로 1차 검토. 9개월 전 = 입학설명회 참가 + 재학 학부모 인터뷰. 6개월 전 = 최종 결정 + 지원서. 3개월 전 = 시험·인터뷰·서류. 1개월 전 = 비자·교복·셔틀.' } },
    { '@type': 'Question', name: '학교 옮기기 가장 좋은 시점?', acceptedAnswer: { '@type': 'Answer', text: '학년 사이 (6~8월 여름방학). 학년 중간 옮기기는 자녀 적응 + 학년 진도 부담. 학년 사이 옮기면 새 학년 시작 시점에 적응 시작 — 다른 신입생들과 같은 출발선. 단, 자녀 학년이 이미 IGCSE/A-Level/DP 본격 시작했으면 옮기기 신중.' } },
  ],
};
---
<BaseLayout
  title={title} description={description}
  jsonLd={[breadcrumb, faqSchema]}
  author={{ name: '데이비드', url: '/ko/about/' }}
  publishedAt={publishedAt} updatedAt={updatedAt}
>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/ko/">홈</a> · 비교 / 도구 · <span style="color: var(--color-text-primary)">입학 일정 캘린더</span>
      </nav>
      <div class="mt-4"><span class="badge-navy">📅 학사 일정</span></div>
      <h1 class="mt-5 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.022em">
        국제학교 입학 일정 캘린더 2026
      </h1>
      <p class="mt-4 max-w-2xl text-base sm:text-lg" style="color: var(--color-text-secondary); line-height: 1.7;">
        한국 · 말레이시아 · 태국 · 싱가포르 · 영국 · 미국 · 호주 학년 시작 시점 비교. 입학설명회 · 시험 · 합격 발표 · 등록 · 비자 갱신 12개월 타임라인.
      </p>
      <div class="mt-5">
        <AuthorByline locale="ko" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="각 학교 공식 사이트 학사 일정, 운영자 학부모 커뮤니티 청취" />
      </div>
    </div>
  </section>

  <article class="container-content py-10 max-w-3xl">

    <div class="rounded-2xl p-6" style="background: linear-gradient(135deg, #FFFBF0 0%, #FEF9E7 100%); border: 1px solid #FCD34D">
      <div class="text-xs uppercase tracking-wider" style="color: var(--color-accent-700); font-weight: 700; letter-spacing: 0.08em">✦ 핵심 포인트</div>
      <p class="mt-3 text-base" style="color: var(--color-accent-700); line-height: 1.7; font-weight: 500">
        대부분 국제학교는 <strong>9월 시작</strong> — 지원 준비는 <strong>12개월 전(전년 9월)</strong>부터. 호주는 1월 시작 — 6개월 갭 활용 가능. 학년 중간 옮기기는 자녀 부담 크므로 학년 사이 (6~8월) 권장.
      </p>
    </div>

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">국가별 학년 시작 시점</h2>
      <div class="mt-5 overflow-x-auto">
        <table class="w-full text-sm border-collapse" style="border:1px solid var(--color-border-light)">
          <thead>
            <tr style="background: var(--color-bg-soft)">
              <th class="p-3 text-left" style="border:1px solid var(--color-border-light)">국가</th>
              <th class="p-3 text-left" style="border:1px solid var(--color-border-light)">학년 시작</th>
              <th class="p-3 text-left" style="border:1px solid var(--color-border-light)">학년 종료</th>
              <th class="p-3 text-left" style="border:1px solid var(--color-border-light)">메인 휴가</th>
            </tr>
          </thead>
          <tbody>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">한국</td><td class="p-3" style="border:1px solid var(--color-border-light)">3월 (한국 공립)</td><td class="p-3" style="border:1px solid var(--color-border-light)">2월</td><td class="p-3" style="border:1px solid var(--color-border-light)">여름 · 겨울 방학</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">한국 외국인학교</td><td class="p-3" style="border:1px solid var(--color-border-light)">8월 말~9월</td><td class="p-3" style="border:1px solid var(--color-border-light)">6월</td><td class="p-3" style="border:1px solid var(--color-border-light)">여름·겨울·봄</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">말레이시아</td><td class="p-3" style="border:1px solid var(--color-border-light)">8월 말~9월</td><td class="p-3" style="border:1px solid var(--color-border-light)">6월</td><td class="p-3" style="border:1px solid var(--color-border-light)">3 텀제 · 텀 사이 휴식</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">태국</td><td class="p-3" style="border:1px solid var(--color-border-light)">8월 말~9월</td><td class="p-3" style="border:1px solid var(--color-border-light)">6월</td><td class="p-3" style="border:1px solid var(--color-border-light)">3 텀제</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">베트남</td><td class="p-3" style="border:1px solid var(--color-border-light)">8월 말~9월</td><td class="p-3" style="border:1px solid var(--color-border-light)">6월</td><td class="p-3" style="border:1px solid var(--color-border-light)">3 텀제</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">싱가포르 국제학교</td><td class="p-3" style="border:1px solid var(--color-border-light)">8월 말~9월</td><td class="p-3" style="border:1px solid var(--color-border-light)">6월</td><td class="p-3" style="border:1px solid var(--color-border-light)">3 텀제</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">싱가포르 SFMS (사립)</td><td class="p-3" style="border:1px solid var(--color-border-light)">1월</td><td class="p-3" style="border:1px solid var(--color-border-light)">11월</td><td class="p-3" style="border:1px solid var(--color-border-light)">싱가포르 공립 학사</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">영국</td><td class="p-3" style="border:1px solid var(--color-border-light)">9월</td><td class="p-3" style="border:1px solid var(--color-border-light)">7월</td><td class="p-3" style="border:1px solid var(--color-border-light)">3 텀제 + Half-term</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">미국</td><td class="p-3" style="border:1px solid var(--color-border-light)">8월 말~9월</td><td class="p-3" style="border:1px solid var(--color-border-light)">5~6월</td><td class="p-3" style="border:1px solid var(--color-border-light)">2 학기제</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">캐나다</td><td class="p-3" style="border:1px solid var(--color-border-light)">9월</td><td class="p-3" style="border:1px solid var(--color-border-light)">6월</td><td class="p-3" style="border:1px solid var(--color-border-light)">2 학기제</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">호주 (남반구)</td><td class="p-3" style="border:1px solid var(--color-border-light)">1월 말~2월</td><td class="p-3" style="border:1px solid var(--color-border-light)">12월</td><td class="p-3" style="border:1px solid var(--color-border-light)">4 텀제</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">9월 학기 입학 12개월 타임라인</h2>
      <p class="mt-3 text-base" style="line-height:1.75">한국·동남아·영국·미국 국제학교 대부분 9월 학기 시작 기준입니다.</p>
      <div class="mt-5 overflow-x-auto">
        <table class="w-full text-sm border-collapse" style="border:1px solid var(--color-border-light)">
          <thead>
            <tr style="background: var(--color-bg-soft)">
              <th class="p-3 text-left" style="border:1px solid var(--color-border-light)">시점</th>
              <th class="p-3 text-left" style="border:1px solid var(--color-border-light)">할 일</th>
            </tr>
          </thead>
          <tbody>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">전년 9월 (-12개월)</td><td class="p-3" style="border:1px solid var(--color-border-light)">후보 학교 5~7개 압축. 본 사이트 카탈로그·블로그 글로 1차 검토.</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">전년 10~11월 (-10개월)</td><td class="p-3" style="border:1px solid var(--color-border-light)">3~4개 학교 입학설명회 참가. 재학 한국 학부모 1명씩 인터뷰 요청.</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">전년 12월 (-9개월)</td><td class="p-3" style="border:1px solid var(--color-border-light)">자녀 데려가서 캠퍼스 직접 체감. 최종 1~2개 학교 압축.</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">1~2월 (-7개월)</td><td class="p-3" style="border:1px solid var(--color-border-light)">온라인 지원서 + 지원료 결제. UKiset · SSAT · TOEFL 등 응시.</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">3월 (-6개월)</td><td class="p-3" style="border:1px solid var(--color-border-light)">학교 입학 시험 + 인터뷰. 이전 학교 알리기 시점 (새 학교 합격 통지 후가 안전).</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">4월 (-5개월)</td><td class="p-3" style="border:1px solid var(--color-border-light)">합격 통지 + 등록금 결제 + 환불 가능 보증금 결제.</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">5~6월 (-3~4개월)</td><td class="p-3" style="border:1px solid var(--color-border-light)">학생 비자 갱신 + 이전 학교 성적표·서류 정리. 가족 이사 준비.</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">7월 (-2개월)</td><td class="p-3" style="border:1px solid var(--color-border-light)">교복·교재 구입. 셔틀·점심·CCA 신청.</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">8월 (-1개월)</td><td class="p-3" style="border:1px solid var(--color-border-light)">오리엔테이션 참석. 새 거주지 정착.</td></tr>
            <tr style="background: #FFFBF0"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:700">9월 (D-Day)</td><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:700">학년 시작</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">호주 1월 학기 학부모를 위한 갭 활용</h2>
      <p class="mt-3 text-base" style="line-height:1.75">한국 (3월·9월) 또는 동남아 (9월) 학년 시작과 호주 (1월) 학년 시작 사이 갭 활용:</p>
      <ul class="mt-4 space-y-2 text-sm" style="line-height:1.7">
        <li>• 한국 학년 종료 (2월) → 호주 학년 시작 (1월·2월) — 부드러운 전환</li>
        <li>• 동남아 학년 종료 (6월) → 호주 학년 시작 (1월·2월) — 6개월 갭 활용 (영어 학원·여행·가족 시간)</li>
        <li>• 호주 학년 종료 (12월) → 한국 학년 시작 (3월) — 2~3개월 갭 활용</li>
      </ul>
      <p class="mt-4 text-sm" style="color: var(--color-text-secondary); line-height: 1.7">
        💡 <strong>실용 팁:</strong> 자녀 영어 부족한 경우 호주 학기 시작 전 3~6개월 영어 집중 학원·홈튜터 권장. 호주 학교 입학 시험 (AEAS) 도 같은 시점 응시.
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">학교 옮기기 적정 시점</h2>
      <ul class="mt-4 space-y-3 text-sm" style="line-height:1.7">
        <li>✅ <strong>가장 좋음:</strong> 학년 사이 (6~8월 여름방학) — 새 학년 시작 시점에 적응 시작</li>
        <li>✅ <strong>좋음:</strong> 1월 second-intake (학교가 운영하는 경우) — 학년 중간이지만 학교가 입학 절차 정식 운영</li>
        <li>⚠️ <strong>주의:</strong> 학년 중간 임의 시점 — 자녀 학년 진도 따라가는 부담 + 친구 그룹 이미 형성</li>
        <li>❌ <strong>피하세요:</strong> IGCSE/A-Level/DP 본격 시작 후 (Year 10~13) — 1년 추가 학업 가능성 큼</li>
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">중요 시험 응시 시점</h2>
      <div class="mt-5 overflow-x-auto">
        <table class="w-full text-sm border-collapse" style="border:1px solid var(--color-border-light)">
          <thead>
            <tr style="background: var(--color-bg-soft)">
              <th class="p-3 text-left" style="border:1px solid var(--color-border-light)">시험</th>
              <th class="p-3 text-left" style="border:1px solid var(--color-border-light)">목적</th>
              <th class="p-3 text-left" style="border:1px solid var(--color-border-light)">권장 응시 시점</th>
            </tr>
          </thead>
          <tbody>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">UKiset</td><td class="p-3" style="border:1px solid var(--color-border-light)">UK 학교 입학</td><td class="p-3" style="border:1px solid var(--color-border-light)">입학 1년 전 (Year 6·8·10 가을)</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">ISEB Pre-test</td><td class="p-3" style="border:1px solid var(--color-border-light)">UK 보딩 13+</td><td class="p-3" style="border:1px solid var(--color-border-light)">Year 6 가을</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">SSAT</td><td class="p-3" style="border:1px solid var(--color-border-light)">미국 보딩 9~12학년</td><td class="p-3" style="border:1px solid var(--color-border-light)">입학 1년 전 가을</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">TOEFL iBT</td><td class="p-3" style="border:1px solid var(--color-border-light)">미국·캐나다·호주 영어 증명</td><td class="p-3" style="border:1px solid var(--color-border-light)">입학 6개월 전</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">IELTS</td><td class="p-3" style="border:1px solid var(--color-border-light)">UK·호주·캐나다 영어 증명</td><td class="p-3" style="border:1px solid var(--color-border-light)">입학 6개월 전</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">AEAS</td><td class="p-3" style="border:1px solid var(--color-border-light)">호주 학교 입학</td><td class="p-3" style="border:1px solid var(--color-border-light)">입학 6~12개월 전</td></tr>
            <tr><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">CAT4 · MAP</td><td class="p-3" style="border:1px solid var(--color-border-light)">동남아 학교 입학</td><td class="p-3" style="border:1px solid var(--color-border-light)">학교가 정한 시점 (보통 3개월 전)</td></tr>
            <tr style="background: var(--color-bg-soft)"><td class="p-3" style="border:1px solid var(--color-border-light); font-weight:600">SAT · ACT</td><td class="p-3" style="border:1px solid var(--color-border-light)">미국 대학 진학</td><td class="p-3" style="border:1px solid var(--color-border-light)">Grade 11 가을 ~ Grade 12 봄</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">자주 묻는 질문</h2>
      <div class="mt-5 space-y-3">
        {faqSchema.mainEntity.map((f: any) => (
