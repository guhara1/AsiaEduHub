---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import TrackSimulator from '~/components/react/TrackSimulator.tsx';
const publishedAt = new Date('2026-05-21');
const updatedAt = new Date('2026-05-21');
const title = '升学路径模拟器 — 济州 NLCS → 牛剑 · 东南亚 IB → 美国 Top 30 场景 | AsiaEduHub';
const description = '输入子女年级 · 英语水平 · 目标大学 · 预算 → 各年级阶段 · 考试 · 总成本自动计算。7 大核心升学路径场景对比。';
---
<BaseLayout title={title} description={description} author={{ name: 'David', url: '/zh/about/' }} publishedAt={publishedAt} updatedAt={updatedAt}>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)"><a href="/zh/">首页</a> · 对比 / 工具 · <span style="color: var(--color-text-primary)">升学路径模拟器</span></nav>
      <h1 class="mt-5 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.022em">升学路径模拟器</h1>
      <p class="mt-4 max-w-2xl text-base sm:text-lg" style="color: var(--color-text-secondary); line-height: 1.7;">输入子女年级 · 英语水平 · 目标大学 · 预算 → 各年级阶段 · 考试 · 总成本自动计算。</p>
      <div class="mt-5"><AuthorByline locale="zh" publishedAt={publishedAt} updatedAt={updatedAt} sources="各校升学结果公示,牛剑 · 常春藤 · 澳 Top 8 入学标准" /></div>
    </div>
  </section>
  <article class="container-content py-10 max-w-3xl">
    <div class="rounded-2xl p-6" style="background: linear-gradient(135deg, #FFFBF0 0%, #FEF9E7 100%); border: 1px solid #FCD34D">
      <div class="text-xs uppercase tracking-wider" style="color: var(--color-accent-700); font-weight: 700; letter-spacing: 0.08em">✦ 核心要点</div>
      <p class="mt-3 text-base" style="color: var(--color-accent-700); line-height: 1.7; font-weight: 500">同一子女不同升学路径 = <strong>总成本 4 倍 + 结果差异</strong>。名校寄宿 · 东南亚 IB · 韩国国际学校 → 牛剑/常春藤/澳 Top 8/韩国 SKY 模拟对比。</p>
    </div>
    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">模拟器</h2>
      <TrackSimulator client:visible locale="zh" />
    </section>
    <section class="mt-12 card-cta">
      <h2 class="text-xl text-white" style="font-weight:500">子女升学路径 1:1 咨询</h2>
      <p class="mt-3 text-sm">告知子女年级 · 英语水平 · 目标大学 · 家庭优先级 · 预算,可获 7 大路径中最优答复。</p>
      <a href="/zh/contact/" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-3" style="font-weight:500">WeChat 咨询<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></a>
    </section>
    <section class="mt-10">
      <h2 class="text-xl" style="font-weight:700">相关工具 · 信息</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/zh/tools/curriculum-guide/" class="card text-sm block"><div class="text-primary-900" style="font-weight:500">📚 IB vs AP vs A-Level</div></a>
        <a href="/zh/tools/calculator/" class="card text-sm block"><div class="text-primary-900" style="font-weight:500">💰 学费计算器</div></a>
        <a href="/zh/abroad/anglosphere/usa/" class="card text-sm block"><div class="text-primary-900" style="font-weight:500">🇺🇸 美国寄宿</div></a>
        <a href="/zh/abroad/anglosphere/uk/" class="card text-sm block"><div class="text-primary-900" style="font-weight:500">🇬🇧 英国牛剑路径</div></a>
      </div>
    </section>
  </article>
</BaseLayout>
