---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import { FOREIGN_SCHOOLS, REGION_METAS, COMMON_ELIGIBILITY, COMMON_ADMISSION_PROCESS, getRegionFaqs, type DomesticRegion } from '~/lib/domestic-schools';

export async function getStaticPaths() {
  const regions = REGION_METAS.filter((r) => r.category === 'foreign-schools');
  return regions.map((r) => ({
    params: { region: r.id },
    props: { regionId: r.id },
  }));
}

const { regionId } = Astro.props as { regionId: DomesticRegion };
const meta = REGION_METAS.find((r) => r.category === 'foreign-schools' && r.id === regionId)!;
const schools = FOREIGN_SCHOOLS.filter((s) => s.region === regionId);

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const title = `${meta.zh} — 学校详细对比(学费 · 课程 · 入学资格)| AsiaEduHub`;
const description = `${meta.zh}全部学校:${schools.map((s) => s.abbreviation || s.name_en).join(' · ')}。按校整理入学资格 · 课程 · 学费 · 官网 · 常见问题。`;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'zh/' },
    { '@type': 'ListItem', position: 2, name: '韩国国际学校', item: (Astro.site?.toString() ?? '') + 'zh/domestic/' },
    { '@type': 'ListItem', position: 3, name: '外国人学校' },
    { '@type': 'ListItem', position: 4, name: meta.zh },
  ],
};
const elig = COMMON_ELIGIBILITY['foreign-schools'].zh;
const proc = COMMON_ADMISSION_PROCESS.zh;
const faqs = getRegionFaqs(regionId);

const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q_zh,
    acceptedAnswer: { '@type': 'Answer', text: f.a_zh },
  })),
} : null;
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={faqSchema ? [breadcrumb, faqSchema] : breadcrumb}
  author={{ name: 'David', url: '/zh/about/' }}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="container-content py-10">
    <nav class="text-sm text-[color:var(--color-text-secondary)]">
      <a href="/zh/">首页</a> · <a href="/zh/domestic/">韩国国际学校</a> · 外国人学校 · {meta.zh}
    </nav>

    <h1 class="mt-3 text-2xl sm:text-3xl">{meta.zh}</h1>
    <p class="mt-3 max-w-2xl text-sm text-[color:var(--color-text-secondary)]">{meta.intro_zh}</p>

    <div class="mt-4">
      <AuthorByline locale="zh" publishedAt={publishedAt} updatedAt={updatedAt}
        sources="《外国人学校法》、各校官网、各校招生资料" />
    </div>

    <section class="mt-8">
      <h2 class="text-xl">{meta.zh} — 共 {schools.length} 所</h2>
      <div class="mt-4 grid gap-5 md:grid-cols-2">
        {schools.map((s) => (
          <a href={`/zh/domestic/foreign-schools/${s.region}/${s.slug}/`} class="block rounded-lg border p-5 transition-colors hover:border-primary-700" style="border-color: var(--color-border-light)">
            <div class="flex items-baseline justify-between">
              <h3 class="text-lg text-primary-900" style="font-weight:500">{s.name_zh}</h3>
              {s.founded_year && <span class="text-xs text-[color:var(--color-text-tertiary)]">{s.founded_year} 创立</span>}
            </div>
            <p class="mt-1 text-xs text-[color:var(--color-text-secondary)]">{s.name_en}{s.abbreviation && ` (${s.abbreviation})`}</p>
            <p class="mt-1 text-xs text-[color:var(--color-text-tertiary)]">
              {s.city_zh}{s.district_zh && ` · ${s.district_zh}`}
            </p>
            <p class="mt-3 text-sm text-[color:var(--color-text-secondary)]">{s.summary_zh}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {s.curriculum_en.map((c) => (
                <span class="rounded-full bg-[color:var(--color-bg-tertiary)] px-2 py-0.5 text-[10px] text-[color:var(--color-text-secondary)]">{c}</span>
              ))}
            </div>
            <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">
              年学费(估算):${s.tuition_range_usd[0].toLocaleString()} – ${s.tuition_range_usd[1].toLocaleString()}
            </p>
          </a>
        ))}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-xl">外国人学校通用入学资格</h2>
      <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">
        依据《外国人学校法》(2009)— 适用于 {meta.zh} 全部学校。各校附加要求请查阅官网。
      </p>
      <ul class="mt-4 space-y-2 text-sm">
        {elig.map((e) => <li>• {e}</li>)}
      </ul>
      <p class="mt-4 rounded-md border-l-4 border-accent-500 bg-accent-100 p-3 text-xs text-accent-700">
        ⚠ 本国学生入读外国人学校受严格限制。需父母外籍或学生海外居住 3 年以上。仅为英语环境建议查看 <a href="/zh/domestic/international-schools/jeju/" class="underline">济州国际学校</a>。
      </p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl">入学时间表(秋季学期)</h2>
      <ol class="mt-4 space-y-2 text-sm">
        {proc.map((p) => <li>• {p}</li>)}
      </ol>
    </section>

    <section class="mt-10 rounded-lg border bg-[color:var(--color-bg-secondary)] p-5" style="border-color: var(--color-border-light)">
      <h2 class="text-lg" style="font-weight:500">学费之外的附加费用(通用)</h2>
      <ul class="mt-3 space-y-1 text-sm text-[color:var(--color-text-secondary)]">
        <li>• 注册费(年学费的 10~30%)</li>
        <li>• 设施分摊费</li>
        <li>• 校服 · 教材</li>
        <li>• 校车(月 30~80 万韩元)</li>
        <li>• 餐费(月 30~60 万韩元)</li>
        <li>• 考试报名费(IB · AP · SAT 等)</li>
      </ul>
      <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">建议在年学费基础上预留 15~25% 作为额外开支。</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl">各校详细页面</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {schools.map((s) => (
          <a href={`/zh/domestic/foreign-schools/${s.region}/${s.slug}/`} class="rounded-full border px-3 py-1 text-xs hover:border-primary-700 hover:text-primary-700" style="border-color: var(--color-border-light)">
            {s.name_zh} →
          </a>
        ))}
      </div>
    </section>

    {faqs.length > 0 && (
      <section id="faq" class="mt-12 scroll-mt-24">
        <h2 class="text-xl">{meta.zh} 常见问题</h2>
        <div class="mt-5 space-y-3">
          {faqs.map((f) => (
            <details class="rounded-lg border p-4" style="border-color: var(--color-border-light)">
              <summary class="cursor-pointer text-sm text-primary-900" style="font-weight:500; list-style: disclosure-closed">{f.q_zh}</summary>
              <p class="mt-3 text-sm text-[color:var(--color-text-primary)]">{f.a_zh}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <section class="mt-12 rounded-lg bg-primary-900 p-6 text-white">
      <h2 class="text-lg" style="font-weight:500">不确定哪所学校适合您家孩子?</h2>
      <p class="mt-2 text-sm opacity-90">请告知海外居住经历 · 孩子年级 · 对韩国学生比例的偏好 · 预算,站长 1:1 答复。</p>
      <div class="mt-4">
        <a href="/zh/contact/" class="inline-flex items-center rounded-md bg-white px-4 py-2 text-sm text-primary-900" style="font-weight:500">WeChat 咨询 →</a>
      </div>
    </section>
  </section>
</BaseLayout>
