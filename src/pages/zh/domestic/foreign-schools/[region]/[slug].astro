---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import Flag from '~/components/Flag.astro';
import SchoolFinancialDetails from '~/components/SchoolFinancialDetails.astro';
import SchoolNeighborhood from '~/components/SchoolNeighborhood.astro';
import { deriveFinance } from '~/lib/school-finance';
import { SCHOOL_NEIGHBORHOODS } from '~/lib/school-neighborhood';
import { domesticToFinanceInput } from '~/lib/domestic-schools';
import { FOREIGN_SCHOOLS, REGION_METAS, COMMON_ELIGIBILITY, COMMON_ADMISSION_PROCESS } from '~/lib/domestic-schools';

export async function getStaticPaths() {
  return FOREIGN_SCHOOLS.map((s) => ({
    params: { region: s.region, slug: s.slug },
    props: { school: s },
  }));
}

const { school: s } = Astro.props;
const meta = REGION_METAS.find((r) => r.category === 'foreign-schools' && r.id === s.region)!;

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const title = `${s.name_zh} (${s.name_en}) — 入学资格 · 课程 · 学费完整整理 | AsiaEduHub`;
const description = s.summary_zh;

const eduOrg = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: s.name_en,
  alternateName: [s.name_ko, s.name_zh].filter(Boolean),
  url: s.website,
  sameAs: [s.website].filter(Boolean),
  foundingDate: s.founded_year ? `${s.founded_year}` : undefined,
  address: { '@type': 'PostalAddress', addressLocality: s.city_zh, addressCountry: 'KR' },
  description: s.summary_zh,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `${s.name_zh} 年学费`,
    itemListElement: [{
      '@type': 'Offer',
      priceCurrency: 'USD',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: s.tuition_range_usd[0],
        maxPrice: s.tuition_range_usd[1],
        priceCurrency: 'USD',
      },
      category: '年学费',
    }],
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'zh/' },
    { '@type': 'ListItem', position: 2, name: '韩国国际学校', item: (Astro.site?.toString() ?? '') + 'zh/domestic/' },
    { '@type': 'ListItem', position: 3, name: meta.zh, item: (Astro.site?.toString() ?? '') + `zh/domestic/foreign-schools/${s.region}/` },
    { '@type': 'ListItem', position: 4, name: s.name_zh },
  ],
};

const elig = COMMON_ELIGIBILITY['foreign-schools'].zh;
const proc = COMMON_ADMISSION_PROCESS.zh;

const otherSchools = FOREIGN_SCHOOLS.filter((o) => o.region === s.region && o.slug !== s.slug);
const finance = deriveFinance(domesticToFinanceInput(s));
const neighborhoods = SCHOOL_NEIGHBORHOODS[s.slug] ?? [];
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[eduOrg, breadcrumb]}
  author={{ name: 'David', url: '/zh/about/' }}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="hero-gradient hero-gradient-korea school-hero-wrap">
    <div class="container-content pt-10 sm:pt-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/zh/domestic/">韩国国际学校</a> ·
        <a href={`/zh/domestic/foreign-schools/${s.region}/`}>{meta.zh}</a> · <span style="color: var(--color-text-primary)">{s.name_zh}</span>
      </nav>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <span class="badge-navy"><Flag country="KR" />外国人学校</span>
        {s.founded_year && <span class="badge-navy">{s.founded_year} 创立</span>}
      </div>

      <h1 class="mt-5 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.02em">{s.name_zh}</h1>
      <p class="mt-2 text-base" style="color: var(--color-text-secondary); font-weight:500">{s.name_en}{s.abbreviation && ` · ${s.abbreviation}`}</p>
      <p class="mt-5 max-w-2xl text-base sm:text-lg text-pretty" style="color: var(--color-text-secondary); line-height: 1.7;">{s.summary_zh}</p>

      <div class="mt-6">
        <AuthorByline locale="zh" publishedAt={publishedAt} updatedAt={updatedAt}
          sources={`${s.name_zh} 官网,《外国人学校法》,学校招生资料`} />
      </div>

      <div class="mt-5">
        <a href={s.website} target="_blank" rel="noopener" class="official-site-button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.7"/>
            <path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20" stroke="currentColor" stroke-width="1.7"/>
          </svg>
          访问官方网站
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M7 17L17 7M7 7h10v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <div class="container-content school-stats-overlap">
    <dl class="stat-grid grid-cols-2 lg:grid-cols-4">
      <div class="stat-card">
        <span class="stat-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-7.5-7-12a7 7 0 1114 0c0 4.5-7 12-7 12z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.8"/></svg>
        </span>
        <dt>位置</dt>
        <dd>{s.city_zh}{s.district_zh && <><br/><span class="text-sm" style="color:var(--color-text-secondary); font-weight:500">{s.district_zh}</span></>}</dd>
      </div>
      <div class="stat-card">
        <span class="stat-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M2 7l10-4 10 4-10 4L2 7zM6 9v5c0 2 3 3 6 3s6-1 6-3V9" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
        </span>
        <dt>年级</dt>
        <dd>{s.grade_range}</dd>
      </div>
      <div class="stat-card">
        <span class="stat-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 5h16v14H4zM4 9h16M9 5v14" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
        </span>
        <dt>课程</dt>
        <dd class="text-sm" style="font-weight:600">{s.curriculum_en.join(' · ')}</dd>
      </div>
      <div class="stat-card stat-card-tuition">
        <span class="stat-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </span>
        <dt>年学费(估算)</dt>
        <dd>${s.tuition_range_usd[0].toLocaleString()}~${s.tuition_range_usd[1].toLocaleString()}</dd>
        <p class="tuition-note">学校官网为准</p>
      </div>
    </dl>
  </div>

  <article class="container-content pt-6 pb-12 max-w-3xl">

    <section class="mt-10">
      <h2 class="text-xl">{s.name_zh} 核心特点</h2>
      <p class="mt-2 text-xs text-[color:var(--color-text-tertiary)]">基于学校官方资料整理</p>
      <ul class="mt-4 space-y-2 text-sm">
        {s.highlights_zh.map((h) => <li>✓ {h}</li>)}
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-xl">入学资格(《外国人学校法》)</h2>
      <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">
        {s.name_zh}依据《外国人学校法》(2009),申请人须满足以下资格之一。
      </p>
      <ul class="mt-4 space-y-2 text-sm">
        {elig.map((e) => <li>• {e}</li>)}
      </ul>
      <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">
        各校附加要求(英语测试种类 · 面试 等)请查阅官网。
      </p>
    </section>

    <SchoolFinancialDetails details={finance} locale="zh" schoolName={s.name_zh} />

    {neighborhoods.length > 0 && <SchoolNeighborhood neighborhoods={neighborhoods} locale="zh" />}

    <section class="mt-10">
      <h2 class="text-xl">入学流程(秋季学期)</h2>
      <ol class="mt-4 space-y-2 text-sm">
        {proc.map((p) => <li>• {p}</li>)}
      </ol>
    </section>

    <section class="mt-10 rounded-lg border-l-4 border-accent-500 bg-accent-100 p-5">
      <div class="text-xs uppercase tracking-wide text-accent-700">站长一句话(待补充)</div>
      <p class="mt-2 text-sm text-accent-700">
        站长(David)将在参加 {s.name_zh} 招生说明会 · 在校生访谈 · 校园走访后,从家长视角补充分析。
        韩国学生比例 · 教师国籍 · 设施自有/共用等学校公开资料未涉及的细节可
        <a href="/zh/contact/" class="underline">直接向站长咨询</a>。
      </p>
    </section>

    {otherSchools.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl">同地区其他学校</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {otherSchools.map((o) => (
            <a href={`/zh/domestic/foreign-schools/${o.region}/${o.slug}/`} class="block rounded-md border p-4 text-sm hover:border-primary-700" style="border-color: var(--color-border-light)">
              <div class="text-primary-900" style="font-weight:500">{o.name_zh}</div>
              <div class="mt-1 text-xs text-[color:var(--color-text-secondary)]">{o.curriculum_en.join(' · ')}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mt-12 rounded-lg bg-primary-900 p-6 text-white">
      <h2 class="text-lg" style="font-weight:500">{s.name_zh} 入学咨询</h2>
      <p class="mt-2 text-sm opacity-90">
        告知孩子年级 · 海外居住经历 · 英语水平 · 预算,可获 {s.name_zh} 与可比学校的 1:1 答复。
      </p>
      <div class="mt-4">
        <a href="/zh/contact/" class="inline-flex items-center rounded-md bg-white px-4 py-2 text-sm text-primary-900" style="font-weight:500">WeChat 咨询 →</a>
      </div>
    </section>

    <p class="mt-8 text-xs text-[color:var(--color-text-tertiary)]">
      ※ 本页基于 {s.name_zh} 公开资料,由站长(David)整理。学校政策 · 学费 · 资格每年都可能变化,最新信息请以学校官网为准。
    </p>
  </article>
</BaseLayout>
