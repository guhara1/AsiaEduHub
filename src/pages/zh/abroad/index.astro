---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import SchoolCard from '~/components/SchoolCard.astro';
import { loadSchools } from '~/lib/schools';
import { SOUTHEAST_ASIA, ANGLOSPHERE, SCHOOL_TYPES, countryName, cityName } from '~/lib/locations';
import { COUNTRIES, ABROAD_FAQS } from '~/lib/abroad-info';

const schools = await loadSchools('zh');
const seaCountries = COUNTRIES.filter((c) => c.region === 'sea');
const angloCountries = COUNTRIES.filter((c) => c.region === 'anglo');

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const title = '海外国际学校 — 东南亚(高性价比)vs 英美澳加(高端)全面对比 | AsiaEduHub';
const description =
  '马来西亚 · 泰国 · 新加坡 · 越南东南亚国际学校与美国 · 英国 · 加拿大 · 澳大利亚英美澳加寄宿学校学费 · 生活成本 · 签证 · 升学路径对比。站长本地居住核实。';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'zh/' },
    { '@type': 'ListItem', position: 2, name: '海外留学' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: ABROAD_FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q_zh,
    acceptedAnswer: { '@type': 'Answer', text: f.a_zh },
  })),
};
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumb, faqSchema]}
  author={{ name: 'David', url: '/zh/about/' }}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="hero-gradient border-b" style="border-color: var(--color-border-light)">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)"><a href="/zh/">首页</a> · 海外留学</nav>
      <h1 class="mt-3 text-3xl sm:text-4xl text-balance">海外国际学校 — <span class="text-accent-700">东南亚高性价比</span> vs <span class="text-primary-900">英美澳加高端</span></h1>
      <p class="mt-4 max-w-2xl text-base text-pretty" style="color: var(--color-text-secondary); line-height: 1.65;">
        为孩子升入英美澳加大学的两条战略路径:
        <strong style="font-weight:500">东南亚 IB 学校(高性价比)</strong>与 <strong style="font-weight:500">英美澳加寄宿学校(高端)</strong>。
        学费 · 生活成本 · 签证 · 升学路径一页通览。
      </p>
      <div class="mt-5">
        <AuthorByline locale="zh" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="各国政府官方资料、学校官方公告、MM2H · Thailand Privilege · MOM · ICA、站长本地居住(吉隆坡)" />
      </div>
    </div>
  </section>

  <section class="container-content py-10">

    <section class="mt-8 grid gap-4 md:grid-cols-2">
      <div class="rounded-lg border-l-4 border-accent-500 bg-accent-100 p-5">
        <div class="text-xs uppercase tracking-wide text-accent-700">🌏 东南亚(高性价比)</div>
        <h2 class="mt-1 text-lg text-accent-700" style="font-weight:500">$6K–$50K / 年 · MM2H · Elite · EP</h2>
        <ul class="mt-3 space-y-1 text-sm text-accent-700">
          <li>• 学费为英美寄宿的 1/3 ~ 1/2</li>
          <li>• 家长陪读签证选项多</li>
          <li>• 与亚洲时差小,飞行短</li>
          <li>• 站长本地居住,信息可及性高</li>
        </ul>
      </div>
      <div class="rounded-lg border-l-4 border-primary-700 bg-primary-100 p-5">
        <div class="text-xs uppercase tracking-wide text-primary-900">🌎 英美澳加(高端)</div>
        <h2 class="mt-1 text-lg text-primary-900" style="font-weight:500">$20K–$90K / 年 · 寄宿为主 · Student Visa</h2>
        <ul class="mt-3 space-y-1 text-sm text-primary-900">
          <li>• 顶尖寄宿(Eton · Andover · Westminster 等)</li>
          <li>• 牛剑 · 常春藤直通</li>
          <li>• IB / A-Level / AP 正统环境</li>
          <li>• 家长难陪读(澳大利亚 590 例外)</li>
        </ul>
      </div>
    </section>

    <section class="mt-10 overflow-x-auto">
      <h2 class="text-xl">按国家对比 — 学费 · 生活成本 · 签证</h2>
      <table class="mt-4 w-full text-sm min-w-[820px]">
        <thead>
          <tr class="border-b" style="border-color: var(--color-border-light)">
            <th class="py-2 text-left" style="font-weight:500">国家</th>
            <th class="py-2 text-left" style="font-weight:500">年学费 (USD)</th>
            <th class="py-2 text-left" style="font-weight:500">家庭月生活费 (USD)</th>
            <th class="py-2 text-left" style="font-weight:500">家长签证</th>
            <th class="py-2 text-left" style="font-weight:500">一句话总结</th>
          </tr>
        </thead>
        <tbody class="text-[color:var(--color-text-secondary)]">
          {COUNTRIES.map((c) => (
            <tr class="border-b align-top" style="border-color: var(--color-border-light)">
              <td class="py-3 text-[color:var(--color-text-primary)]" style="font-weight:500">
                {c.flag} {c.zh_name}
                {c.operator_proximity === 'high' && <span class="ml-2 badge-gold text-[10px]">⭐ 站长居住</span>}
              </td>
              <td class="py-3">${c.tuition_range_usd[0].toLocaleString()} – ${c.tuition_range_usd[1].toLocaleString()}</td>
              <td class="py-3">${c.family_living_monthly_usd[0].toLocaleString()} – ${c.family_living_monthly_usd[1].toLocaleString()}</td>
              <td class="py-3">{c.popular_visas_zh.join(' · ')}</td>
              <td class="py-3 text-[color:var(--color-text-primary)]">{c.tagline_zh}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">※ 2025–2026 时点市场推估,因学校 · 城市 · 学年不同。</p>
    </section>

    <section class="mt-12">
      <h2 class="text-xl">🌏 东南亚 — 高性价比 4 国详情</h2>
      <div class="mt-4 grid gap-5 md:grid-cols-2">
        {seaCountries.map((c) => (
          <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
            <h3 class="text-lg" style="font-weight:500">{c.flag} {c.zh_name}</h3>
            <p class="mt-1 text-xs text-[color:var(--color-text-tertiary)]">{c.tagline_zh}</p>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              <div>
                <div class="text-xs text-primary-900" style="font-weight:500">优点</div>
                <ul class="mt-1 space-y-1 text-xs text-[color:var(--color-text-primary)]">{c.pros_zh.map((p) => <li>✓ {p}</li>)}</ul>
              </div>
              <div>
                <div class="text-xs" style="font-weight:500; color: var(--color-danger)">缺点</div>
                <ul class="mt-1 space-y-1 text-xs text-[color:var(--color-text-primary)]">{c.cons_zh.map((p) => <li>⚠ {p}</li>)}</ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-xl">🌎 英美澳加 — 高端 4 国详情</h2>
      <div class="mt-4 grid gap-5 md:grid-cols-2">
        {angloCountries.map((c) => (
          <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
            <h3 class="text-lg" style="font-weight:500">{c.flag} {c.zh_name}</h3>
            <p class="mt-1 text-xs text-[color:var(--color-text-tertiary)]">{c.tagline_zh}</p>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              <div>
                <div class="text-xs text-primary-900" style="font-weight:500">优点</div>
                <ul class="mt-1 space-y-1 text-xs text-[color:var(--color-text-primary)]">{c.pros_zh.map((p) => <li>✓ {p}</li>)}</ul>
              </div>
              <div>
                <div class="text-xs" style="font-weight:500; color: var(--color-danger)">缺点</div>
                <ul class="mt-1 space-y-1 text-xs text-[color:var(--color-text-primary)]">{c.cons_zh.map((p) => <li>⚠ {p}</li>)}</ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="faq" class="mt-12 scroll-mt-24">
      <h2 class="text-xl">常见问题</h2>
      <div class="mt-5 space-y-3">
        {ABROAD_FAQS.map((f) => (
          <details class="rounded-lg border p-4" style="border-color: var(--color-border-light)">
            <summary class="cursor-pointer text-sm text-primary-900" style="font-weight:500; list-style: disclosure-closed">{f.q_zh}</summary>
            <p class="mt-3 text-sm text-[color:var(--color-text-primary)]">{f.a_zh}</p>
          </details>
        ))}
      </div>
    </section>

    <h2 class="mt-16 text-xl">已收录学校(站长核实)</h2>
    <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">站长亲自走访 · 核实的学校陆续上架。空白城市将随学校添加自动显示。</p>

    <div class="mt-4 flex flex-wrap gap-2">
      <span class="text-xs text-[color:var(--color-text-tertiary)] self-center">东南亚:</span>
      {SOUTHEAST_ASIA.map((c) => (
        <a href={`#${c.id}`} class="rounded-full bg-accent-100 px-3 py-1 text-xs text-accent-700 hover:bg-accent-500 hover:text-white" style="font-weight:500">
          {c.flag} {countryName(c, 'zh')}
        </a>
      ))}
    </div>

    {SOUTHEAST_ASIA.map((country) => {
      const countrySchools = schools.filter((s) => s.data.country === country.id);
      return (
        <section id={country.id} class="mt-10 scroll-mt-24">
          <div class="flex items-end justify-between border-b pb-2" style="border-color: var(--color-border-light)">
            <h3 class="text-lg">{country.flag} {countryName(country, 'zh')}</h3>
            <span class="text-xs text-[color:var(--color-text-tertiary)]">已收录 {countrySchools.length} 所</span>
          </div>
          {country.cities.length > 0 ? (
            country.cities.map((city) => {
              const cityList = schools.filter((s) => s.data.city === city.id);
              return (
                <div id={city.id} class="mt-6 scroll-mt-24">
                  <h4 class="text-sm text-primary-900" style="font-weight:500">{cityName(city, 'zh')}</h4>
                  {cityList.length > 0 ? (
                    <div class="mt-3 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                      {cityList.map((entry) => <SchoolCard entry={entry} locale="zh" />)}
                    </div>
                  ) : (
                    <p class="mt-2 text-xs text-[color:var(--color-text-secondary)]">核实学校累积中。</p>
                  )}
                </div>
              );
            })
          ) : countrySchools.length > 0 ? (
            <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {countrySchools.map((entry) => <SchoolCard entry={entry} locale="zh" />)}
            </div>
          ) : (
            <p class="mt-3 text-xs text-[color:var(--color-text-secondary)]">核实学校累积中。</p>
          )}
        </section>
      );
    })}

    {ANGLOSPHERE.map((country) => {
      const countrySchools = schools.filter((s) => s.data.country === country.id);
      return (
        <section id={country.id} class="mt-10 scroll-mt-24">
          <div class="flex items-end justify-between border-b pb-2" style="border-color: var(--color-border-light)">
            <h3 class="text-lg">{country.flag} {countryName(country, 'zh')}</h3>
            <span class="text-xs text-[color:var(--color-text-tertiary)]">已收录 {countrySchools.length} 所</span>
          </div>
          {countrySchools.length > 0 ? (
            <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {countrySchools.map((entry) => <SchoolCard entry={entry} locale="zh" />)}
            </div>
          ) : (
            <p class="mt-3 text-xs text-[color:var(--color-text-secondary)]">升学路径分析 + 核实学校累积中。</p>
          )}
        </section>
      );
    })}

    {SCHOOL_TYPES.map((t) => (
      <section id={`type-${t.id}`} class="mt-8 scroll-mt-24">
        <h3 class="text-sm text-[color:var(--color-text-secondary)] uppercase tracking-wide">{t.zh}</h3>
        <p class="mt-1 text-xs text-[color:var(--color-text-tertiary)]">按类型筛选 — 学校数据累积后自动显示</p>
      </section>
    ))}

    <section class="mt-16 rounded-lg bg-primary-900 p-6 text-white">
      <h2 class="text-lg" style="font-weight:500">东南亚 vs 英美澳加,哪条路径适合您家?</h2>
      <p class="mt-2 text-sm opacity-90">请告知:孩子年级、英语水平、目标大学、预算。站长 1:1 答复。</p>
      <div class="mt-4">
        <a href="/zh/contact/" class="inline-flex items-center rounded-md bg-white px-4 py-2 text-sm text-primary-900" style="font-weight:500">WeChat 咨询 →</a>
      </div>
    </section>
  </section>
</BaseLayout>
