---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import Flag from '~/components/Flag.astro';
import { ANGLOSPHERE_INFO, ANGLO_KEYS } from '~/lib/anglosphere-info';

export async function getStaticPaths() {
  return ANGLO_KEYS.map((country) => ({ params: { country }, props: { country } }));
}

const { country } = Astro.props as { country: string };
const info = ANGLOSPHERE_INFO[country];

const publishedAt = new Date('2026-05-21');
const updatedAt = new Date('2026-05-21');

const title = `${info.name_zh} 寄宿学校 · 国际学校综合指南 — 学费 · 签证 · 入学考试 · 升学 | AsiaEduHub`;
const description = info.tagline_zh + ' 学费 ' + info.tuition_local + ',签证 · 入学考试 · 名校一站整理。';

const siteRoot = Astro.site?.toString() ?? '';
const flagCode = country === 'usa' ? 'US' : country === 'uk' ? 'UK' : country === 'canada' ? 'CA' : 'AU';

const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: siteRoot + 'zh/' },
    { '@type': 'ListItem', position: 2, name: '海外留学', item: siteRoot + 'zh/abroad/' },
    { '@type': 'ListItem', position: 3, name: info.name_zh },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: info.faqs.map((f) => ({
    '@type': 'Question', name: f.q_zh,
    acceptedAnswer: { '@type': 'Answer', text: f.a_zh },
  })),
};
---
<BaseLayout
  title={title} description={description}
  jsonLd={[breadcrumb, faqSchema]}
  author={{ name: 'David', url: '/zh/about/' }}
  publishedAt={publishedAt} updatedAt={updatedAt}
>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/zh/">首页</a> · <a href="/zh/abroad/">海外留学</a> · <span style="color: var(--color-text-primary)">{info.name_zh}</span>
      </nav>
      <div class="mt-4 flex flex-wrap items-center gap-2">
        <span class="badge-navy"><Flag country={flagCode as any} />英美澳加高端</span>
        <span class="badge-navy">{info.tuition_usd}</span>
      </div>
      <h1 class="mt-5 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.022em">
        {info.flag} {info.name_zh}
      </h1>
      <p class="mt-4 max-w-2xl text-base sm:text-lg text-pretty" style="color: var(--color-text-secondary); line-height: 1.7;">
        {info.tagline_zh}
      </p>
      <div class="mt-5">
        <AuthorByline locale="zh" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="各国政府官方资料,学校官网,家长社群" />
      </div>
    </div>
  </section>

  <article class="container-content py-10 max-w-3xl">
    <div class="rounded-2xl p-6 mt-2" style="background: linear-gradient(135deg, #FFFBF0 0%, #FEF9E7 100%); border: 1px solid #FCD34D">
      <div class="text-xs uppercase tracking-wider" style="color: var(--color-accent-700); font-weight: 700; letter-spacing: 0.08em">✦ 核心要点</div>
      <p class="mt-3 text-base" style="color: var(--color-accent-700); line-height: 1.7; font-weight: 500">
        {info.tagline_zh} <strong>学费 {info.tuition_local}</strong>。{info.destinations_zh}
      </p>
    </div>

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">韩中家长关注核心要点</h2>
      <ul class="mt-5 space-y-2 text-sm" style="line-height:1.75">
        {info.key_points_zh.map((p) => <li>✓ {p}</li>)}
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">教育系统概览</h2>
      <p class="mt-3 text-base" style="line-height:1.75">{info.system_zh}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">签证信息</h2>
      <div class="mt-4 rounded-xl p-5" style="background: var(--color-primary-50); border-left: 4px solid var(--color-primary-700)">
        <p class="text-sm" style="color: var(--color-primary-900); line-height:1.7; font-weight:500">{info.visa_zh}</p>
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">入学考试</h2>
      <ul class="mt-4 space-y-2 text-sm" style="line-height:1.7">
        {info.exams.map((e) => <li>• <strong>{e}</strong></li>)}
      </ul>
      <p class="mt-3 text-sm" style="color: var(--color-text-secondary); line-height:1.7">{info.timeline_zh}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">代表学校</h2>
      <p class="mt-2 text-xs text-[color:var(--color-text-tertiary)]">基于家长常搜学校整理。所有信息建议向学校官网最新核实。</p>
      <div class="mt-5 grid gap-3">
        {info.notable_schools.map((s) => (
          <div class="rounded-xl border p-4" style="border-color: var(--color-border-light)">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <div class="text-primary-900" style="font-weight:700">{s.name}</div>
              <div class="text-xs" style="color: var(--color-text-tertiary)">{s.location}</div>
            </div>
            <p class="mt-2 text-sm" style="color: var(--color-text-secondary); line-height:1.6">{s.note_zh}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">升学路径</h2>
      <p class="mt-3 text-base" style="line-height:1.75">{info.destinations_zh}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl" style="font-weight:800; letter-spacing:-0.02em">常见问题</h2>
      <div class="mt-5 space-y-3">
        {info.faqs.map((f) => (
          <details class="rounded-xl p-4" style="border:1px solid var(--color-border-light)">
            <summary class="cursor-pointer" style="font-weight:600; color: var(--color-primary-900)">{f.q_zh}</summary>
            <p class="mt-3 text-sm" style="line-height:1.7">{f.a_zh}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mt-12 card-cta">
      <h2 class="text-xl text-white" style="font-weight:500">{info.name_zh} 入学咨询</h2>
      <p class="mt-3 text-sm">告知子女年级 · 英语水平 · 预算 · 家长陪同意愿,1:1 答复。</p>
      <a href="/zh/contact/" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-3 text-primary-900" style="font-weight:500">
        WeChat 咨询
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
    </section>

    <section class="mt-10">
      <h2 class="text-xl" style="font-weight:700">相关信息</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/zh/abroad/types/boarding/" class="card text-sm block">
          <div class="text-primary-900" style="font-weight:500">寄宿学校综合</div>
        </a>
        <a href="/zh/abroad/types/ib/" class="card text-sm block">
          <div class="text-primary-900" style="font-weight:500">IB 学校指南</div>
        </a>
        <a href="/zh/abroad/" class="card text-sm block">
          <div class="text-primary-900" style="font-weight:500">海外国际学校综合</div>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>
