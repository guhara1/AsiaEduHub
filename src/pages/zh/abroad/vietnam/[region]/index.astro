---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Flag from '~/components/Flag.astro';
import { VIETNAM_SCHOOLS, VN_REGION_LABELS, type VnRegion } from '~/lib/vietnam-schools';

export async function getStaticPaths() {
  const regions: VnRegion[] = ['hanoi', 'ho-chi-minh', 'hai-phong', 'da-nang'];
  return regions.map((region) => ({ params: { region }, props: { region } }));
}

const { region } = Astro.props as { region: VnRegion };
const regionLabel = VN_REGION_LABELS[region];
const schools = VIETNAM_SCHOOLS.filter((s) => s.region === region);

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const title = `越南 ${regionLabel.zh} 国际学校 ${schools.length} 所 — 学费 · 课程 | AsiaEduHub`;
const description = `${regionLabel.zh} 地区国际学校 ${schools.length} 所。${schools.slice(0, 3).map(s => s.name_zh).join(' · ')} 等。`;

const siteRoot = Astro.site?.toString() ?? '';
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: siteRoot + 'zh/' },
    { '@type': 'ListItem', position: 2, name: '海外留学', item: siteRoot + 'zh/abroad/' },
    { '@type': 'ListItem', position: 3, name: '越南', item: siteRoot + 'zh/abroad/vietnam/' },
    { '@type': 'ListItem', position: 4, name: regionLabel.zh },
  ],
};
const itemList = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: `越南 ${regionLabel.zh} 国际学校`, numberOfItems: schools.length,
  itemListElement: schools.map((s, i) => ({
    '@type': 'ListItem', position: i + 1, name: s.name_zh,
    url: siteRoot + `zh/abroad/vietnam/${s.region}/${s.slug}/`,
  })),
};
---
<BaseLayout
  title={title} description={description}
  jsonLd={[breadcrumb, itemList]}
  author={{ name: 'David', url: '/zh/about/' }}
  publishedAt={publishedAt} updatedAt={updatedAt}
>
  <section class="hero-gradient">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)">
        <a href="/zh/abroad/">海外留学</a> · <a href="/zh/abroad/vietnam/"><Flag country="VN" />越南</a> · <span style="color: var(--color-text-primary)">{regionLabel.zh}</span>
      </nav>
      <h1 class="mt-4 text-3xl sm:text-4xl lg:text-5xl text-balance" style="font-weight:800; letter-spacing:-0.02em">
        🇻🇳 {regionLabel.zh} 国际学校 {schools.length} 所
      </h1>
      <p class="mt-3 max-w-2xl text-base" style="color: var(--color-text-secondary); line-height: 1.7;">
        {regionLabel.zh} 地区国际学校详情 — 课程 · 学费 · 位置。
      </p>
    </div>
  </section>

  <article class="container-content py-10 max-w-4xl">
    <div class="grid gap-3 sm:grid-cols-2">
      {schools.map((s) => (
        <a href={`/zh/abroad/vietnam/${s.region}/${s.slug}/`} class="card text-sm block">
          <div class="text-primary-900" style="font-weight:600">{s.name_zh}</div>
          <div class="mt-1 text-xs" style="color: var(--color-text-secondary)">{s.name_en}{s.abbreviation ? ` · ${s.abbreviation}` : ''}</div>
          <p class="mt-2 text-xs" style="color: var(--color-text-secondary); line-height:1.55">{s.summary_zh}</p>
          <div class="mt-3 flex flex-wrap gap-1">
            <span class="badge-outlined">{s.curriculum.type}</span>
            {s.boarding && <span class="badge-navy">寄宿</span>}
            {s.founded_year && <span class="badge-outlined">{s.founded_year}</span>}
          </div>
          <div class="mt-2 text-xs" style="color: var(--color-text-tertiary)">
            年 ${s.tuition_range_usd[0].toLocaleString()}~${s.tuition_range_usd[1].toLocaleString()}
          </div>
        </a>
      ))}
    </div>

    <section class="mt-12 card-cta">
      <h2 class="text-xl text-white" style="font-weight:500">{regionLabel.zh} 学校咨询</h2>
      <p class="mt-3 text-sm opacity-95">告知孩子年级 · 英语水平 · 预算,1:1 答复。</p>
      <a href="/zh/contact/" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-3 text-primary-900" style="font-weight:500">
        WeChat 咨询
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
    </section>
  </article>
</BaseLayout>
