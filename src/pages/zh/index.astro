---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getMessages } from '~/lib/i18n';
import { getCollection } from 'astro:content';
import { formatDate } from '~/lib/schools';

const t = getMessages('zh');

const title = `${t.site.name} — ${t.site.tagline}`;
const description =
  '居住马来西亚的家长 David 独立运营。韩国外国人学校 · 济州国际学校 · 东南亚 · 英美澳加学校信息,MM2H 签证,学费计算器,升学路径模拟器等家长真正需要的信息整理。';

const websiteSchema = {
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: t.site.name, url: Astro.site?.toString(), inLanguage: 'zh-CN',
};
const orgSchema = {
  '@context': 'https://schema.org', '@type': 'Organization',
  name: 'AsiaEduHub', url: Astro.site?.toString(),
  logo: (Astro.site?.toString() ?? '') + 'favicon.svg',
  founder: { '@type': 'Person', name: 'David', url: (Astro.site?.toString() ?? '') + 'zh/about/' },
};

const recentGuides = (await getCollection('guides', (e) => e.data.locale === 'zh'))
  .sort((a, b) => b.data.last_updated.getTime() - a.data.last_updated.getTime())
  .slice(0, 3);
const recentExperts = (await getCollection('experts', (e) => e.data.locale === 'zh'))
  .sort((a, b) => b.data.published_at.getTime() - a.data.published_at.getTime())
  .slice(0, 2);

const heroCards = [
  { href: '/zh/domestic/', title: '外国人学校 vs 国际学校的区别', desc: '法律资格 · 学历认定 · 学费差异。SFS · YISS · NLCS · BHA · Chadwick 松岛等主要学校整理。', icon: 'M3 21h18M3 10l9-7 9 7M5 21V10m14 11V10M9 21v-6h6v6', tone: 'primary' },
  { href: '/zh/abroad/malaysia/', title: '马来西亚国际学校 22 所', desc: 'Alice Smith · ISKL · MKIS · GIS · Epsom · Nexus · UCSI 等吉隆坡 · 雪兰莪 · 布城全部学校。', icon: 'M12 3l9 4.5v9L12 21l-9-4.5v-9L12 3zm0 0v18M3 7.5l9 4.5 9-4.5', tone: 'primary' },
  { href: '/zh/mm2h/', title: 'MM2H · Thailand · Singapore 签证对比', desc: '含 2024 MM2H 修订。5 种家长签证按资格 · 费用 · 子女教育影响对比。', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', tone: 'primary' },
  { href: '/zh/abroad/', title: '东南亚性价比 vs 英美澳加高端', desc: '学费差 1/3~1/2。东南亚 IB 路径可升入牛剑 · 常春藤。', icon: 'M3 12h18M3 12l4-4M3 12l4 4M21 12l-4-4M21 12l-4 4', tone: 'primary' },
  { href: '/zh/tools/compare/#track-simulator', title: '升学路径模拟器', desc: '输入孩子年级 · 目标大学 · 预算 → 各阶段步骤 · 考试 · 总成本自动计算。', icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z', tone: 'accent', badge: '⭐ 核心工具' },
  { href: '/zh/experts/', title: '专家专栏', desc: '现职教师 · 招生官 · 留学顾问访谈,站长核实身份。', icon: 'M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-3.13a4 4 0 11-8 0 4 4 0 018 0zm6 0a4 4 0 11-8 0 4 4 0 018 0z', tone: 'primary' },
];

const personaCards = [
  { grade: '幼儿园 ~ G3', label: '低年级', color: 'sky', title: '环境 · 设施 · 餐饮 · 比例', emoji: '🧒',
    links: [
      { label: '马来西亚性价比学校', href: '/zh/abroad/malaysia/' },
      { label: '英语幼儿园', href: '/zh/domestic/#kindergarten' },
      { label: '入学考试 · 面试准备', href: '/zh/guide/#admission' },
    ] },
  { grade: 'G4 ~ G8', label: '中年级', color: 'amber', title: '学业环境 + 课程过渡', emoji: '🎒',
    links: [
      { label: 'IB · A-Level · AP 对比', href: '/zh/guide/ib-vs-alevel-vs-ap/' },
      { label: '东南亚 IB 学校', href: '/zh/abroad/' },
      { label: '学费计算器', href: '/zh/tools/compare/#calculator' },
    ] },
  { grade: 'G9 ~ G12', label: '高年级', color: 'rose', title: '考试结果 + 大学申请', emoji: '🎓',
    links: [
      { label: '升学路径模拟器', href: '/zh/tools/compare/#track-simulator' },
      { label: '牛剑 · 常春藤录取案例', href: '/zh/guide/#track-reviews' },
      { label: '英美澳加寄宿学校', href: '/zh/abroad/#usa' },
    ] },
];

const budgetCards = [
  { href: '/zh/tools/budget/budget-friendly/', title: '高性价比', sub: '< 1 万美元/年', color: 'emerald' },
  { href: '/zh/tools/budget/mid-range/', title: '中等预算', sub: '1 万~2 万', color: 'sky' },
  { href: '/zh/tools/budget/premium/', title: '高端', sub: '2 万~3.5 万', color: 'violet' },
  { href: '/zh/tools/budget/top-tier/', title: '顶级', sub: '3.5 万+', color: 'rose' },
];

const operatorFacts = [
  { num: '2024', label: '韩国 → 吉隆坡' },
  { num: '2', label: '两个孩子,UCSI 在读' },
  { num: '2 次', label: '转校 — 一手经验', highlight: true },
  { num: '3', label: '韩语 · 中文 · 英语' },
  { num: '12+', label: '在线营销年数' },
  { num: 'KL', label: '吉隆坡本地居住' },
];
---
<BaseLayout title={title} description={description} jsonLd={[websiteSchema, orgSchema]}>
  <section class="hero-gradient relative overflow-hidden">
    <div aria-hidden="true" class="absolute -right-32 -top-32 h-96 w-96 rounded-full" style="background: radial-gradient(circle, rgba(245,158,11,0.10) 0%, transparent 70%); filter: blur(40px);"></div>
    <div aria-hidden="true" class="absolute -left-32 bottom-0 h-96 w-96 rounded-full" style="background: radial-gradient(circle, rgba(59,130,246,0.10) 0%, transparent 70%); filter: blur(40px);"></div>

    <div class="container-content section-xl">
      <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr] lg:items-center">
        <div>
          <span class="badge-gold mb-6 inline-flex">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.8 6.6L22 10l-5.5 4.8 1.7 7.2L12 18l-6.2 4 1.7-7.2L2 10l7.2-1.4z"/></svg>
            {t.badges.two_school_switches}
          </span>
          <h1 class="text-balance" style="font-size: clamp(2.25rem, 4vw + 0.5rem, 3.75rem); line-height: 1.08; letter-spacing: -0.032em; font-weight: 600;">
            <span style="color: var(--color-text-primary)">韩国外国人学校·济州国际学校,</span><br />
            <span class="text-gradient-accent" style="position: relative; display: inline-block;">东南亚留学</span><span style="color: var(--color-text-primary)">的真实信息</span>
          </h1>
          <p class="mt-7 max-w-xl text-pretty" style="color: var(--color-text-secondary); font-size: 1.0625rem; line-height: 1.7;">
            站长 <strong style="color: var(--color-primary-900); font-weight: 600;">David</strong> 是居住马来西亚的韩国家长。
            两个孩子,两次转校的亲身经验,从家长视角核实整理学费、签证、课程、升学路径。
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a href="/zh/abroad/malaysia/" class="cta-primary" style="padding: 0.875rem 1.5rem; font-size: 0.9375rem;">
              <span aria-hidden="true" style="font-family: 'Apple Color Emoji','Segoe UI Emoji','Noto Color Emoji', emoji;">🇲🇾</span>
              马来西亚国际学校 22 所
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
            </a>
            <a href="/zh/domestic/" class="cta-secondary" style="padding: 0.875rem 1.5rem; font-size: 0.9375rem;">
              韩国国际学校
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
            </a>
          </div>

          <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-xs" style="color: var(--color-text-tertiary)">
            <li class="inline-flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              不使用 AI 自动生成
            </li>
            <li class="inline-flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              标注来源与更新日期
            </li>
            <li class="inline-flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              站长第一手经验
            </li>
          </ul>
        </div>

        <aside class="relative">
          <div class="rounded-3xl bg-white p-7 lg:p-8" style="border: 1px solid var(--color-border-light); box-shadow: var(--shadow-xl); position: relative; overflow: hidden;">
            <div aria-hidden="true" class="absolute -right-6 -top-6 h-24 w-24 rounded-full" style="background: linear-gradient(135deg, rgba(245,158,11,0.16) 0%, transparent 70%);"></div>

            <div class="flex items-center gap-4">
              <span aria-hidden="true" class="inline-flex h-16 w-16 items-center justify-center rounded-2xl text-white text-2xl" style="background: linear-gradient(135deg, var(--color-primary-900) 0%, var(--color-primary-700) 100%); box-shadow: var(--shadow-md); font-weight: 600;">D</span>
              <div>
                <div class="text-xl text-primary-900" style="font-weight: 600; letter-spacing: -0.01em;">David</div>
                <div class="mt-0.5 text-xs" style="color: var(--color-text-tertiary)">吉隆坡 · 两次转校的家长</div>
              </div>
            </div>

            <div class="mt-6 rounded-2xl p-5" style="background: linear-gradient(135deg, var(--color-accent-100) 0%, var(--color-accent-50) 100%); border: 1px solid rgba(245,158,11,0.30);">
              <div class="flex items-baseline gap-2">
                <span class="text-4xl" style="color: var(--color-accent-700); font-weight: 700; letter-spacing: -0.03em;">2 次</span>
                <span class="text-xs" style="color: var(--color-accent-700); font-weight: 500;">⭐ 本站核心差异</span>
              </div>
              <div class="mt-2 text-sm" style="color: var(--color-accent-700); font-weight: 500;">转校 — 一手经验</div>
              <p class="mt-2 text-[11px]" style="color: var(--color-accent-700); opacity: 0.8;">学费上涨 + 韩国学生骤增的真实经历</p>
            </div>

            <div class="mt-4 grid grid-cols-2 gap-2.5">
              <div class="rounded-xl p-3" style="background: var(--color-bg-soft);">
                <div class="text-base text-primary-900" style="font-weight: 600;">2024</div>
                <div class="mt-0.5 text-[10px]" style="color: var(--color-text-tertiary)">韩国 → 吉隆坡</div>
              </div>
              <div class="rounded-xl p-3" style="background: var(--color-bg-soft);">
                <div class="text-base text-primary-900" style="font-weight: 600;">UCSI</div>
                <div class="mt-0.5 text-[10px]" style="color: var(--color-text-tertiary)">两个孩子在读</div>
              </div>
              <div class="rounded-xl p-3" style="background: var(--color-bg-soft);">
                <div class="text-base text-primary-900" style="font-weight: 600;">韩·中·英</div>
                <div class="mt-0.5 text-[10px]" style="color: var(--color-text-tertiary)">三语</div>
              </div>
              <div class="rounded-xl p-3" style="background: var(--color-bg-soft);">
                <div class="text-base text-primary-900" style="font-weight: 600;">12 年+</div>
                <div class="mt-0.5 text-[10px]" style="color: var(--color-text-tertiary)">在线营销</div>
              </div>
            </div>

            <a href="/zh/about/" class="mt-5 inline-flex items-center gap-1.5 text-sm" style="color: var(--color-primary-700); font-weight: 500;">
              站长简介详情
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="container-content section-md">
    <div class="mb-8" data-reveal>
      <h2 class="text-2xl sm:text-3xl">家长最常问的主题</h2>
      <p class="mt-2 text-sm" style="color: var(--color-text-secondary)">信息 · 工具 · 专家访谈按分类持续累积的信息中心</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {heroCards.map((c) => (
        <a href={c.href} class:list={[c.tone === 'accent' ? 'card-feature' : 'card-info', 'group block']}>
          <div class="flex items-start gap-3">
            <div class:list={[c.tone === 'accent' ? 'icon-circle-accent' : 'icon-circle']}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d={c.icon} stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              {c.badge && <span class="badge-gold mb-2 text-[10px]">{c.badge}</span>}
              <h3 class="text-base sm:text-lg leading-snug">{c.title}</h3>
              <p class="mt-2 text-sm" style="color: var(--color-text-secondary); line-height: 1.6;">{c.desc}</p>
            </div>
          </div>
          <div class="mt-4 inline-flex items-center gap-1 text-xs text-primary-700 transition-transform group-hover:translate-x-1" style="font-weight:500">
            查看详情
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="container-content section-md">
    <div class="mb-8" data-reveal>
      <h2 class="text-2xl sm:text-3xl">按孩子年级找起点</h2>
      <p class="mt-2 text-sm" style="color: var(--color-text-secondary)">各年级家长关注重点不同</p>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {personaCards.map((p) => (
        <div class="card flex flex-col">
          <div class="flex items-start justify-between">
            <span class="text-4xl" aria-hidden="true">{p.emoji}</span>
            <span class:list={[
              'rounded-full px-3 py-1 text-xs',
              p.color === 'sky' && 'bg-sky-100 text-sky-700',
              p.color === 'amber' && 'bg-amber-100 text-amber-700',
              p.color === 'rose' && 'bg-rose-100 text-rose-700',
            ]} style="font-weight:500">{p.label}</span>
          </div>
          <div class="mt-3 text-xs uppercase tracking-wide" style="color: var(--color-text-tertiary)">{p.grade}</div>
          <h3 class="mt-1 text-base">{p.title}</h3>
          <ul class="mt-4 space-y-2 text-sm">
            {p.links.map((l) => (
              <li>
                <a href={l.href} class="inline-flex items-center gap-1 hover:underline" style="color: var(--color-text-primary)">
                  <span class="text-primary-700">▸</span> {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="container-content section-md">
    <div class="mb-8" data-reveal>
      <h2 class="text-2xl sm:text-3xl">按预算推荐学校</h2>
      <p class="mt-2 text-sm" style="color: var(--color-text-secondary)">年学费 + 附加费用综合</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {budgetCards.map((b) => (
        <a href={b.href} class="card group flex flex-col">
          <div class:list={[
            'inline-flex h-10 w-10 items-center justify-center rounded-lg',
            b.color === 'emerald' && 'bg-emerald-100 text-emerald-700',
            b.color === 'sky' && 'bg-sky-100 text-sky-700',
            b.color === 'violet' && 'bg-violet-100 text-violet-700',
            b.color === 'rose' && 'bg-rose-100 text-rose-700',
          ]}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 6v12m-3-9h6m-6 6h6M5 6a2 2 0 012-2h10a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
          </div>
          <div class="mt-4 text-lg text-primary-900" style="font-weight:500">{b.title}</div>
          <div class="mt-1 text-sm" style="color: var(--color-text-secondary)">{b.sub}</div>
          <div class="mt-3 text-xs text-primary-700 transition-transform group-hover:translate-x-1" style="font-weight:500">
            查看学校 →
          </div>
        </a>
      ))}
    </div>
  </section>

  {(recentGuides.length > 0 || recentExperts.length > 0) && (
    <section class="container-content section-md">
      <div class="mb-8" data-reveal>
        <h2 class="text-2xl sm:text-3xl">最近发布 · 更新</h2>
        <p class="mt-2 text-sm" style="color: var(--color-text-secondary)">站长审核后发布的指南与专家访谈</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {recentGuides.map((g) => (
          <a href={`/zh/guide/${g.slug.replace(/-zh$/, '')}/`} class="card group">
            <div class="badge-navy text-[10px]">📘 指南</div>
            <h3 class="mt-3 text-base leading-snug">{g.data.title}</h3>
            <p class="mt-2 text-sm" style="color: var(--color-text-secondary); line-height: 1.6;">{g.data.summary}</p>
            <p class="mt-3 text-xs" style="color: var(--color-text-tertiary)">{formatDate(g.data.last_updated, 'zh')}</p>
          </a>
        ))}
        {recentExperts.map((e) => (
          <a href={`/zh/experts/${e.slug.replace(/-zh$/, '')}/`} class="card group">
            <div class="flex flex-wrap items-center gap-1">
              <span class="badge-gold text-[10px]">🎤 专家专栏</span>
              {e.data.expert.verified && <span class="badge-gold text-[10px]">⭐ 已核实</span>}
            </div>
            <h3 class="mt-3 text-base leading-snug">{e.data.title}</h3>
            <p class="mt-2 text-sm" style="color: var(--color-text-secondary); line-height: 1.6;">{e.data.summary}</p>
            <p class="mt-3 text-xs" style="color: var(--color-text-tertiary)">{e.data.expert.affiliation}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="container-content section-md">
    <div class="card-cta">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <h2 class="text-2xl sm:text-3xl text-white">为什么选 AsiaEduHub</h2>
          <p class="mt-3 text-sm opacity-90 max-w-2xl">
            遵守 Google 2026 政策(E-E-A-T · Helpful Content · Who/How/Why)的家长信息网站。
          </p>
          <div class="mt-6 grid gap-4 sm:grid-cols-3 text-sm">
            <div>
              <div class="text-xs uppercase tracking-wide opacity-80">第一手经验(E-E-A-T)</div>
              <p class="mt-1 opacity-95">站长本人:韩国 → 马来西亚移居,两次转校,亲自申请 MM2H。</p>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wide opacity-80">来源 · 核实</div>
              <p class="mt-1 opacity-95">所有数据标注来源 + 最后更新日期。每季度复核。</p>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wide opacity-80">广告与内容分离</div>
              <p class="mt-1 opacity-95">广告内容标注 SPONSORED。<a href="/zh/editorial-policy/" class="underline text-white">编辑原则</a>公开。</p>
            </div>
          </div>
        </div>
        <div class="md:text-right">
          <a href="/zh/contact/" class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-primary-900" style="font-weight:500; box-shadow: var(--shadow-md)">
            1:1 咨询
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
