---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getMessages } from '~/lib/i18n';
import { getCollection } from 'astro:content';
import { formatDate } from '~/lib/schools';

const t = getMessages('zh');

const title = `${t.site.name} — ${t.site.tagline}`;
const description =
  '居住马来西亚的家长 David 独立运营。韩国外国人学校·济州国际学校·东南亚·英美澳加学校信息,MM2H 签证,学费计算器,升学路径模拟器等家长真正需要的信息整理。';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: t.site.name,
  url: Astro.site?.toString(),
  inLanguage: 'zh-CN',
};
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'AsiaEduHub',
  url: Astro.site?.toString(),
  logo: (Astro.site?.toString() ?? '') + 'favicon.svg',
  founder: { '@type': 'Person', name: 'David', url: (Astro.site?.toString() ?? '') + 'zh/about/' },
};

const recentGuides = (await getCollection('guides', (e) => e.data.locale === 'zh'))
  .sort((a, b) => b.data.last_updated.getTime() - a.data.last_updated.getTime())
  .slice(0, 3);
const recentExperts = (await getCollection('experts', (e) => e.data.locale === 'zh'))
  .sort((a, b) => b.data.published_at.getTime() - a.data.published_at.getTime())
  .slice(0, 2);
---
<BaseLayout title={title} description={description} jsonLd={[websiteSchema, orgSchema]}>
  <section class="container-content py-12 sm:py-16">
    <div class="grid gap-10 lg:grid-cols-[1.6fr_1fr] lg:items-start">
      <div>
        <p class="badge-gold mb-3">{t.badges.two_school_switches}</p>
        <h1 class="text-3xl sm:text-5xl">
          韩国外国人学校 · 济州国际学校 · 东南亚留学,<br />
          真实家长整理的真实信息
        </h1>
        <p class="mt-6 max-w-2xl text-base text-[color:var(--color-text-secondary)]">
          站长 David 是居住马来西亚的韩国家长。两个孩子,两次转校的亲身经验,
          从家长视角核实整理学费、签证、课程、升学路径。本站不使用 AI 自动生成正文。
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/zh/abroad/" class="cta-primary">海外留学对比 →</a>
          <a href="/zh/domestic/" class="cta-secondary">韩国国际学校 →</a>
        </div>
      </div>

      <aside class="rounded-lg border p-5" style="border-color: var(--color-border-light); background: var(--color-bg-secondary)">
        <div class="flex items-center gap-3">
          <span aria-hidden="true" class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary-900 text-white text-lg">D</span>
          <div>
            <div class="text-primary-900" style="font-weight:500">David</div>
            <div class="text-xs text-[color:var(--color-text-tertiary)]">居住吉隆坡 · 两次转校的家长</div>
          </div>
        </div>
        <ul class="mt-4 space-y-1 text-xs text-[color:var(--color-text-secondary)]">
          <li>• 2024 年从韩国移居吉隆坡</li>
          <li>• 两个孩子,就读 UCSI 国际学校</li>
          <li>• 两次转校(学费 + 韩国学生比例骤增)</li>
          <li>• 韩语 · 中文(北京经历)· 英语</li>
          <li>• 在线营销 12 年+ 经验</li>
        </ul>
        <a href="/zh/about/" class="mt-4 inline-block text-xs text-primary-700 hover:underline">站长简介 →</a>
      </aside>
    </div>
  </section>

  <section class="container-content pb-4">
    <h2 class="text-xl">家长最常问的主题</h2>
    <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/zh/domestic/" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">外国人学校 vs 国际学校的区别</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">法律资格 · 学历认定 · 学费差异。SFS · YISS · NLCS · BHA 等主要学校整理。</p>
      </a>
      <a href="/zh/mm2h/" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">MM2H · Thailand · Singapore 签证对比</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">含 2024 MM2H 修订。5 种家长签证按资格 · 费用 · 子女教育影响对比。</p>
      </a>
      <a href="/zh/abroad/" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">东南亚性价比 vs 英美澳加高端</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">学费差 1/3~1/2。东南亚 IB 路径可升入牛剑 · 常春藤。</p>
      </a>
      <a href="/zh/tools/compare/#track-simulator" class="block rounded-lg border p-5 bg-accent-100 hover:border-accent-500" style="border-color: var(--color-accent-500)">
        <div class="flex items-center gap-2">
          <h3 class="text-base text-accent-700" style="font-weight:500">升学路径模拟器</h3>
          <span class="badge-gold text-[10px]">⭐ 核心工具</span>
        </div>
        <p class="mt-2 text-sm text-accent-700">输入孩子年级 · 目标大学 · 预算 → 各阶段步骤 · 考试 · 总成本自动计算。</p>
      </a>
      <a href="/zh/tools/compare/#calculator" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">学费计算器</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">学费 + 杂费 + 寄宿 + 机票 + 汇率 + 通胀。韩元 · 人民币换算。</p>
      </a>
      <a href="/zh/experts/" class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
        <h3 class="text-base text-primary-900" style="font-weight:500">专家专栏</h3>
        <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">现职教师 · 招生官 · 留学顾问访谈,站长核实身份。</p>
      </a>
    </div>
  </section>

  <section class="container-content py-12">
    <h2 class="text-xl">按孩子年级找起点</h2>
    <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">各年级家长关注重点不同。</p>
    <div class="mt-5 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
        <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">幼儿园 ~ G3(低年级)</div>
        <h3 class="mt-1 text-base" style="font-weight:500">环境 · 设施 · 餐饮 · 比例</h3>
        <ul class="mt-3 space-y-1 text-sm text-[color:var(--color-text-secondary)]">
          <li>• <a href="/zh/abroad/#malaysia" class="hover:text-primary-700">马来西亚性价比学校</a></li>
          <li>• <a href="/zh/domestic/#kindergarten" class="hover:text-primary-700">英语幼儿园</a></li>
          <li>• <a href="/zh/guide/#admission" class="hover:text-primary-700">入学考试 · 面试准备</a></li>
        </ul>
      </div>
      <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
        <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">G4 ~ G8(中年级)</div>
        <h3 class="mt-1 text-base" style="font-weight:500">学业环境 + 课程过渡</h3>
        <ul class="mt-3 space-y-1 text-sm text-[color:var(--color-text-secondary)]">
          <li>• <a href="/zh/guide/#curriculum-compare" class="hover:text-primary-700">IB · A-Level · AP 对比</a></li>
          <li>• <a href="/zh/abroad/" class="hover:text-primary-700">东南亚 IB 学校</a></li>
          <li>• <a href="/zh/tools/compare/#calculator" class="hover:text-primary-700">学费计算器</a></li>
        </ul>
      </div>
      <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
        <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">G9 ~ G12(高年级)</div>
        <h3 class="mt-1 text-base" style="font-weight:500">考试结果 + 大学申请</h3>
        <ul class="mt-3 space-y-1 text-sm text-[color:var(--color-text-secondary)]">
          <li>• <a href="/zh/tools/compare/#track-simulator" class="hover:text-primary-700">升学路径模拟器</a></li>
          <li>• <a href="/zh/guide/#track-reviews" class="hover:text-primary-700">牛剑 · 常春藤录取案例</a></li>
          <li>• <a href="/zh/abroad/#usa" class="hover:text-primary-700">英美澳加寄宿学校</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="container-content pb-4">
    <h2 class="text-xl">按预算推荐学校</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { href: '/zh/tools/budget/budget-friendly/', title: '高性价比', sub: '< 1 万美元/年' },
        { href: '/zh/tools/budget/mid-range/', title: '中等预算', sub: '1 万~2 万' },
        { href: '/zh/tools/budget/premium/', title: '高端', sub: '2 万~3.5 万' },
        { href: '/zh/tools/budget/top-tier/', title: '顶级', sub: '3.5 万+' },
      ].map((b) => (
        <a href={b.href} class="rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
          <div class="text-lg text-primary-900" style="font-weight:500">{b.title}</div>
          <div class="mt-1 text-sm text-[color:var(--color-text-secondary)]">{b.sub}</div>
        </a>
      ))}
    </div>
  </section>

  {(recentGuides.length > 0 || recentExperts.length > 0) && (
    <section class="container-content py-12">
      <h2 class="text-xl">最近发布 / 更新</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {recentGuides.map((g) => (
          <a href={`/zh/guide/${g.slug.replace(/-zh$/, '')}/`} class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
            <div class="text-xs text-[color:var(--color-text-tertiary)]">指南</div>
            <div class="mt-1 text-base text-primary-900" style="font-weight:500">{g.data.title}</div>
            <p class="mt-2 text-xs text-[color:var(--color-text-secondary)]">{g.data.summary}</p>
            <p class="mt-2 text-xs text-[color:var(--color-text-tertiary)]">{formatDate(g.data.last_updated, 'zh')}</p>
          </a>
        ))}
        {recentExperts.map((e) => (
          <a href={`/zh/experts/${e.slug.replace(/-zh$/, '')}/`} class="block rounded-lg border p-5 hover:border-primary-700" style="border-color: var(--color-border-light)">
            <div class="flex items-center gap-1">
              <span class="text-xs text-[color:var(--color-text-tertiary)]">专家专栏</span>
              {e.data.expert.verified && <span class="badge-gold text-[10px]">⭐ 已核实</span>}
            </div>
            <div class="mt-1 text-base text-primary-900" style="font-weight:500">{e.data.title}</div>
            <p class="mt-2 text-xs text-[color:var(--color-text-secondary)]">{e.data.summary}</p>
            <p class="mt-2 text-xs text-[color:var(--color-text-tertiary)]">{e.data.expert.affiliation}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="container-content pb-16">
    <div class="rounded-lg border p-5" style="border-color: var(--color-border-light); background: var(--color-bg-secondary)">
      <h2 class="text-lg" style="font-weight:500">为什么选择 AsiaEduHub</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-3 text-sm">
        <div>
          <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">第一手经验(E-E-A-T)</div>
          <p class="mt-1">站长本人:韩国 → 马来西亚移居,两次转校,亲自申请 MM2H。</p>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">来源 · 核实</div>
          <p class="mt-1">所有数据均标注来源 + 最后更新日期。每季度复核。</p>
        </div>
        <div>
          <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">广告与内容分离</div>
          <p class="mt-1">广告标注 SPONSORED。<a href="/zh/editorial-policy/" class="text-primary-700 hover:underline">编辑原则</a>公开。</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
