---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AuthorByline from '~/components/AuthorByline.astro';
import { VISA_PROGRAMS, MM2H_FAQS } from '~/lib/mm2h-info';

const title = '东南亚长期居留签证完整对比 — MM2H · Thailand Privilege · LTR · Singapore EP · PR | AsiaEduHub';
const description =
  '马来西亚 MM2H、泰国 Thailand Privilege · LTR、新加坡 EP · PR 在资格·费用·期限·子女教育上的对比。涵盖 2024 MM2H 修订。家长常见问题。';

const publishedAt = new Date('2026-05-20');
const updatedAt = new Date('2026-05-20');

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + 'zh/' },
    { '@type': 'ListItem', position: 2, name: 'MM2H · 移居' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: MM2H_FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q_zh,
    acceptedAnswer: { '@type': 'Answer', text: f.a_zh },
  })),
};

// HowTo schema — 马来西亚 MM2H 申请 7 步
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '马来西亚 MM2H 签证申请 7 步',
  description: '依据 2024 修订申请马来西亚 MM2H(My Second Home)签证的 7 步流程。',
  totalTime: 'P9M',
  estimatedCost: { '@type': 'MonetaryAmount', currency: 'MYR', value: '520000' },
  step: [
    { '@type': 'HowToStep', position: 1, name: '资格预评', text: '中介或本人自查资格,整理可定存金额、收入证明、随行人数。1~2 周。' },
    { '@type': 'HowToStep', position: 2, name: '选定中介', text: '政府持牌中介对比后选定,费用 RM 15,000~40,000。' },
    { '@type': 'HowToStep', position: 3, name: '准备文件', text: '护照、银行流水、收入、无犯罪、体检、海牙认证等文件 4~8 周准备。' },
    { '@type': 'HowToStep', position: 4, name: '提交申请', text: '中介向 MM2H 办公室提交,获受理编号。' },
    { '@type': 'HowToStep', position: 5, name: '政府审核', text: '身份·财务·健康审核,3~6 个月。可能要求补件。' },
    { '@type': 'HowToStep', position: 6, name: '有条件批准', text: '批准信发放后开立定存账户、购买医疗保险、马来西亚指定医院体检。' },
    { '@type': 'HowToStep', position: 7, name: '签证发放与入境', text: '所有条件完成后正式签证发放,5 年居留开始。' },
  ],
};
---
<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumb, faqSchema, howToSchema]}
  author={{ name: 'David', url: '/zh/about/' }}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <section class="hero-gradient border-b" style="border-color: var(--color-border-light)">
    <div class="container-content py-10 sm:py-12">
      <nav class="text-sm" style="color: var(--color-text-secondary)"><a href="/zh/">首页</a> · MM2H · 移居</nav>
      <h1 class="mt-3 text-3xl sm:text-4xl text-balance">东南亚长期居留签证 — <span class="text-accent-700">MM2H · 泰国 · 新加坡</span> 全面对比</h1>
      <p class="mt-4 max-w-2xl text-base text-pretty" style="color: var(--color-text-secondary); line-height: 1.65;">
        为子女国际学校教育而考虑东南亚长期签证的家长指南。
        马来西亚 MM2H(2024 修订)、泰国 Thailand Privilege · LTR、新加坡 EP · PR 的资格·费用·期限·子女教育影响一页通览。
      </p>
      <div class="mt-5">
        <AuthorByline locale="zh" publishedAt={publishedAt} updatedAt={updatedAt}
          sources="马来西亚 MM2H 部门、Thailand Privilege Card Co.、Thailand BOI、Singapore MOM·ICA 官方资料" />
      </div>
    </div>
  </section>

  <section class="container-content py-10">

    <section class="mt-8 rounded-lg border bg-[color:var(--color-bg-secondary)] p-5 overflow-x-auto" style="border-color: var(--color-border-light)">
      <h2 class="text-lg" style="font-weight:500">一览对比</h2>
      <table class="mt-4 w-full text-sm min-w-[700px]">
        <thead>
          <tr class="border-b" style="border-color: var(--color-border-light)">
            <th class="py-2 text-left" style="font-weight:500">签证</th>
            <th class="py-2 text-left" style="font-weight:500">国家</th>
            <th class="py-2 text-left" style="font-weight:500">期限</th>
            <th class="py-2 text-left" style="font-weight:500">核心资格</th>
            <th class="py-2 text-left" style="font-weight:500">费用(摘要)</th>
          </tr>
        </thead>
        <tbody class="text-[color:var(--color-text-secondary)]">
          {VISA_PROGRAMS.map((v) => (
            <tr class="border-b align-top" style="border-color: var(--color-border-light)">
              <td class="py-3 text-[color:var(--color-text-primary)]" style="font-weight:500"><a href={`#${v.id}`} class="hover:text-primary-700">{v.zh.name}</a></td>
              <td class="py-3">{v.country === 'malaysia' ? '🇲🇾 马来西亚' : v.country === 'thailand' ? '🇹🇭 泰国' : '🇸🇬 新加坡'}</td>
              <td class="py-3">{v.zh.duration}</td>
              <td class="py-3">{v.zh.eligibility[0]}</td>
              <td class="py-3">{v.zh.cost}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="mt-3 text-xs text-[color:var(--color-text-tertiary)]">
        ※ 准确资格与金额请前往各签证章节的官方网站确认,政策频繁修订。
      </p>
    </section>

    {VISA_PROGRAMS.map((v) => (
      <section id={v.id} class="mt-12 scroll-mt-24">
        <div class="flex flex-wrap items-baseline gap-2">
          <h2 class="text-xl">{v.zh.full_name}</h2>
          <span class="text-xs text-[color:var(--color-text-tertiary)]">
            {v.country === 'malaysia' ? '🇲🇾' : v.country === 'thailand' ? '🇹🇭' : '🇸🇬'}
          </span>
        </div>
        <p class="mt-1 text-xs text-[color:var(--color-text-tertiary)]">依据:{v.zh.legal_basis}</p>

        <div class="mt-5 grid gap-5 sm:grid-cols-2">
          <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
            <h3 class="text-sm uppercase tracking-wide text-[color:var(--color-text-tertiary)]">资格</h3>
            <ul class="mt-3 space-y-2 text-sm">
              {v.zh.eligibility.map((e) => <li>• {e}</li>)}
            </ul>
          </div>
          <div class="rounded-lg border p-5" style="border-color: var(--color-border-light)">
            <h3 class="text-sm uppercase tracking-wide text-[color:var(--color-text-tertiary)]">费用 · 期限</h3>
            <dl class="mt-3 space-y-3 text-sm">
              <div>
                <dt class="text-[color:var(--color-text-secondary)]">费用</dt>
                <dd style="font-weight:500">{v.zh.cost}</dd>
              </div>
              <div>
                <dt class="text-[color:var(--color-text-secondary)]">期限</dt>
                <dd style="font-weight:500">{v.zh.duration}</dd>
              </div>
            </dl>
          </div>
        </div>

        <div class="mt-4 rounded-lg border-l-4 border-primary-700 bg-primary-100 p-4 text-sm text-primary-900">
          <div class="text-xs uppercase tracking-wide opacity-80">对子女教育的影响</div>
          <p class="mt-1">{v.zh.child_education}</p>
        </div>

        <div class="mt-5 grid gap-5 sm:grid-cols-2">
          <div>
            <h3 class="text-sm text-primary-900" style="font-weight:500">适合的家庭类型</h3>
            <ul class="mt-2 space-y-1 text-sm text-[color:var(--color-text-primary)]">
              {v.zh.suitable_for.map((s) => <li>✓ {s}</li>)}
            </ul>
          </div>
          <div>
            <h3 class="text-sm" style="font-weight:500; color: var(--color-danger)">注意事项</h3>
            <ul class="mt-2 space-y-1 text-sm text-[color:var(--color-text-primary)]">
              {v.zh.cautions.map((c) => <li>⚠ {c}</li>)}
            </ul>
          </div>
        </div>

        <p class="mt-4 text-xs text-[color:var(--color-text-tertiary)]">
          官方资料:<a href={v.official_url} target="_blank" rel="noopener" class="text-primary-700 hover:underline">{v.official_url} ↗</a>
        </p>
      </section>
    ))}

    <section id="faq" class="mt-16 scroll-mt-24">
      <h2 class="text-xl">常见问题</h2>
      <div class="mt-5 space-y-3">
        {MM2H_FAQS.map((f) => (
          <details class="rounded-lg border p-4" style="border-color: var(--color-border-light)">
            <summary class="cursor-pointer text-sm text-primary-900" style="font-weight:500; list-style: disclosure-closed">{f.q_zh}</summary>
            <p class="mt-3 text-sm text-[color:var(--color-text-primary)]">{f.a_zh}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mt-12 rounded-lg border-l-4 border-accent-500 bg-accent-100 p-5">
      <div class="text-xs uppercase tracking-wide text-accent-700">站长亲身经验</div>
      <p class="mt-2 text-sm text-accent-700">
        站长(David)持有 MM2H,本人居住马来西亚。推荐中介、实际申请流程、费用细节将累积于
        <a href="/zh/guide/" class="underline">指南</a> 的签证类目下。
      </p>
    </section>

    <section class="mt-10 rounded-lg bg-primary-900 p-6 text-white">
      <h2 class="text-lg" style="font-weight:500">不确定哪种签证最适合您家?</h2>
      <p class="mt-2 text-sm opacity-90">
        请提供:孩子年级、目标国家·城市、资产·收入水平。站长将 1:1 答复。
      </p>
      <div class="mt-4">
        <a href="/zh/contact/" class="inline-flex items-center rounded-md bg-white px-4 py-2 text-sm text-primary-900" style="font-weight:500">WeChat 咨询 →</a>
      </div>
    </section>
  </section>
</BaseLayout>
