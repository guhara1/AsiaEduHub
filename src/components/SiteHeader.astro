---
import { resolveLocale, alternateUrlFor, getMessages, type Locale } from '../lib/i18n';
import {
  SOUTHEAST_ASIA,
  ANGLOSPHERE,
  SCHOOL_TYPES,
  COMPARE_TOOLS,
  MM2H_TOPICS,
  GUIDE_CATEGORIES,
  DOMESTIC_KOREA,
  countryName,
  cityName,
} from '../lib/locations';
import { FOREIGN_SCHOOLS, INTERNATIONAL_SCHOOLS } from '../lib/domestic-schools';
import { MALAYSIA_SCHOOLS } from '../lib/malaysia-schools';
import { THAILAND_SCHOOLS, REGION_LABELS as THAI_REGIONS } from '../lib/thailand-schools';
import { SINGAPORE_SCHOOLS } from '../lib/singapore-schools';

const pathname = Astro.url.pathname;
const locale: Locale = resolveLocale(Astro.currentLocale, pathname);
const t = getMessages(locale);

type ChildLink = { kind: 'link'; label: string; href: string };
type ChildHeader = { kind: 'header'; label: string };
type ChildSubmenu = {
  kind: 'submenu';
  label: string;
  href: string; // мһҗмІҙ мқёлҚұмҠӨ нҺҳмқҙм§Җ (мҳҲ: м„ңмҡё мҷёкөӯмқён•ҷкөҗ лӘ©лЎқ)
  children: { label: string; href: string }[]; // н•ҷкөҗ лҰ¬мҠӨнҠё
};
type DropdownChild = ChildLink | ChildHeader | ChildSubmenu;

type MenuItem =
  | { type: 'link'; label: string; href: string }
  | {
      type: 'dropdown';
      label: string;
      children: DropdownChild[];
      viewAll?: ChildLink;
    };

// көӯлӮҙ(н•ңкөӯ) көӯм ңн•ҷкөҗ л“ңлЎӯлӢӨмҡҙ вҖ” 3лӢЁкі„ (м№ҙн…Ңкі лҰ¬ вҶ’ м§Җм—ӯ вҶ’ н•ҷкөҗ)
const domesticChildren: DropdownChild[] = [];
for (const g of DOMESTIC_KOREA) {
  const headerLabel = locale === 'ko'
    ? `${g.ko}${g.ko_sub ? ` В· ${g.ko_sub}` : ''}`
    : `${g.zh}${g.zh_sub ? ` В· ${g.zh_sub}` : ''}`;
  const isCategoryWithRegions = g.regions && g.regions.length > 0;
  const isFsOrIs = g.id === 'foreign-schools' || g.id === 'international-schools';

  if (isCategoryWithRegions && isFsOrIs) {
    domesticChildren.push({ kind: 'header', label: headerLabel });
    for (const r of g.regions!) {
      const allSchools = g.id === 'foreign-schools' ? FOREIGN_SCHOOLS : INTERNATIONAL_SCHOOLS;
      const schoolsInRegion = allSchools.filter((s) => s.region === r.id);
      const regionLabel = locale === 'ko' ? r.ko : r.zh;
      const regionHref = `/${locale}/domestic/${g.id}/${r.id}/`;

      if (schoolsInRegion.length > 0) {
        domesticChildren.push({
          kind: 'submenu',
          label: regionLabel,
          href: regionHref,
          children: [
            ...schoolsInRegion.map((s) => ({
              label: locale === 'ko' ? s.name_ko : s.name_zh,
              href: `/${locale}/domestic/${g.id}/${r.id}/${s.slug}/`,
            })),
            {
              label: locale === 'ko' ? `${regionLabel} м „мІҙ вҶ’` : `${regionLabel} е…ЁйғЁ вҶ’`,
              href: regionHref,
            },
          ],
        });
      } else {
        domesticChildren.push({
          kind: 'link',
          label: regionLabel,
          href: regionHref,
        });
      }
    }
  } else {
    domesticChildren.push({
      kind: 'link',
      label: locale === 'ko' ? g.ko : g.zh,
      href: `/${locale}/domestic/#${g.id}`,
    });
  }
}

// н•ҙмҷё мң н•ҷ л“ңлЎӯлӢӨмҡҙ: лҸҷлӮЁм•„(к°Җм„ұл№„) / мҳҒлҜёк¶Ң(н”„лҰ¬лҜём—„) / н•ҷкөҗ мң нҳ•лі„
const countryChildren: DropdownChild[] = [];
// 1) лҸҷлӮЁм•„ к·ёлЈ№
countryChildren.push({
  kind: 'header',
  label: 'рҹҢҸ ' + (locale === 'ko' ? 'лҸҷлӮЁм•„ (к°Җм„ұл№„)' : 'дёңеҚ—дәҡ(й«ҳжҖ§д»·жҜ”)'),
});
for (const c of SOUTHEAST_ASIA) {
  // л§җл ҲмқҙмӢңм•„лҠ” н•ҷкөҗлі„ sub-menu лЎң нҺјм№Ё (22к°ң н•ҷкөҗ)
  if (c.id === 'malaysia') {
    countryChildren.push({
      kind: 'submenu',
      label: `${c.flag} ${countryName(c, locale)}`,
      href: `/${locale}/abroad/malaysia/`,
      children: [
        ...MALAYSIA_SCHOOLS.map((s) => ({
          label: locale === 'ko' ? s.name_ko : s.name_zh,
          href: `/${locale}/abroad/malaysia/${s.slug}/`,
        })),
        {
          label: locale === 'ko' ? 'рҹҮІрҹҮҫ л§җл ҲмқҙмӢңм•„ м „мІҙ вҶ’' : 'рҹҮІрҹҮҫ й©¬жқҘиҘҝдәҡе…ЁйғЁ вҶ’',
          href: `/${locale}/abroad/malaysia/`,
        },
      ],
    });
  } else if (c.id === 'thailand') {
    // нғңкөӯмқҖ м§Җм—ӯлі„ к·ёлЈ№ + н•ҷкөҗлі„ sub-menu (15к°ң н•ҷкөҗ)
    const thaiChildren: Array<{ label: string; href: string }> = [];
    const regions: Array<'bangkok' | 'pattaya' | 'phuket' | 'chiang-mai'> = ['bangkok', 'pattaya', 'phuket', 'chiang-mai'];
    for (const r of regions) {
      const regionSchools = THAILAND_SCHOOLS.filter((s) => s.region === r);
      if (regionSchools.length === 0) continue;
      // м§Җм—ӯ н—ӨлҚ” (кө¬л¶„мҡ©)
      thaiChildren.push({
        label: `в”Җв”Җ ${locale === 'ko' ? THAI_REGIONS[r].ko : THAI_REGIONS[r].zh} (${regionSchools.length}) в”Җв”Җ`,
        href: `/${locale}/abroad/thailand/${r}/`,
      });
      for (const s of regionSchools) {
        thaiChildren.push({
          label: `   ${locale === 'ko' ? s.name_ko : s.name_zh}`,
          href: `/${locale}/abroad/thailand/${r}/${s.slug}/`,
        });
      }
    }
    thaiChildren.push({
      label: locale === 'ko' ? 'рҹҮ№рҹҮӯ нғңкөӯ м „мІҙ вҶ’' : 'рҹҮ№рҹҮӯ жі°еӣҪе…ЁйғЁ вҶ’',
      href: `/${locale}/abroad/thailand/`,
    });
    countryChildren.push({
      kind: 'submenu',
      label: `${c.flag} ${countryName(c, locale)}`,
      href: `/${locale}/abroad/thailand/`,
      children: thaiChildren,
    });
  } else if (c.id === 'singapore') {
    // мӢұк°ҖнҸ¬лҘҙ вҖ” н•ҷкөҗлі„ sub-menu (9к°ң)
    countryChildren.push({
      kind: 'submenu',
      label: `${c.flag} ${countryName(c, locale)}`,
      href: `/${locale}/abroad/singapore/`,
      children: [
        ...SINGAPORE_SCHOOLS.map((s) => ({
          label: locale === 'ko' ? s.name_ko : s.name_zh,
          href: `/${locale}/abroad/singapore/${s.slug}/`,
        })),
        {
          label: locale === 'ko' ? 'рҹҮёрҹҮ¬ мӢұк°ҖнҸ¬лҘҙ м „мІҙ вҶ’' : 'рҹҮёрҹҮ¬ ж–°еҠ еқЎе…ЁйғЁ вҶ’',
          href: `/${locale}/abroad/singapore/`,
        },
      ],
    });
  } else {
    const cityTrail = c.cities.length > 0
      ? ` (${c.cities.map((city) => cityName(city, locale)).join(' / ')})`
      : '';
    countryChildren.push({
      kind: 'link',
      label: `${c.flag} ${countryName(c, locale)}${cityTrail}`,
      href: `/${locale}/abroad/#${c.id}`,
    });
  }
}
// 2) мҳҒлҜёк¶Ң к·ёлЈ№
countryChildren.push({
  kind: 'header',
  label: 'рҹҢҺ ' + (locale === 'ko' ? 'мҳҒлҜёк¶Ң (н”„лҰ¬лҜём—„)' : 'иӢұзҫҺжҫіеҠ (й«ҳз«Ҝ)'),
});
for (const c of ANGLOSPHERE) {
  countryChildren.push({
    kind: 'link',
    label: `${c.flag} ${countryName(c, locale)}`,
    href: `/${locale}/abroad/#${c.id}`,
  });
}
// 3) н•ҷкөҗ мң нҳ•лі„
countryChildren.push({
  kind: 'header',
  label: 'рҹ“ҡ ' + (locale === 'ko' ? 'н•ҷкөҗ мң нҳ•лі„' : 'жҢүеӯҰж Ўзұ»еһӢ'),
});
for (const t of SCHOOL_TYPES) {
  countryChildren.push({
    kind: 'link',
    label: locale === 'ko' ? t.ko : t.zh,
    href: `/${locale}/abroad/#type-${t.id}`,
  });
}

const compareChildren: DropdownChild[] = COMPARE_TOOLS.map((t) => ({
  kind: 'link',
  label: locale === 'ko' ? t.ko : t.zh,
  href: `/${locale}/tools/compare/#${t.id}`,
}));

const mm2hChildren: DropdownChild[] = MM2H_TOPICS.map((t) => ({
  kind: 'link',
  label: locale === 'ko' ? t.ko : t.zh,
  href: `/${locale}/mm2h/#${t.id}`,
}));

const guideChildren: DropdownChild[] = GUIDE_CATEGORIES.map((g) => ({
  kind: 'link',
  label: locale === 'ko' ? g.ko : g.zh,
  href: g.id === 'expert-columns' ? `/${locale}/experts/` : `/${locale}/guide/#${g.id}`,
}));

const menu: MenuItem[] = [
  {
    type: 'dropdown',
    label: locale === 'ko' ? 'көӯлӮҙ көӯм ңн•ҷкөҗ' : 'йҹ©еӣҪеӣҪйҷ…еӯҰж Ў',
    children: domesticChildren,
    viewAll: {
      kind: 'link',
      label: locale === 'ko' ? 'көӯлӮҙ н•ҷкөҗ м „мІҙ вҶ’' : 'жҹҘзңӢе…ЁйғЁ вҶ’',
      href: `/${locale}/domestic/`,
    },
  },
  {
    type: 'dropdown',
    label: locale === 'ko' ? 'н•ҙмҷё мң н•ҷ' : 'жө·еӨ–з•ҷеӯҰ',
    children: countryChildren,
    viewAll: {
      kind: 'link',
      label: locale === 'ko' ? 'н•ҙмҷё н•ҷкөҗ м „мІҙ вҶ’' : 'жҹҘзңӢе…ЁйғЁ вҶ’',
      href: `/${locale}/abroad/`,
    },
  },
  {
    type: 'dropdown',
    label: locale === 'ko' ? 'л№„көҗ / лҸ„кө¬' : 'еҜ№жҜ” / е·Ҙе…·',
    children: compareChildren,
    viewAll: {
      kind: 'link',
      label: locale === 'ko' ? 'л№„көҗ лҸ„кө¬ м „мІҙ вҶ’' : 'жҹҘзңӢе…ЁйғЁеҜ№жҜ”е·Ҙе…· вҶ’',
      href: `/${locale}/tools/compare/`,
    },
  },
  {
    type: 'dropdown',
    label: locale === 'ko' ? 'MM2H В· мқҙмЈј' : 'MM2H В· з§»еұ…',
    children: mm2hChildren,
    viewAll: {
      kind: 'link',
      label: locale === 'ko' ? 'м „мІҙ ліҙкё° вҶ’' : 'жҹҘзңӢе…ЁйғЁ вҶ’',
      href: `/${locale}/mm2h/`,
    },
  },
  {
    type: 'dropdown',
    label: locale === 'ko' ? 'к°Җмқҙл“ң' : 'жҢҮеҚ—',
    children: guideChildren,
    viewAll: {
      kind: 'link',
      label: locale === 'ko' ? 'м „мІҙ к°Җмқҙл“ң ліҙкё° вҶ’' : 'жҹҘзңӢе…ЁйғЁжҢҮеҚ— вҶ’',
      href: `/${locale}/guide/`,
    },
  },
  { type: 'link', label: locale === 'ko' ? 'мғҒлӢҙмӢ мІӯ' : 'е…Қиҙ№е’ЁиҜў', href: `/${locale}/contact/` },
];

const koUrl = alternateUrlFor(pathname, 'ko');
const zhUrl = alternateUrlFor(pathname, 'zh');
const menuLabel = locale === 'ko' ? 'л©”лүҙ' : 'иҸңеҚ•';
const closeLabel = locale === 'ko' ? 'лӢ«кё°' : 'е…ій—ӯ';
const langLabel = locale === 'ko' ? 'м–ём–ҙ' : 'иҜӯиЁҖ';
---
<header class="border-b bg-white" style="border-color: var(--color-border-light)">
  <div class="container-content flex h-16 items-center justify-between gap-3">
    <a href={`/${locale}/`} class="flex items-center gap-2 text-primary-900 shrink-0" style="font-weight:500" aria-label="AsiaEduHub">
      <span aria-hidden="true" class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-primary-900 text-white text-sm">D</span>
      <span class="text-base hidden lg:inline">{t.site.name}</span>
      <span class="text-base lg:hidden">AsiaEduHub</span>
    </a>

    {/* PC л©”лүҙ (md+) */}
    <nav class="hidden md:flex items-center gap-1 lg:gap-2 text-sm" aria-label={menuLabel}>
      {menu.map((item) =>
        item.type === 'link' ? (
          <a href={item.href} class="px-2 py-2 text-[color:var(--color-text-primary)] hover:text-primary-700 whitespace-nowrap">
            {item.label}
          </a>
        ) : (
          <details class="dropdown relative">
            <summary class="dropdown-summary list-none cursor-pointer px-2 py-2 inline-flex items-center gap-1 text-[color:var(--color-text-primary)] hover:text-primary-700 whitespace-nowrap">
              {item.label}
              <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" class="opacity-60"><path d="M1 3l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
            </summary>
            <div
              class="dropdown-panel absolute left-0 top-full z-30 mt-1 min-w-[220px] rounded-md border bg-white py-2 shadow-lg"
              style="border-color: var(--color-border-light)"
            >
              {item.children.map((c) =>
                c.kind === 'header' ? (
                  <div class="px-3 pt-2 pb-1 text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">{c.label}</div>
                ) : c.kind === 'submenu' ? (
                  <div class="submenu-wrap relative">
                    <a
                      href={c.href}
                      class="flex items-center justify-between gap-2 px-3 py-1.5 text-sm text-[color:var(--color-text-primary)] hover:bg-[var(--color-bg-secondary)] hover:text-primary-700"
                    >
                      <span>{c.label}</span>
                      <svg width="9" height="9" viewBox="0 0 10 10" aria-hidden="true" class="opacity-60"><path d="M3 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
                    </a>
                    <div
                      class="submenu-panel absolute left-full top-0 z-40 min-w-[200px] rounded-md border bg-white py-2 shadow-lg"
                      style="border-color: var(--color-border-light)"
                    >
                      {c.children.map((sc, i) => (
                        <a
                          href={sc.href}
                          class:list={[
                            'block px-3 py-1.5 text-sm hover:bg-[var(--color-bg-secondary)] hover:text-primary-700',
                            i === c.children.length - 1
                              ? 'mt-1 border-t pt-2 text-primary-900'
                              : 'text-[color:var(--color-text-primary)]',
                          ]}
                          style={i === c.children.length - 1 ? 'border-color: var(--color-border-light); font-weight:500' : ''}
                        >
                          {sc.label}
                        </a>
                      ))}
                    </div>
                  </div>
                ) : (
                  <a href={c.href} class="block px-3 py-1.5 text-sm text-[color:var(--color-text-primary)] hover:bg-[var(--color-bg-secondary)] hover:text-primary-700">
                    {c.label}
                  </a>
                )
              )}
              {item.viewAll && (
                <>
                  <div class="my-1 border-t" style="border-color: var(--color-border-light)"></div>
                  <a
                    href={item.viewAll.href}
                    class="block px-3 py-1.5 text-sm text-primary-900 hover:bg-[var(--color-bg-secondary)]"
                    style="font-weight:500"
                  >
                    {item.viewAll.label}
                  </a>
                </>
              )}
            </div>
          </details>
        )
      )}
    </nav>

    <div class="flex items-center gap-2">
      {/* лӘЁл°”мқј мғҒлӢҙ CTA вҖ” н–„лІ„кұ° л°– н•ӯмғҒ л…ём¶ң (м „нҷҳмңЁ вҶ‘) */}
      <a
        href={`/${locale}/contact/`}
        class="md:hidden inline-flex items-center justify-center rounded-md bg-primary-900 px-3 py-1.5 text-xs text-white"
        style="font-weight:500"
        aria-label={locale === 'ko' ? 'л¬ҙлЈҢ мғҒлӢҙ мӢ мІӯ' : 'е…Қиҙ№е’ЁиҜў'}
      >
        {locale === 'ko' ? 'мғҒлӢҙ' : 'е’ЁиҜў'}
      </a>

      {/* м–ём–ҙ нҶ кёҖ */}
      <div
        class="inline-flex items-center rounded-md border text-xs"
        style="border-color: var(--color-border-light)"
        role="group"
        aria-label={langLabel}
      >
        <a
          href={koUrl}
          aria-current={locale === 'ko' ? 'true' : undefined}
          class:list={[
            'px-2 py-1 rounded-l-md inline-flex items-center gap-1',
            locale === 'ko' ? 'bg-primary-100 text-primary-900' : 'text-[color:var(--color-text-secondary)] hover:text-primary-700',
          ]}
          style={locale === 'ko' ? 'font-weight:500' : ''}
        >
          <span aria-hidden="true">рҹҮ°рҹҮ·</span>
          <span class="hidden sm:inline">н•ңкөӯм–ҙ</span>
        </a>
        <span class="text-[color:var(--color-text-tertiary)]" aria-hidden="true">|</span>
        <a
          href={zhUrl}
          aria-current={locale === 'zh' ? 'true' : undefined}
          class:list={[
            'px-2 py-1 rounded-r-md inline-flex items-center gap-1',
            locale === 'zh' ? 'bg-primary-100 text-primary-900' : 'text-[color:var(--color-text-secondary)] hover:text-primary-700',
          ]}
          style={locale === 'zh' ? 'font-weight:500' : ''}
        >
          <span aria-hidden="true">рҹҮЁрҹҮі</span>
          <span class="hidden sm:inline">дёӯж–Ү</span>
        </a>
      </div>

      {/* н…Ңл§Ҳ нҶ кёҖ */}
      <button
        id="theme-toggle"
        type="button"
        class="theme-toggle"
        aria-label={locale === 'ko' ? 'н…Ңл§Ҳ м „нҷҳ' : 'дё»йўҳеҲҮжҚў'}
        title={locale === 'ko' ? 'лқјмқҙнҠё / лӢӨнҒ¬ лӘЁл“ң м „нҷҳ' : 'жө…иүІ / ж·ұиүІжЁЎејҸ'}
      >
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </button>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-[color:var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={menuLabel}
      >
        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" fill="none"/>
        </svg>
      </button>
    </div>
  </div>
</header>

{/* лӘЁл°”мқј н’ҖмҠӨнҒ¬лҰ° л©”лүҙ */}
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 overflow-y-auto bg-white md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label={menuLabel}
  hidden
>
  <div class="flex h-16 items-center justify-between px-4 border-b" style="border-color: var(--color-border-light)">
    <div class="flex items-center gap-2 text-primary-900" style="font-weight:500">
      <span aria-hidden="true" class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-primary-900 text-white text-sm">D</span>
      <span>AsiaEduHub</span>
    </div>
    <button
      id="mobile-menu-close"
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-[color:var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]"
      aria-label={closeLabel}
    >
      <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 5l14 14M19 5L5 19" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" fill="none"/>
      </svg>
    </button>
  </div>

  <nav class="px-4 py-4" aria-label={menuLabel}>
    <ul class="space-y-1">
      {menu.map((item) =>
        item.type === 'link' ? (
          <li>
            <a href={item.href} class="block rounded-md px-3 py-3 text-base text-[color:var(--color-text-primary)] hover:bg-[var(--color-bg-secondary)]" style="font-weight:500">
              {item.label}
            </a>
          </li>
        ) : (
          <li>
            <details class="rounded-md">
              <summary class="dropdown-summary list-none cursor-pointer rounded-md px-3 py-3 text-base hover:bg-[var(--color-bg-secondary)] flex items-center justify-between" style="font-weight:500">
                {item.label}
                <svg width="12" height="12" viewBox="0 0 10 10" aria-hidden="true" class="opacity-60"><path d="M1 3l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
              </summary>
              <div class="ml-2 mt-1 mb-2 border-l pl-3" style="border-color: var(--color-border-light)">
                {item.children.map((c) =>
                  c.kind === 'header' ? (
                    <div class="px-2 pt-2 pb-1 text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">{c.label}</div>
                  ) : c.kind === 'submenu' ? (
                    <details class="rounded-md">
                      <summary class="dropdown-summary list-none cursor-pointer rounded-md px-2 py-2 text-sm hover:bg-[var(--color-bg-secondary)] flex items-center justify-between">
                        <span style="font-weight:500">{c.label}</span>
                        <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" class="opacity-60"><path d="M1 3l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
                      </summary>
                      <div class="ml-2 mt-1 mb-1 border-l pl-2" style="border-color: var(--color-border-light)">
                        {c.children.map((sc, i) => (
                          <a
                            href={sc.href}
                            class:list={[
                              'block rounded-md px-2 py-1.5 text-sm',
                              i === c.children.length - 1
                                ? 'text-primary-900'
                                : 'text-[color:var(--color-text-primary)] hover:bg-[var(--color-bg-secondary)]',
                            ]}
                            style={i === c.children.length - 1 ? 'font-weight:500' : ''}
                          >
                            {sc.label}
                          </a>
                        ))}
                      </div>
                    </details>
                  ) : (
                    <a href={c.href} class="block rounded-md px-2 py-2 text-sm text-[color:var(--color-text-primary)] hover:bg-[var(--color-bg-secondary)]">{c.label}</a>
                  )
                )}
                {item.viewAll && (
                  <a href={item.viewAll.href} class="mt-1 block rounded-md px-2 py-2 text-sm text-primary-900" style="font-weight:500">
                    {item.viewAll.label}
                  </a>
                )}
              </div>
            </details>
          </li>
        )
      )}
    </ul>

    <div class="mt-6 px-3">
      <div class="text-xs text-[color:var(--color-text-tertiary)]">{langLabel}</div>
      <div class="mt-2 inline-flex items-center rounded-md border text-sm" style="border-color: var(--color-border-light)">
        <a href={koUrl} aria-current={locale === 'ko' ? 'true' : undefined}
           class:list={['px-3 py-2 rounded-l-md', locale === 'ko' ? 'bg-primary-100 text-primary-900' : '']}
           style={locale === 'ko' ? 'font-weight:500' : ''}>рҹҮ°рҹҮ· н•ңкөӯм–ҙ</a>
        <span class="text-[color:var(--color-text-tertiary)] px-1" aria-hidden="true">|</span>
        <a href={zhUrl} aria-current={locale === 'zh' ? 'true' : undefined}
           class:list={['px-3 py-2 rounded-r-md', locale === 'zh' ? 'bg-primary-100 text-primary-900' : '']}
           style={locale === 'zh' ? 'font-weight:500' : ''}>рҹҮЁрҹҮі дёӯж–Ү</a>
      </div>
    </div>
  </nav>
</div>

<style>
  /* details/summary кё°ліё л””мҠӨнҒҙлЎңм Җ м•„мқҙмҪҳ м ңкұ° */
  .dropdown-summary::-webkit-details-marker { display: none; }
  .dropdown-summary::marker { content: ''; }

  /* PC submenu: нҸүмҶҢ мҲЁк№Җ, л¶ҖлӘЁ hover лҳҗлҠ” focus-within мӢң н‘ңмӢң */
  .submenu-panel { display: none; max-height: 80vh; overflow-y: auto; }
  .submenu-wrap:hover > .submenu-panel,
  .submenu-wrap:focus-within > .submenu-panel { display: block; }

  /* mouse к°Җ submenu panel лЎң мқҙлҸҷн•  л•Ң hover к°Җ лҒҠкё°м§Җ м•ҠлҸ„лЎқ м•Ҫк°„мқҳ right-margin нҷ•ліҙ */
  .submenu-wrap > a { padding-right: 1.5rem; }
</style>

<script>
  // 1) PC л“ңлЎӯлӢӨмҡҙ: мҷёл¶Җ нҒҙлҰӯ / Esc лЎң лӢ«кё°
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    document.querySelectorAll<HTMLDetailsElement>('details.dropdown[open]').forEach((d) => {
      if (!d.contains(target)) d.removeAttribute('open');
    });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll<HTMLDetailsElement>('details.dropdown[open]').forEach((d) => d.removeAttribute('open'));
      // лӘЁл°”мқј л©”лүҙлҸ„ Esc лЎң лӢ«кё°
      const m = document.getElementById('mobile-menu');
      const t = document.getElementById('mobile-menu-toggle');
      if (m && t && !m.hidden) {
        m.hidden = true;
        t.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    }
  });

  // 2) лӢӨнҒ¬ лӘЁл“ң нҶ кёҖ
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const isDark = root.getAttribute('data-theme') === 'dark';
    if (isDark) {
      root.removeAttribute('data-theme');
      try { localStorage.setItem('aeh-theme', 'light'); } catch (e) {}
    } else {
      root.setAttribute('data-theme', 'dark');
      try { localStorage.setItem('aeh-theme', 'dark'); } catch (e) {}
    }
  });

  // 3) лӘЁл°”мқј н–„лІ„кұ°
  const toggle = document.getElementById('mobile-menu-toggle');
  const menuEl = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-menu-close');
  toggle?.addEventListener('click', () => {
    if (!menuEl) return;
    menuEl.hidden = false;
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  });
  closeBtn?.addEventListener('click', () => {
    if (!menuEl || !toggle) return;
    menuEl.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  });
</script>
