---
import { resolveLocale, alternateUrlFor, getMessages, type Locale } from '../lib/i18n';

const pathname = Astro.url.pathname;
const locale: Locale = resolveLocale(Astro.currentLocale, pathname);
const t = getMessages(locale);
const otherLocale: Locale = locale === 'ko' ? 'zh' : 'ko';
const otherUrl = alternateUrlFor(pathname, otherLocale);

const navItems = [
  { label: t.nav.domestic, href: `/${locale}/domestic/` },
  { label: t.nav.abroad, href: `/${locale}/abroad/` },
  { label: t.nav.compare, href: `/${locale}/tools/compare/` },
  { label: t.nav.guide, href: `/${locale}/guide/` },
  { label: t.nav.experience, href: `/${locale}/experience/` },
];
---
<header class="border-b" style="border-color: var(--color-border-light)">
  <div class="container-content flex h-16 items-center justify-between gap-4">
    <a href={`/${locale}/`} class="flex items-center gap-2 text-primary-900" style="font-weight:500">
      {/* D 모노그램 — 사양 사이트 로고 */}
      <span aria-hidden="true" class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-primary-900 text-white text-sm">D</span>
      <span class="text-base">{t.site.name}</span>
    </a>

    <nav class="hidden items-center gap-6 text-sm md:flex">
      {navItems.map((item) => (
        <a href={item.href} class="text-[color:var(--color-text-primary)] hover:text-primary-700">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href={`/${locale}/contact/`} class="cta-primary text-sm py-2 px-3 hidden sm:inline-flex">
        {t.nav.consultation}
      </a>
      <a
        href={otherUrl}
        aria-label={t.nav.language}
        class="rounded-md border px-2.5 py-1 text-xs text-[color:var(--color-text-secondary)]"
        style="border-color: var(--color-border-light)"
      >
        {otherLocale === 'ko' ? '한국어' : '中文'}
      </a>
    </div>
  </div>
</header>
