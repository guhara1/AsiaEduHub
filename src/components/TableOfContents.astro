---
/**
 * 가이드·블로그·정보 페이지용 사이드 인덱스 (Table of Contents).
 * Astro 빌드 시점엔 본문 h2/h3 를 파악할 수 없으므로,
 * 클라이언트에서 JS 로 article 내 h2/h3 를 추출해 목차 + ScrollSpy + 진행률.
 */
import type { Locale } from '~/lib/i18n';
export interface Props {
  locale: Locale;
  /** TOC가 스캔할 article 또는 영역의 선택자. 기본 'article' */
  targetSelector?: string;
}
const { locale, targetSelector = 'article' } = Astro.props;
const tocLabel = locale === 'ko' ? '목차' : '目录';
const sectionsLabel = locale === 'ko' ? '섹션' : '章节';
const topLabel = locale === 'ko' ? '맨 위로' : '回到顶部';
---
<nav
  aria-label={tocLabel}
  class="toc"
  data-toc-target={targetSelector}
>
  <div class="toc-header">
    <div class="toc-label">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      {tocLabel}
    </div>
    <span class="toc-count" id="toc-count" data-sections-label={sectionsLabel}></span>
  </div>
  <ol class="toc-list" id="toc-list">
    {/* JS 로 채워짐 */}
  </ol>
  <a href="#top" class="toc-top">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    {topLabel}
  </a>
</nav>

<script>
  (function () {
    document.querySelectorAll('[data-toc-target]').forEach((tocEl) => {
      const targetSelector = (tocEl as HTMLElement).dataset.tocTarget || 'article';
      const target = document.querySelector(targetSelector);
      const list = tocEl.querySelector('#toc-list') as HTMLOListElement | null;
      const countEl = tocEl.querySelector('#toc-count') as HTMLElement | null;
      if (!target || !list) return;

      const headings = Array.from(target.querySelectorAll('h2, h3')) as HTMLElement[];
      if (headings.length === 0) {
        (tocEl as HTMLElement).style.display = 'none';
        return;
      }

      // 각 heading 에 id 자동 부여 (없으면)
      headings.forEach((h, i) => {
        if (!h.id) {
          const text = (h.textContent || '').trim().toLowerCase();
          const slug = text.replace(/[^\p{L}\p{N}]+/gu, '-').replace(/^-|-$/g, '');
          h.id = slug || `toc-${i}`;
        }
        h.style.scrollMarginTop = '96px';
      });

      // h2 만 번호 부여 (h3 는 sub item)
      let h2Index = 0;
      const items = headings.map((h) => {
        const isH2 = h.tagName === 'H2';
        if (isH2) h2Index++;
        const li = document.createElement('li');
        li.className = isH2 ? 'toc-item toc-h2' : 'toc-item toc-h3';
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.className = 'toc-link';
        a.dataset.tocId = h.id;

        if (isH2) {
          const num = document.createElement('span');
          num.className = 'toc-num';
          num.textContent = String(h2Index).padStart(2, '0');
          a.appendChild(num);
        } else {
          const dot = document.createElement('span');
          dot.className = 'toc-dot';
          dot.setAttribute('aria-hidden', 'true');
          a.appendChild(dot);
        }

        const text = document.createElement('span');
        text.className = 'toc-text';
        // ' — ' 구분자 이전을 strong, 이후를 가벼운 색으로 분리 (매거진 스타일)
        const fullText = (h.textContent || '').trim();
        const dashIdx = fullText.indexOf(' — ');
        if (dashIdx > -1 && isH2) {
          const main = document.createElement('span');
          main.className = 'toc-text-main';
          main.textContent = fullText.slice(0, dashIdx);
          const sub = document.createElement('span');
          sub.className = 'toc-text-sub';
          sub.textContent = fullText.slice(dashIdx + 3);
          text.appendChild(main);
          text.appendChild(sub);
        } else {
          text.textContent = fullText;
        }
        a.appendChild(text);
        li.appendChild(a);
        return { li, link: a, heading: h };
      });
      items.forEach((it) => list.appendChild(it.li));

      // 섹션 수 표시 (h2 만)
      if (countEl) {
        const label = countEl.dataset.sectionsLabel || '';
        countEl.textContent = `${h2Index} ${label}`;
      }

      // ScrollSpy
      if ('IntersectionObserver' in window) {
        const linkMap = new Map(items.map((it) => [it.heading.id, it.link]));
        let activeId: string | null = null;
        const setActive = (id: string | null) => {
          if (id === activeId) return;
          if (activeId) linkMap.get(activeId)?.classList.remove('active');
          activeId = id;
          if (id) linkMap.get(id)?.classList.add('active');
        };
        const visible = new Set<string>();
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              const id = (e.target as HTMLElement).id;
              if (e.isIntersecting) visible.add(id);
              else visible.delete(id);
            });
            for (const it of items) {
              if (visible.has(it.heading.id)) {
                setActive(it.heading.id);
                return;
              }
            }
          },
          { rootMargin: '-96px 0px -70% 0px' }
        );
        headings.forEach((h) => io.observe(h));
      }
    });
  })();
</script>
