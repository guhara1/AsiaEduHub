---
import BaseLayout from '~/layouts/BaseLayout.astro';
import type { Locale } from '~/lib/i18n';

export interface CategoryItem {
  id: string;
  label: string;
  description?: string;
  /** 별도 페이지로 연결할 경우. 없으면 anchor 섹션만. */
  href?: string;
  /** 강조 배지 표시(킬러 콘텐츠 등) */
  highlight?: string;
}

export interface Props {
  locale: Locale;
  pageTitle: string;
  metaDescription: string;
  h1: string;
  intro: string;
  categories: CategoryItem[];
  /** 콘텐츠 누적 전 stub 상태 = true → noindex */
  draftMode?: boolean;
  breadcrumbName: string;
}

const { locale, pageTitle, metaDescription, h1, intro, categories, draftMode = true, breadcrumbName } = Astro.props;

const T = {
  ko: {
    home: '홈',
    quickJump: '빠른 이동',
    emptyMsg: '운영자가 직접 작성·검증한 콘텐츠가 누적되는 카테고리입니다. 지금 바로 운영자에게 1:1 상담을 받으실 수 있습니다.',
    cta: '무료 상담 신청 →',
    contact: `/${locale}/contact/`,
    draftNotice: '이 페이지는 운영자 콘텐츠가 누적되는 동안 검색엔진 노출이 제한됩니다 (noindex).',
  },
  zh: {
    home: '首页',
    quickJump: '快速跳转',
    emptyMsg: '本类目正在由站长亲自撰写·核实并陆续上架。如有具体问题,可立即向站长 1:1 咨询。',
    cta: '免费咨询 →',
    contact: `/${locale}/contact/`,
    draftNotice: '本页面在内容累积期间限制搜索引擎收录(noindex)。',
  },
}[locale];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AsiaEduHub', item: (Astro.site?.toString() ?? '') + locale + '/' },
    { '@type': 'ListItem', position: 2, name: breadcrumbName },
  ],
};
---
<BaseLayout title={pageTitle} description={metaDescription} noindex={draftMode} jsonLd={breadcrumb}>
  <section class="container-content py-10">
    <nav class="text-sm text-[color:var(--color-text-secondary)]"><a href={`/${locale}/`}>{T.home}</a> · {breadcrumbName}</nav>
    <h1 class="mt-2 text-2xl sm:text-3xl">{h1}</h1>
    <p class="mt-3 max-w-2xl text-sm text-[color:var(--color-text-secondary)]">{intro}</p>

    <div class="mt-6">
      <div class="text-xs uppercase tracking-wide text-[color:var(--color-text-tertiary)]">{T.quickJump}</div>
      <div class="mt-2 flex flex-wrap gap-2">
        {categories.map((c) => (
          <a href={`#${c.id}`} class="rounded-full border px-3 py-1 text-xs hover:border-primary-700 hover:text-primary-700" style="border-color: var(--color-border-light)">
            {c.label}
          </a>
        ))}
      </div>
    </div>

    {categories.map((c) => (
      <section id={c.id} class="mt-12 scroll-mt-24">
        <div class="flex flex-wrap items-center gap-2 border-b pb-2" style="border-color: var(--color-border-light)">
          <h2 class="text-xl">{c.label}</h2>
          {c.highlight && <span class="badge-gold">⭐ {c.highlight}</span>}
        </div>
        {c.description && (
          <p class="mt-3 text-sm text-[color:var(--color-text-secondary)]">{c.description}</p>
        )}
        <p class="mt-4 text-sm text-[color:var(--color-text-secondary)]">{T.emptyMsg}</p>
        <div class="mt-4 flex flex-wrap gap-3">
          {c.href && (
            <a href={c.href} class="cta-secondary text-sm">
              {locale === 'ko' ? '카테고리 페이지로' : '前往该分类页面'}
            </a>
          )}
          <a href={T.contact} class="cta-primary text-sm">{T.cta}</a>
        </div>
      </section>
    ))}

    {draftMode && (
      <p class="mt-12 text-xs text-[color:var(--color-text-tertiary)]">※ {T.draftNotice}</p>
    )}
  </section>
</BaseLayout>
