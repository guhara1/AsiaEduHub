---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import AdRail from '../components/AdRail.astro';
import MobileStickyAd from '../components/MobileStickyAd.astro';
import { resolveLocale, alternateUrlFor, HTML_LANG, getMessages } from '../lib/i18n';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  /** 페이지에 사용된 schema.org JSON-LD 객체(들). breadcrumb 등 page 단위 schema 는 여기로 전달. */
  jsonLd?: object | object[];
  /** 정보 페이지의 작성자·발행·업데이트 메타.
   *  지정 시 Article schema 자동 생성 + meta 태그 추가. */
  author?: { name: string; url?: string };
  publishedAt?: Date;
  updatedAt?: Date;
  /** Article schema 타입. 기본 'Article'. */
  articleType?: 'Article' | 'NewsArticle' | 'BlogPosting';
}

const { title, description, ogImage, noindex = false, jsonLd, author, publishedAt, updatedAt, articleType = 'Article' } = Astro.props;

const pathname = Astro.url.pathname;
const locale = resolveLocale(Astro.currentLocale, pathname);
const htmlLang = HTML_LANG[locale];
const t = getMessages(locale);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = siteUrl + pathname;
const altKo = siteUrl + alternateUrlFor(pathname, 'ko');
const altZh = siteUrl + alternateUrlFor(pathname, 'zh');
const ogImageUrl = ogImage ? (ogImage.startsWith('http') ? ogImage : siteUrl + ogImage) : siteUrl + '/og-default.png';

const jsonLdArray: object[] = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// Article schema 자동 생성 (author + publishedAt 둘 다 있을 때만)
if (author && publishedAt) {
  jsonLdArray.push({
    '@context': 'https://schema.org',
    '@type': articleType,
    headline: title,
    description,
    image: [ogImageUrl], // 사양 9순위: schema.image + og:image 매칭
    datePublished: publishedAt.toISOString(),
    dateModified: (updatedAt ?? publishedAt).toISOString(),
    author: {
      '@type': 'Person',
      name: author.name,
      url: author.url ? siteUrl + author.url : undefined,
    },
    publisher: {
      '@type': 'Organization',
      name: t.site.name,
      url: siteUrl + '/',
      logo: { '@type': 'ImageObject', url: siteUrl + '/favicon.svg' },
    },
    inLanguage: htmlLang,
    // 음성 검색·Google Assistant 대응 (speakable)
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['h1', 'article > p:first-of-type', '[data-speakable]'],
    },
  });
}
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    {/* FOUC 방지: 페이지 로드 전 테마 적용 */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('aeh-theme');
          var prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = saved || (prefers ? 'dark' : 'light');
          if (theme === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1E3A8A" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0F172A" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light dark" />
    <meta name="format-detection" content="telephone=no" />

    {/* 퍼포먼스 힌트 — LCP 개선 */}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* hreflang — 사양상 ko/zh 상호 매칭 필수 */}
    <link rel="alternate" hreflang="ko-KR" href={altKo} />
    <link rel="alternate" hreflang="zh-CN" href={altZh} />
    <link rel="alternate" hreflang="x-default" href={altKo} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={t.site.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={htmlLang.replace('-', '_')} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Article 메타 (정보 페이지) */}
    {author && <meta name="author" content={author.name} />}
    {publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
    {updatedAt && <meta property="article:modified_time" content={updatedAt.toISOString()} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* RSS — 콘텐츠 신선도 신호 */}
    <link rel="alternate" type="application/rss+xml" title="AsiaEduHub 가이드 (한국어)" href="/ko/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="AsiaEduHub 指南 (中文)" href="/zh/rss.xml" />

    {jsonLdArray.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    <slot name="head" />
  </head>
  <body class="min-h-screen bg-white text-[color:var(--color-text-primary)]">
    <SiteHeader />
    {/* 광고 슬롯 — 광고주 체결 전까지 비활성. 활성화 시 아래 4줄 주석 해제.
    <AdRail side="left" locale={locale} />
    <AdRail side="right" locale={locale} />
    */}
    <main>
      <slot />
    </main>
    <SiteFooter />
    {/* <MobileStickyAd locale={locale} /> */}

    {/* IntersectionObserver — data-reveal 요소 fade-in */}
    <script>
      (function () {
        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('in-view'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -80px 0px', threshold: 0.05 }
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
